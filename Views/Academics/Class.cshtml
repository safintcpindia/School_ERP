@*
    ======================================================================
    VIEW: Academics / Class.cshtml
    PURPOSE: User interface for managing Classes and their Section mappings.
    ======================================================================
*@
@model SchoolERP.Net.Models.MstClassPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Class Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
        
    var canAdd = PermHelper.HasPermissionByUrl("/Academics/Class", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Academics/Class", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Academics/Class", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-1 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Class Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary" id="btnAddClass" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-edit me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

<div id="classPageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="classesTable">
                        <thead>
                            <tr class="bg-light">
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Class Name</th>
                                <th>Sections</th>
                                <th>Status</th>
                                <th>Created On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Classes)
                            {
                                <tr class="item-row" onclick="selectItem(@c.ClassID, this)" style="cursor: pointer;">
                                    <td class="ps-4 text-center">
                                        <input type="radio" name="selectedClass" class="form-check-input" value="@c.ClassID">
                                    </td>
                                    <td>@c.ClassName</td>
                                    <td>@c.SectionNames</td>
                                    <td>
                                        @if (canEdit)
                                        {
                                            <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                <input class="form-check-input class-status-switch" type="checkbox" @(c.IsActive ? "checked" : "") onchange="toggleStatus(@c.ClassID, this.checked)">
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span>
                                        }
                                    </td>
                                    <td>@c.CreatedOn.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header p-3">
                <h5 class="modal-title" id="modalTitle">Add Class</h5>
                <div class="ms-auto d-flex align-items-center gap-1">                    
                    <button type="button" class="btn btn-success" id="btnSave" onclick="saveItem()">
                        <i class="ti ti-cloud me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                </div>
            </div>
            <div class="modal-body p-3">
                <div id="classModalNotice"></div>
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Class Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtClassName" placeholder="e.g. 1st Class" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtClassName"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Assign Sections <span class="text-danger">*</span></label>
                        <select id="ddlSections" class="form-control select2" multiple data-placeholder="Select Sections">
                            @foreach (var s in Model.AvailableSections)
                            {
                                <option value="@s.SectionID">@s.SectionName</option>
                            }
                        </select>
                        <div class="invalid-feedback" id="errDdlSections"></div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" checked>
                        <label class="form-check-label fw-bold" for="isActive">Active</label>                        
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Select2 Bootstrap 5 Integration */
        .select2-container--default .select2-selection--multiple {
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            min-height: 38px;
            padding: 2px 5px;
        }
        .select2-container--default.select2-container--focus .select2-selection--multiple {
            border-color: #86b7fe;
            outline: 0;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }
        .select2-container--default .select2-selection--multiple .select2-selection__choice {
            background-color: #0d6efd;
            border: none;
            color: #fff;
            border-radius: 4px;
            padding: 2px 8px;
            margin-top: 4px;
        }
        .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
            color: #fff;
            margin-right: 5px;
            border: none;
            background: none;
        }
        .select2-container--default .select2-selection--multiple .select2-selection__choice__remove:hover {
            color: #ffc107;
            background: none;
        }
        .select2-container {
            width: 100% !important;
        }
        .select2-dropdown {
            z-index: 1060; /* Higher than bootstrap modal */
        }
    </style>
}

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const IV = window.InlineFormValidation || {
            clearMap: (map) => Object.keys(map).forEach(k => { 
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }),
            setFieldError: (id, errId, msg) => {
                document.getElementById(id)?.classList.add('is-invalid');
                const err = document.getElementById(errId); if(err) err.textContent = msg;
            },
            setNotice: (id, msg) => {
                const el = document.getElementById(id);
                if(el) el.innerHTML = `<div class="alert alert-danger alert-dismissible fade show" role="alert">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
            },
            clearNotice: (id) => { const el = document.getElementById(id); if(el) el.innerHTML = ''; },
            bindAutoClear: (map) => Object.keys(map).forEach(k => document.getElementById(k)?.addEventListener('input', () => {
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }))
        };

        const classFieldMap = { txtClassName: 'errTxtClassName', ddlSections: 'errDdlSections' };
        const itemModalEl = document.getElementById('itemModal');
        const itemModal = new bootstrap.Modal(itemModalEl);
        let selectedClassId = 0;

        $(document).ready(function() {
            $('#ddlSections').select2({
                dropdownParent: $('#itemModal'),
                placeholder: "Select Sections",
                allowClear: true
            });
        });

        function clearModalValidation() {
            IV.clearMap(classFieldMap);
            IV.clearNotice('classModalNotice');
        }

        IV.bindAutoClear(classFieldMap);

        function selectItem(id, row) {
            IV.clearNotice('classPageNotice');
            selectedClassId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            row.querySelector('input[type="radio"]').checked = true;
            const btnEdit = document.getElementById('btnEdit');
            const btnDelete = document.getElementById('btnDelete');
            if (btnEdit && permCanEdit) btnEdit.disabled = false;
            if (btnDelete && permCanDelete) btnDelete.disabled = false;
        }

        function openAddModal() {
            if (!permCanAdd) {
                IV.setNotice('classPageNotice', 'You do not have permission to add.');
                return;
            }
            IV.clearNotice('classPageNotice');
            clearModalValidation();
            document.getElementById('modalTitle').textContent = 'Add Class';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            
            // Clear multiple select
            $('#ddlSections').val(null).trigger('change');
            
            itemModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) {
                IV.setNotice('classPageNotice', 'You do not have permission to edit.');
                return;
            }
            if (selectedClassId === 0) return;
            IV.clearNotice('classPageNotice');
            clearModalValidation();
            try {
                const resp = await fetch(`/Academics/GetClass?id=${selectedClassId}`);
                const res = await resp.json();
                if (res.success) {
                    document.getElementById('modalTitle').textContent = 'Edit Class';
                    document.getElementById('txtItemId').value = res.data.classID;
                    document.getElementById('txtClassName').value = res.data.className;
                    document.getElementById('isActive').checked = res.data.isActive;
                    
                    // Set multiple select
                    const selectedIds = res.data.sectionIds || [];
                    $('#ddlSections').val(selectedIds).trigger('change');
                    
                    itemModal.show();
                } else {
                    IV.setNotice('classPageNotice', res.message || 'Could not load class.');
                }
            } catch (err) {
                console.error(err);
                IV.setNotice('classPageNotice', 'Could not load class details.');
            }
        }

        async function deleteSelected() {
            if (!permCanDelete) {
                IV.setNotice('classPageNotice', 'You do not have permission to delete.');
                return;
            }
            if (selectedClassId === 0) return;
            if (!confirm('Are you sure you want to delete this class?')) return;

            IV.clearNotice('classPageNotice');
            try {
                const resp = await fetch(`/Academics/DeleteClass?id=${selectedClassId}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('classPageNotice', res.message || 'Delete failed.');
            } catch (err) {
                console.error(err);
                IV.setNotice('classPageNotice', 'Could not delete class.');
            }
        }

        async function saveItem() {
            const cid = parseInt(document.getElementById('txtItemId').value);
            if (cid === 0 && !permCanAdd) {
                IV.setNotice('classModalNotice', 'You do not have permission to add.');
                return;
            }
            if (cid > 0 && !permCanEdit) {
                IV.setNotice('classModalNotice', 'You do not have permission to edit.');
                return;
            }
            clearModalValidation();
            
            const name = document.getElementById('txtClassName').value.trim();
            if (!name) {
                IV.setFieldError('txtClassName', 'errTxtClassName', 'Class name is required.');
                return;
            }

            const sectionIds = ($('#ddlSections').val() || []).map(v => parseInt(v));
            if (sectionIds.length === 0) {
                IV.setFieldError('ddlSections', 'errDdlSections', 'At least one section must be assigned.');
                return;
            }

            const data = {
                classID: cid,
                className: name,
                isActive: document.getElementById('isActive').checked,
                sectionIds: sectionIds
            };

            try {
                const resp = await fetch('/Academics/SaveClass', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('classModalNotice', res.message || 'Save failed.');
            } catch (err) {
                console.error(err);
                IV.setNotice('classModalNotice', 'Could not save class.');
            }
        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                IV.setNotice('classPageNotice', 'You do not have permission to change status.');
                location.reload();
                return;
            }
            IV.clearNotice('classPageNotice');
            try {
                const resp = await fetch(`/Academics/ToggleClassStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) {
                    if (window.toast) window.toast.success(res.message || 'Status updated.');
                } else {
                    IV.setNotice('classPageNotice', res.message || 'Could not update status.');
                    location.reload();
                }
            } catch (err) {
                console.error(err);
                IV.setNotice('classPageNotice', 'Could not update status.');
                location.reload();
            }
        }
    </script>
}
