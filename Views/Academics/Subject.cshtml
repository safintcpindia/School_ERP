@*
    ======================================================================
    VIEW: Academics / Subject.cshtml
    PURPOSE: User interface for managing Subjects.
    ======================================================================
*@
@model SchoolERP.Net.Models.MstSubjectPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Subject Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
        
    var canAdd = PermHelper.HasPermissionByUrl("/Academics/Subject", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Academics/Subject", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Academics/Subject", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h6 class="fw-bold mb-0">Subject Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        @if (canAdd)
        {
            <button class="btn btn-primary shadow-sm" id="btnAddSubject" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info shadow-sm" disabled onclick="editSelected()">
                <i class="ti ti-edit me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

<div id="pageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl border-0 overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="subjectsTable">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Subject Name</th>
                                <th>Subject Code</th>
                                <th>Subject Type</th>
                                <th>Status</th>
                                <th class="pe-4">Created On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Subjects != null && Model.Subjects.Any())
                            {
                                foreach (var s in Model.Subjects)
                                {
                                    <tr class="item-row" onclick="selectItem(@s.SubjectID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="radio" name="selectedSubject" class="form-check-input" value="@s.SubjectID">
                                        </td>
                                        <td class="fw-medium">@s.SubjectName</td>
                                        <td><span class="badge bg-light text-dark border">@(string.IsNullOrEmpty(s.SubjectCode) ? "N/A" : s.SubjectCode)</span></td>
                                        <td>@s.SubjectType</td>
                                        <td>
                                            @if (canEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input status-switch" type="checkbox" @(s.IsActive ? "checked" : "") onchange="toggleStatus(@s.SubjectID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                        <td class="pe-4">@s.CreatedOn.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No subjects found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header p-3 bg-white border-bottom">
                <h5 class="modal-title fw-bold" id="modalTitle">Add Subject</h5>
                <div class="ms-auto d-flex align-items-center gap-2">                    
                    <button type="button" class="btn btn-success px-3" id="btnSave" onclick="saveItem()">
                        <i class="ti ti-cloud me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal"><i class="ti ti-x"></i></button>
                </div>
            </div>
            <div class="modal-body p-4">
                <div id="modalNotice"></div>
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Subject Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtSubjectName" placeholder="e.g. Mathematics" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtSubjectName"></div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Subject Code</label>
                            <input type="text" class="form-control" id="txtSubjectCode" placeholder="e.g. MATH101" autocomplete="off">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Subject Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlSubjectType">
                                <option value="">Select Type</option>
                                <option value="Theory">Theory</option>
                                <option value="Practical">Practical</option>
                                
                            </select>
                            <div class="invalid-feedback" id="errDdlSubjectType"></div>
                        </div>
                    </div>
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" id="isActive" checked>
                        <label class="form-check-label fw-semibold" for="isActive">Active Status</label>                        
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .shadow-tbl {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }
        .item-row.bg-light-primary {
            background-color: rgba(13, 110, 253, 0.05);
        }
        .status-switch {
            width: 2.5rem;
            height: 1.25rem;
            cursor: pointer;
        }
        .table thead th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            color: #6c757d;
        }
    </style>
}

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));

        const IV = {
            clearMap: (map) => Object.keys(map).forEach(k => { 
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }),
            setFieldError: (id, errId, msg) => {
                document.getElementById(id)?.classList.add('is-invalid');
                const err = document.getElementById(errId); if(err) err.textContent = msg;
            },
            setNotice: (id, msg, type = 'danger') => {
                const el = document.getElementById(id);
                if(el) el.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
            },
            clearNotice: (id) => { const el = document.getElementById(id); if(el) el.innerHTML = ''; },
            bindAutoClear: (map) => Object.keys(map).forEach(k => document.getElementById(k)?.addEventListener('input', () => {
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }))
        };

        const fieldMap = { txtSubjectName: 'errTxtSubjectName', ddlSubjectType: 'errDdlSubjectType' };
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedId = 0;

        IV.bindAutoClear(fieldMap);

        function selectItem(id, row) {
            IV.clearNotice('pageNotice');
            selectedId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light-primary'));
            row.classList.add('bg-light-primary');
            row.querySelector('input[type="radio"]').checked = true;
            
            if (permCanEdit) document.getElementById('btnEdit').disabled = false;
            if (permCanDelete) document.getElementById('btnDelete').disabled = false;
        }

        function openAddModal() {
            if (!permCanAdd) {
                IV.setNotice('pageNotice', 'You do not have permission to add.');
                return;
            }
            IV.clearNotice('pageNotice');
            IV.clearMap(fieldMap);
            IV.clearNotice('modalNotice');
            
            document.getElementById('modalTitle').textContent = 'Add Subject';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            
            itemModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) {
                IV.setNotice('pageNotice', 'You do not have permission to edit.');
                return;
            }
            if (selectedId === 0) return;
            IV.clearNotice('pageNotice');
            IV.clearMap(fieldMap);
            IV.clearNotice('modalNotice');
            
            try {
                const resp = await fetch(`/Academics/GetSubject?id=${selectedId}`);
                const res = await resp.json();
                if (res.success) {
                    document.getElementById('modalTitle').textContent = 'Edit Subject';
                    document.getElementById('txtItemId').value = res.data.subjectID;
                    document.getElementById('txtSubjectName').value = res.data.subjectName;
                    document.getElementById('txtSubjectCode').value = res.data.subjectCode || '';
                    document.getElementById('ddlSubjectType').value = res.data.subjectType || '';
                    document.getElementById('isActive').checked = res.data.isActive;
                    
                    itemModal.show();
                } else {
                    IV.setNotice('pageNotice', res.message || 'Could not load subject.');
                }
            } catch (err) {
                console.error(err);
                IV.setNotice('pageNotice', 'An error occurred while loading details.');
            }
        }

        async function deleteSelected() {
            if (!permCanDelete) {
                IV.setNotice('pageNotice', 'You do not have permission to delete.');
                return;
            }
            if (selectedId === 0) return;
            if (!confirm('Are you sure you want to delete this subject?')) return;

            IV.clearNotice('pageNotice');
            try {
                const resp = await fetch(`/Academics/DeleteSubject?id=${selectedId}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('pageNotice', res.message || 'Delete failed.');
            } catch (err) {
                console.error(err);
                IV.setNotice('pageNotice', 'An error occurred during deletion.');
            }
        }

        async function saveItem() {
            const sid = parseInt(document.getElementById('txtItemId').value);
            if (sid === 0 && !permCanAdd) {
                IV.setNotice('modalNotice', 'You do not have permission to add.');
                return;
            }
            if (sid > 0 && !permCanEdit) {
                IV.setNotice('modalNotice', 'You do not have permission to edit.');
                return;
            }
            
            const name = document.getElementById('txtSubjectName').value.trim();
            if (!name) {
                IV.setFieldError('txtSubjectName', 'errTxtSubjectName', 'Subject name is required.');
                return;
            }

            const type = document.getElementById('ddlSubjectType').value;
            if (!type) {
                IV.setFieldError('ddlSubjectType', 'errDdlSubjectType', 'Subject type is required.');
                return;
            }

            const data = {
                subjectID: sid,
                subjectName: name,
                subjectCode: document.getElementById('txtSubjectCode').value.trim(),
                subjectType: type,
                isActive: document.getElementById('isActive').checked
            };

            try {
                const resp = await fetch('/Academics/SaveSubject', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('modalNotice', res.message || 'Save failed.');
            } catch (err) {
                console.error(err);
                IV.setNotice('modalNotice', 'An error occurred while saving.');
            }
        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                IV.setNotice('pageNotice', 'You do not have permission to change status.');
                location.reload();
                return;
            }
            IV.clearNotice('pageNotice');
            try {
                const resp = await fetch(`/Academics/ToggleSubjectStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) {
                    if (window.toast) window.toast.success(res.message || 'Status updated.');
                } else {
                    IV.setNotice('pageNotice', res.message || 'Could not update status.');
                    location.reload();
                }
            } catch (err) {
                console.error(err);
                IV.setNotice('pageNotice', 'An error occurred while updating status.');
                location.reload();
            }
        }
    </script>
}
