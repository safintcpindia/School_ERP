@*
    ======================================================================
    VIEW: Academics / SubjectGroup.cshtml
    PURPOSE: User interface for managing Subject Groups.
    ======================================================================
*@
@model SchoolERP.Net.Models.MstSubjectGroupPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Subject Group Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
        
    var canAdd = PermHelper.HasPermissionByUrl("/Academics/SubjectGroup", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Academics/SubjectGroup", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Academics/SubjectGroup", "Delete");
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Subject Group</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

<div id="pageNotice"></div>

<!-- start row -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <input type="text" id="txtSearch" class="form-control w-25 me-3" placeholder="Search..." onkeyup="filterTable()" />
                    <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                        <button class="btn btn-white border" data-bs-toggle="offcanvas" data-bs-target="#filter">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card overflow-auto shadow-tbl">
            <div class="card-body p-0 overflow-auto">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="groupsTable">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Name</th>
                                <th>Class (Sections)</th>
                                <th>Subjects</th>
                                <th>Status</th>
                                <th>Created On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.SubjectGroups != null && Model.SubjectGroups.Any())
                            {
                                foreach (var g in Model.SubjectGroups)
                                {
                                    <tr class="item-row" onclick="selectItem(@g.SubjectGroupID, this)" style="cursor: pointer;">
                                        <td class="text-center">
                                            <input type="radio" name="selectedGroup" class="form-check-input" value="@g.SubjectGroupID">
                                        </td>
                                        <td class="fw-medium">@g.Name</td>
                                        <td>
                                            <span class="fw-bold">@g.ClassName</span>
                                            <br/><small class="text-muted">(@g.SectionNames)</small>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(g.SubjectNames))
                                            {
                                                foreach (var sub in g.SubjectNames.Split(','))
                                                {
                                                    <span class="badge bg-light text-dark border me-1 mb-1">@sub.Trim()</span>
                                                }
                                            }
                                        </td>
                                        <td>
                                            @if (canEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input status-switch" type="checkbox" @(g.IsActive ? "checked" : "") onchange="toggleStatus(@g.SubjectGroupID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(g.IsActive ? "bg-success" : "bg-secondary")">@(g.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                        <td>@g.CreatedOn.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No subject groups found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="itemModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Subject Group</h5>
                <div>
                    <button class="btn btn-success" onclick="saveItem()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i>Close
                    </button>
                </div>
            </div>
            <div class="modal-body p-4">
                <div id="modalNotice"></div>
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="row row-gap-3">
                        <div class="col-md-12">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" id="txtName" class="form-control" placeholder="Group Name" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtName"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Class <span class="text-danger">*</span></label>
                            <select id="ddlClass" class="form-select" onchange="loadSectionsByClass(this.value, 'ddlSections')">
                                <option value="">Select Class</option>
                                @foreach (var c in Model.Classes)
                                {
                                    <option value="@c.ClassID">@c.ClassName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errDdlClass"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Section <span class="text-danger">*</span></label>
                            <select id="ddlSections" class="form-control select2" multiple data-placeholder="Select Sections">
                                @* Sections populated dynamically based on class *@
                            </select>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Subjects <span class="text-danger">*</span></label>
                            <select id="ddlSubjects" class="form-control select2" multiple data-placeholder="Select Subjects">
                                @foreach (var sub in Model.Subjects)
                                {
                                    <option value="@sub.SubjectID">@sub.SubjectName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errDdlSubjects"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Description</label>
                            <textarea id="txtDescription" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="isActive" checked>
                                <label class="form-check-label fw-semibold" for="isActive">Active Status</label>                        
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Filter Offcanvas -->
<div class="offcanvas offcanvas-end" id="filter">
    <div class="offcanvas-header d-flex justify-content-between align-items-center">
        <h5 class="offcanvas-title">Filter</h5>
        <div>
            <button class="btn btn-light" data-bs-dismiss="offcanvas">Close</button>
            <button class="btn btn-primary" onclick="applyFilter()">Apply</button>
        </div>
    </div>
    <div class="offcanvas-body">
        <div class="mb-3">
            <label class="form-label">Class</label>
            <select id="filterClass" class="form-select" onchange="loadSectionsByClass(this.value, 'filterSection')">
                <option value="">All Classes</option>
                @foreach (var c in Model.Classes)
                {
                    <option value="@c.ClassID" data-name="@c.ClassName">@c.ClassName</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Section</label>
            <select id="filterSection" class="form-select">
                <option value="">All Sections</option>
            </select>
        </div>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container { width: 100% !important; }
        .select2-dropdown { z-index: 1060; }
        .item-row.bg-light-primary { background-color: rgba(13, 110, 253, 0.05); }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const allSections = @Html.Raw(JsonSerializer.Serialize(Model.Sections));

        const IV = {
            clearMap: (map) => Object.keys(map).forEach(k => { 
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }),
            setFieldError: (id, errId, msg) => {
                document.getElementById(id)?.classList.add('is-invalid');
                const err = document.getElementById(errId); if(err) err.textContent = msg;
            },
            setNotice: (id, msg, type = 'danger') => {
                const el = document.getElementById(id);
                if(el) el.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
            },
            clearNotice: (id) => { const el = document.getElementById(id); if(el) el.innerHTML = ''; },
            bindAutoClear: (map) => Object.keys(map).forEach(k => document.getElementById(k)?.addEventListener('input', () => {
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }))
        };

        const fieldMap = { txtName: 'errTxtName', ddlClass: 'errDdlClass', ddlSections: 'errDdlSections', ddlSubjects: 'errDdlSubjects' };
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedId = 0;

        $(document).ready(function() {
            $('.select2').select2({
                dropdownParent: $('#itemModal'),
                placeholder: "Select",
                allowClear: true
            });
            IV.bindAutoClear(fieldMap);
        });

        function selectItem(id, row) {
            IV.clearNotice('pageNotice');
            selectedId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light-primary'));
            row.classList.add('bg-light-primary');
            row.querySelector('input[type="radio"]').checked = true;
            if (permCanEdit) document.getElementById('btnEdit').disabled = false;
            if (permCanDelete) document.getElementById('btnDelete').disabled = false;
        }

        async function loadSectionsByClass(classId, targetId) {
            const ddl = $(`#${targetId}`);
            ddl.empty();
            if (!classId) { 
                ddl.append(new Option(targetId.includes('filter') ? 'All Sections' : 'Select', ''));
                ddl.trigger('change'); 
                return null; 
            }
            
            try {
                const resp = await fetch(`/Academics/GetSectionsByClass?id=${classId}`);
                const res = await resp.json();
                if (res.success && res.data) {
                    if (targetId.includes('filter')) ddl.append(new Option('All Sections', ''));
                    
                    res.data.forEach(s => {
                        ddl.append(new Option(s.sectionName, s.sectionID));
                    });
                }
                ddl.trigger('change');
                return res.data || [];
            } catch (err) { 
                console.error(err); 
                return []; 
            }
        }

        function openAddModal() {
            if (!permCanAdd) { IV.setNotice('pageNotice', 'No permission to add.'); return; }
            IV.clearNotice('pageNotice');
            IV.clearMap(fieldMap);
            IV.clearNotice('modalNotice');
            document.getElementById('modalTitle').textContent = 'Add Subject Group';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            $('#ddlSections').empty().trigger('change');
            $('#ddlSubjects').val(null).trigger('change');
            itemModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) { IV.setNotice('pageNotice', 'No permission to edit.'); return; }
            if (selectedId === 0) return;
            IV.clearNotice('pageNotice');
            IV.clearMap(fieldMap);
            IV.clearNotice('modalNotice');
            try {
                const resp = await fetch(`/Academics/GetSubjectGroup?id=${selectedId}`);
                const res = await resp.json();
                if (res.success) {
                    document.getElementById('modalTitle').textContent = 'Edit Subject Group';
                    document.getElementById('txtItemId').value = res.data.subjectGroupID;
                    document.getElementById('txtName').value = res.data.name;
                    document.getElementById('ddlClass').value = res.data.classID;
                    document.getElementById('txtDescription').value = res.data.description || '';
                    document.getElementById('isActive').checked = res.data.isActive;

                    // Load sections then set values
                    await loadSectionsByClass(res.data.classID, 'ddlSections');
                    $('#ddlSections').val(res.data.sectionIds).trigger('change');
                    
                    $('#ddlSubjects').val(res.data.subjectIds).trigger('change');
                    itemModal.show();
                } else {
                    IV.setNotice('pageNotice', res.message || 'Error loading group.');
                }
            } catch (err) { console.error(err); IV.setNotice('pageNotice', 'Error loading details.'); }
        }

        async function saveItem() {
            const sid = parseInt(document.getElementById('txtItemId').value);
            IV.clearMap(fieldMap);
            
            const name = document.getElementById('txtName').value.trim();
            const classId = document.getElementById('ddlClass').value;
            const sectionIds = $('#ddlSections').val() || [];
            const subjectIds = $('#ddlSubjects').val() || [];

            let hasError = false;
            if (!name) { IV.setFieldError('txtName', 'errTxtName', 'Name is required.'); hasError = true; }
            if (!classId) { IV.setFieldError('ddlClass', 'errDdlClass', 'Class is required.'); hasError = true; }
            if (sectionIds.length === 0) { IV.setFieldError('ddlSections', 'errDdlSections', 'At least one section is required.'); hasError = true; }
            if (subjectIds.length === 0) { IV.setFieldError('ddlSubjects', 'errDdlSubjects', 'At least one subject is required.'); hasError = true; }

            if (hasError) return;

            const data = {
                subjectGroupID: sid,
                name: name,
                classID: parseInt(classId),
                description: document.getElementById('txtDescription').value,
                isActive: document.getElementById('isActive').checked,
                sectionIds: sectionIds.map(v => parseInt(v)),
                subjectIds: subjectIds.map(v => parseInt(v))
            };

            try {
                const resp = await fetch('/Academics/SaveSubjectGroup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('modalNotice', res.message || 'Save failed.');
            } catch (err) { console.error(err); IV.setNotice('modalNotice', 'Error saving.'); }
        }

        async function deleteSelected() {
            if (!permCanDelete) { IV.setNotice('pageNotice', 'No permission to delete.'); return; }
            if (selectedId === 0) return;
            if (!confirm('Are you sure you want to delete this group?')) return;
            try {
                const resp = await fetch(`/Academics/DeleteSubjectGroup?id=${selectedId}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('pageNotice', res.message || 'Delete failed.');
            } catch (err) { console.error(err); IV.setNotice('pageNotice', 'Error deleting.'); }
        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) { location.reload(); return; }
            try {
                const resp = await fetch(`/Academics/ToggleSubjectGroupStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
                const res = await resp.json();
                if (!res.success) { IV.setNotice('pageNotice', res.message || 'Status update failed.'); location.reload(); }
            } catch (err) { console.error(err); location.reload(); }
        }

        function filterTable() {
            const search = document.getElementById('txtSearch').value.toLowerCase();
            document.querySelectorAll('#groupsTable tbody tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(search) ? '' : 'none';
            });
        }

        function applyFilter() {
            const classId = document.getElementById('filterClass').value;
            const sectionId = document.getElementById('filterSection').value;
            const className = document.querySelector(`#filterClass option[value="${classId}"]`)?.getAttribute('data-name');
            const sectionName = document.querySelector(`#filterSection option[value="${sectionId}"]`)?.textContent;

            document.querySelectorAll('#groupsTable tbody tr').forEach(row => {
                let show = true;
                if (className) {
                    const rowClass = row.cells[2].querySelector('span').textContent;
                    if (rowClass !== className) show = false;
                }
                if (show && sectionName && sectionId) {
                    const rowSections = row.cells[2].querySelector('small').textContent;
                    if (!rowSections.includes(sectionName)) show = false;
                }
                row.style.display = show ? '' : 'none';
            });
            bootstrap.Offcanvas.getInstance(document.getElementById('filter')).hide();
        }
    </script>
}
