<div class="modal fade" id="myModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal">
            <div class="modal-body text-center">
                <div class="icon-box mb-2 mx-auto">
                    <i class="ti ti-building text-primary display-6"></i>
                </div>

                <h4 class="modal-title mb-2" id="createCompanyLabel">Create a Company</h4>
                <p class="text-muted mb-4">
                    It looks like no company has been set up yet.
                    To start using the ERP system, please create and configure your company profile.
                </p>

                <a href="/Settings/Companies" class="btn btn-primary shadow rounded-pill py-2 px-3 fw-bold">
                    Go to Company Setup <i class="ti ti-arrow-right ms-2"></i>
                </a>                
            </div>
        </div>
    </div>
</div>


<style>
    .custom-modal {
        border: none;
        border-radius: 10px;
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
    }

    /* Icon Container */
    .icon-box {
        width: 80px;
        height: 80px;
        background: #f0f3ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;        
    }
</style>

@section Scripts {

    <script>
        window.onload = function () {
            var myModal = new bootstrap.Modal(document.getElementById('myModal'), {
                backdrop: 'static', // disable outside click close
                keyboard: false // disable ESC key close
            });
            
            if (@ViewBag.totalCompanies == 0)
            {
                myModal.show();
            }
            
        };
    </script>
    <script>
        $(document).ready(function () {
            // Primitive client-side routing guard checking if a session token was previously serialized.
            // Works in tandem with [Authorize] data blocks in the C# backend.
            const token = localStorage.getItem('token');
            if (!token) {
                window.location.href = '/Auth/Login';
            }
        });
    </script>
}
