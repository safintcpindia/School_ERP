@model SchoolERP.Net.Models.FOPostalReceivePageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Postal Receive";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);
    
    var canAdd = PermHelper.HasPermissionByUrl("/FrontOffice/PostalReceive", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/FrontOffice/PostalReceive", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/FrontOffice/PostalReceive", "Delete");
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Postal Receive List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
    </div>
</div>

<div class="row">
    <!-- Filters -->
    <div class="col-md-12 mb-3">
        <div class="card shadow-tbl-outer">
            <div class="card-body py-2">
                <div class="d-flex align-items-center justify-content-between">
                    <input type="text" class="form-control w-25" id="txtSearch" placeholder="Search by title, reference...">
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblPostalReceive">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="ps-3">Select</th>
                                <th>From Title</th>
                                <th>Reference No</th>
                                <th>To Title</th>
                                <th>Date</th>
                                <th>Doc</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="item-row" onclick="selectItem(@item.PostalReceiveID, this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="radio" name="selectedItem" class="form-check-input" value="@item.PostalReceiveID">
                                    </td>
                                    <td>@item.FromTitle</td>
                                    <td>@item.ReferenceNo</td>
                                    <td>@item.ToTitle</td>
                                    <td>@item.Date.ToString("dd-MM-yyyy")</td>
                                    <td>
                                        @if (item.Attachment != null && item.Attachment.Length > 0)
                                        {
                                            <a href="/FrontOffice/DownloadAttachment/@item.PostalReceiveID" target="_blank" class="btn btn-sm btn-white border px-2 py-1" title="View Attachment">
                                                <i class="ti ti-paperclip fs-5"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-7">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@item.PostalReceiveID, this.checked)"
                                                   @(item.IsActive ? "checked" : "")
                                                   @(canEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">No records found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="postalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Postal Receive</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="postalForm">
                    <input type="hidden" id="hdnPostalReceiveID" value="0">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">From Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtFromTitle" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">To Title</label>
                            <input type="text" class="form-control" id="txtToTitle">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Reference No</label>
                            <input type="text" class="form-control" id="txtReferenceNo">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Address</label>
                            <textarea class="form-control" id="txtAddress" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Note</label>
                            <textarea class="form-control" id="txtNote" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtDate" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Attachment</label>
                            <input type="file" class="form-control" id="fileAttachment">
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkActive" checked>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedId = 0;
    const canEdit = @canEdit.ToString().ToLower();
    const canDelete = @canDelete.ToString().ToLower();

    function selectItem(id, row) {
        selectedId = id;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) document.getElementById('btnEdit').disabled = false;
        if (canDelete) document.getElementById('btnDelete').disabled = false;
    }

    // Search
    document.getElementById('txtSearch').addEventListener('keyup', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblPostalReceive tbody tr').forEach(row => {
            if (row.classList.contains('item-row')) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            }
        });
    });

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Postal Receive';
        document.getElementById('hdnPostalReceiveID').value = 0;
        document.getElementById('postalForm').reset();
        document.getElementById('txtDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('chkActive').checked = true;
        new bootstrap.Modal(document.getElementById('postalModal')).show();
    }

    function editSelected() {
        if (!selectedId) return;
        fetch(`/FrontOffice/GetPostalReceive?id=${selectedId}`)
            .then(r => r.json())
            .then(res => {
                if (!res.success) { showToast(res.message, 'danger'); return; }
                const d = res.data;
                document.getElementById('modalTitle').textContent = 'Edit Postal Receive';
                document.getElementById('hdnPostalReceiveID').value = d.postalReceiveID;
                document.getElementById('txtFromTitle').value = d.fromTitle;
                document.getElementById('txtToTitle').value = d.toTitle || '';
                document.getElementById('txtReferenceNo').value = d.referenceNo || '';
                document.getElementById('txtAddress').value = d.address || '';
                document.getElementById('txtNote').value = d.note || '';
                document.getElementById('txtDate').value = d.date.split('T')[0];
                document.getElementById('chkActive').checked = d.isActive;

                new bootstrap.Modal(document.getElementById('postalModal')).show();
            });
    }

    function saveRecord() {
        const form = document.getElementById('postalForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const formData = new FormData();
        formData.append('postalReceiveID', parseInt(document.getElementById('hdnPostalReceiveID').value) || 0);
        formData.append('fromTitle',       document.getElementById('txtFromTitle').value.trim());
        formData.append('toTitle',         document.getElementById('txtToTitle').value.trim() || '');
        formData.append('referenceNo',     document.getElementById('txtReferenceNo').value.trim() || '');
        formData.append('address',         document.getElementById('txtAddress').value.trim() || '');
        formData.append('note',            document.getElementById('txtNote').value.trim() || '');
        formData.append('date',            document.getElementById('txtDate').value);
        formData.append('isActive',        document.getElementById('chkActive').checked);

        const fileInput = document.getElementById('fileAttachment');
        if (fileInput.files[0]) {
            formData.append('attachmentFile', fileInput.files[0]);
        }

        fetch('/FrontOffice/SavePostalReceive', {
            method: 'POST',
            body: formData
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('postalModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    function deleteSelected() {
        if (!selectedId) return;
        if (!confirm('Are you sure you want to delete this record?')) return;
        fetch(`/FrontOffice/DeletePostalReceive?id=${selectedId}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => {
                showToast(res.message, res.success ? 'success' : 'danger');
                if (res.success) setTimeout(() => location.reload(), 800);
            });
    }

    function toggleStatus(id, isActive) {
        fetch(`/FrontOffice/TogglePostalReceiveStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}
