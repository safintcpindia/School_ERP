@model SchoolERP.Net.Models.HostelRoomPageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Hostel Room";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);

    var canAdd = PermHelper.HasPermissionByUrl("/Hostel/HostelRoom", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Hostel/HostelRoom", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Hostel/HostelRoom", "Delete");
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Hostel Room List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
    </div>
</div>

<div class="row">
    <!-- Filters -->
    <div class="col-md-12 mb-3">
        <div class="card shadow-tbl-outer">
            <div class="card-body py-2">
                <div class="d-flex align-items-center justify-content-between">
                    <input type="text" class="form-control w-25" id="txtSearch" placeholder="Search by room title, hostel...">
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblRoom">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="ps-3">Select</th>
                                <th>Hostel Name</th>
                                <th>Room Title</th>
                                <th>Room Type</th>
                                <th>Beds</th>
                                <th>Cost/Bed</th>
                                <th style="width: 100px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="item-row" onclick="selectItem(@item.RoomId, this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="radio" name="selectedItem" class="form-check-input" value="@item.RoomId">
                                    </td>
                                    <td>@item.HostelName</td>
                                    <td>@item.RoomTitle</td>
                                    <td>@item.RoomTypeTitle</td>
                                    <td>@item.NoOfBed</td>
                                    <td>@item.CostPerBed.ToString("N2")</td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@item.RoomId, this.checked)"
                                                   @(item.IsActive ? "checked" : "")
                                                   @(canEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr><td colspan="7" class="text-center text-muted py-4">No records found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="roomModal">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Room</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="roomForm">
                    <input type="hidden" id="hdnRoomId" value="0">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Hostel <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlHostel" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var h in Model.Hostels)
                                {
                                    <option value="@h.HostelID">@h.HostelName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Room Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlRoomType" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.RoomTypes)
                                {
                                    <option value="@rt.RoomTypeID">@rt.RoomTypeTitle</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Room Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtRoomTitle" required placeholder="e.g. 101, A-1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">No. of Beds <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="txtBeds" required min="1" value="1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Cost Per Bed <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="txtCost" required min="0" step="0.01" value="0">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="2"></textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkActive" checked>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedId = 0;
    const canEdit = @canEdit.ToString().ToLower();
    const canDelete = @canDelete.ToString().ToLower();

    $(document).ready(function () {
        // Initialize Select2
        $('#ddlHostel, #ddlRoomType').select2({
            dropdownParent: $('#roomModal'),
            placeholder: "-- Select --",
            allowClear: true
        });
    });

    function selectItem(id, row) {
        selectedId = id;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) document.getElementById('btnEdit').disabled = false;
        if (canDelete) document.getElementById('btnDelete').disabled = false;
    }

    // Search
    document.getElementById('txtSearch').addEventListener('keyup', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblRoom tbody tr').forEach(row => {
            if (row.classList.contains('item-row')) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            }
        });
    });

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Room';
        document.getElementById('hdnRoomId').value = 0;
        document.getElementById('roomForm').reset();
        document.getElementById('chkActive').checked = true;
        
        $('#ddlHostel, #ddlRoomType').val('').trigger('change');

        new bootstrap.Modal(document.getElementById('roomModal')).show();
    }

    function editSelected() {
        if (!selectedId) return;
        fetch(`/api/HostelApi/GetHostelRoomByID/${selectedId}`)
            .then(r => r.json())
            .then(res => {
                if (!res.success) { showToast(res.message, 'danger'); return; }
                const d = res.data;
                document.getElementById('modalTitle').textContent = 'Edit Room';
                document.getElementById('hdnRoomId').value = d.roomId;
                document.getElementById('txtRoomTitle').value = d.roomTitle;
                document.getElementById('txtBeds').value = d.noOfBed;
                document.getElementById('txtCost').value = d.costPerBed;
                document.getElementById('txtDescription').value = d.roomDescription || '';
                document.getElementById('chkActive').checked = d.isActive;

                $('#ddlHostel').val(d.hostelID).trigger('change');
                $('#ddlRoomType').val(d.roomTypeID).trigger('change');

                new bootstrap.Modal(document.getElementById('roomModal')).show();
            });
    }

    function saveRecord() {
        const form = document.getElementById('roomForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const data = {
            roomId:          parseInt(document.getElementById('hdnRoomId').value) || 0,
            hostelID:        parseInt(document.getElementById('ddlHostel').value),
            roomTypeID:      parseInt(document.getElementById('ddlRoomType').value),
            roomTitle:       document.getElementById('txtRoomTitle').value.trim(),
            noOfBed:         parseInt(document.getElementById('txtBeds').value),
            costPerBed:      parseFloat(document.getElementById('txtCost').value),
            roomDescription: document.getElementById('txtDescription').value.trim() || null,
            isActive:        document.getElementById('chkActive').checked
        };

        fetch('/api/HostelApi/UpsertHostelRoom', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('roomModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    function deleteSelected() {
        if (!selectedId) return;
        if (!confirm('Are you sure you want to delete this record?')) return;
        fetch(`/api/HostelApi/DeleteHostelRoom/${selectedId}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => {
                showToast(res.message, res.success ? 'success' : 'danger');
                if (res.success) setTimeout(() => location.reload(), 800);
            });
    }

    function toggleStatus(id, isActive) {
        fetch(`/api/HostelApi/ToggleHostelRoomStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}
