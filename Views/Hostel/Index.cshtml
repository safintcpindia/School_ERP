@model SchoolERP.Net.Models.HostelPageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Hostel";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);

    var canAdd = PermHelper.HasPermissionByUrl("/Hostel/Index", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Hostel/Index", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Hostel/Index", "Delete");
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Hostel List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
    </div>
</div>

<div class="row">
    <!-- Filters -->
    <div class="col-md-12 mb-3">
        <div class="card shadow-tbl-outer">
            <div class="card-body py-2">
                <div class="d-flex align-items-center justify-content-between">
                    <input type="text" class="form-control w-25" id="txtSearch" placeholder="Search by name, address...">
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblHostel">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="ps-3">Select</th>
                                <th>Hostel Name</th>
                                <th>Room Type</th>
                                <th>Intake</th>
                                <th>Address</th>
                                <th style="width: 100px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="item-row" onclick="selectItem(@item.HostelID, this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="radio" name="selectedItem" class="form-check-input" value="@item.HostelID">
                                    </td>
                                    <td>@item.HostelName</td>
                                    <td>@item.RoomTypeTitle</td>
                                    <td>@item.HostelIntake</td>
                                    <td>@item.HostelAddress</td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@item.HostelID, this.checked)"
                                                   @(item.IsActive ? "checked" : "")
                                                   @(canEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">No records found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="hostelModal">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Hostel</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="hostelForm">
                    <input type="hidden" id="hdnHostelID" value="0">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Hostel Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtHostelName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Room Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlRoomType" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.RoomTypes)
                                {
                                    <option value="@rt.RoomTypeID">@rt.RoomTypeTitle</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Intake Capacity <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="txtIntake" required min="0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Address</label>
                            <input type="text" class="form-control" id="txtAddress">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="3"></textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkActive" checked>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedId = 0;
    const canEdit = @canEdit.ToString().ToLower();
    const canDelete = @canDelete.ToString().ToLower();

    $(document).ready(function () {
        // Initialize Select2
        $('#ddlRoomType').select2({
            dropdownParent: $('#hostelModal'),
            placeholder: "-- Select --",
            allowClear: true
        });
    });

    function selectItem(id, row) {
        selectedId = id;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) document.getElementById('btnEdit').disabled = false;
        if (canDelete) document.getElementById('btnDelete').disabled = false;
    }

    // Search
    document.getElementById('txtSearch').addEventListener('keyup', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblHostel tbody tr').forEach(row => {
            if (row.classList.contains('item-row')) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            }
        });
    });

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Hostel';
        document.getElementById('hdnHostelID').value = 0;
        document.getElementById('hostelForm').reset();
        document.getElementById('chkActive').checked = true;
        
        // Reset Select2
        $('#ddlRoomType').val('').trigger('change');

        new bootstrap.Modal(document.getElementById('hostelModal')).show();
    }

    function editSelected() {
        if (!selectedId) return;
        fetch(`/api/HostelApi/GetHostelByID/${selectedId}`)
            .then(r => r.json())
            .then(res => {
                if (!res.success) { showToast(res.message, 'danger'); return; }
                const d = res.data;
                document.getElementById('modalTitle').textContent = 'Edit Hostel';
                document.getElementById('hdnHostelID').value = d.hostelID;
                document.getElementById('txtHostelName').value = d.hostelName;
                
                // Set Select2 value
                $('#ddlRoomType').val(d.roomTypeID).trigger('change');

                document.getElementById('txtIntake').value = d.hostelIntake;
                document.getElementById('txtAddress').value = d.hostelAddress || '';
                document.getElementById('txtDescription').value = d.hostelDescription || '';
                document.getElementById('chkActive').checked = d.isActive;

                new bootstrap.Modal(document.getElementById('hostelModal')).show();
            });
    }

    function saveRecord() {
        const form = document.getElementById('hostelForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const data = {
            hostelID:          parseInt(document.getElementById('hdnHostelID').value) || 0,
            hostelName:        document.getElementById('txtHostelName').value.trim(),
            roomTypeID:        parseInt(document.getElementById('ddlRoomType').value),
            hostelIntake:      parseInt(document.getElementById('txtIntake').value),
            hostelAddress:     document.getElementById('txtAddress').value.trim() || null,
            hostelDescription: document.getElementById('txtDescription').value.trim() || null,
            isActive:            document.getElementById('chkActive').checked
        };

        fetch('/api/HostelApi/UpsertHostel', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('hostelModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    function deleteSelected() {
        if (!selectedId) return;
        if (!confirm('Are you sure you want to delete this record?')) return;
        fetch(`/api/HostelApi/DeleteHostel/${selectedId}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => {
                showToast(res.message, res.success ? 'success' : 'danger');
                if (res.success) setTimeout(() => location.reload(), 800);
            });
    }

    function toggleStatus(id, isActive) {
        fetch(`/api/HostelApi/ToggleHostelStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}

