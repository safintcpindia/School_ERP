@*
    ======================================================================
    VIEW: MasterMenu / Index.cshtml
    PURPOSE: User interface rendering for the MasterMenu module.
    ======================================================================
*@
@model SchoolERP.Net.Models.MenusPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Menu Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/MasterMenu", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/MasterMenu", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/MasterMenu", "Delete");
}

<div id="menuPageNotice" class="alert alert-danger py-2 px-3 small d-none mb-2" role="alert"></div>

    <!-- Page Header -->
    <div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
        <div>
            <h6 class="fw-bold mb-0">Menu Management</h6>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-1">
            @if (canAdd)
            {
                <button class="btn btn-primary shadow-sm" id="btnAddMenu" onclick="openAddModal()">
                    <i class="ti ti-plus me-2"></i>Add
                </button>
            }
            @if (canEdit)
            {
                <button id="btnEdit" class="btn btn-info shadow-sm" disabled onclick="editSelected()">
                    <i class="ti ti-pencil me-2"></i>Edit
                </button>
            }
            @if (canDelete)
            {
                <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
                    <i class="ti ti-trash me-2"></i>Delete
                </button>
            }
        </div>
    </div>

    <!-- Menus Table Card -->
    <div class="row">
        <div class="col-xl-12">
        <div class="card shadow-tbl">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-items-center mb-0" id="menusTable">
                            <thead>
                                <tr class="bg-light">
                                    <th style="width: 50px;">Select</th>
                                    <th>Menu Name / Label</th>
                                    <th>Menu Key</th>
                                    <th>URL / Route</th>
                                    <th>Parent</th>
                                    <th>Order</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var menu in Model.Menus)
                                {
                                    <tr class="item-row" onclick="selectItem(@menu.MenuID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="radio" name="selectedMenu" class="form-check-input" value="@menu.MenuID">
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm me-2 @(menu.ParentID == null ? "bg-primary-soft" : "bg-info-soft")">
                                                    <i class="fas @(menu.ParentID == null ? "fa-folder-open text-primary" : "fa-file text-info")"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fs-13">@menu.MenuName</h6>
                                                    <span class="text-xs text-muted small">@menu.DisplayLabel</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@menu.MenuKey</td>
                                        <td>
                                            <code class="text-xs text-primary font-weight-bold">@menu.MenuURL</code>
                                        </td>
                                        <td>
                                            @if (string.IsNullOrEmpty(menu.ParentMenuName))
                                            {
                                                <span class="badge bg-light text-dark text-xs border">None (Root)</span>
                                            }
                                            else
                                            {
                                                <span class="">@menu.ParentMenuName</span>
                                            }
                                        </td>
                                        <td class="">
                                            @menu.DisplayOrder
                                        </td>
                                        <td class="">
                                            @if (canEdit)
                                            {
                                                <div class="form-check form-switch mb-0" onclick="event.stopPropagation()">
                                                    <input class="form-check-input" type="checkbox" role="switch"
                                                           checked="@menu.IsActive"
                                                           onchange="toggleStatus(@menu.MenuID, this.checked)"
                                                           id="statusSwitch_@menu.MenuID">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(menu.IsActive ? "bg-success" : "bg-secondary")">@(menu.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


<!-- Add/Edit Menu Modal -->
<div class="modal fade" id="menuModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">
                    Add New Menu
                </h5>
                <div class="ms-auto d-flex align-items-center gap-1">
                    @* <button type="button" class="btn btn-sm btn-outline-secondary px-3" id="btnCancel" data-bs-dismiss="modal">Cancel</button> *@
                    <button type="button" class="btn btn-success" onclick="saveMenu()" id="btnSaveMenu">
                        <i class="ti ti-cloud me-1"></i> Save Menu
                    </button>
                    <button type="button" class="btn btn-danger ms-1" data-bs-dismiss="modal" aria-label="Close"><i class="ti ti-x me-1"></i> Close</button>
                </div>
            </div>
            <div class="modal-body p-3">
                <div id="menuModalNotice" class="alert alert-warning py-2 small d-none mb-3" role="alert"></div>
                <form id="menuForm" class="row">
                    <input type="hidden" id="txtMenuId" value="0">
                    
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Menu Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtMenuName" maxlength="20" placeholder="e.g. FeesCollection" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtMenuName"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Display Label (Multilingual)</label>
                        <input type="text" class="form-control" id="txtDisplayLabel" maxlength="200" placeholder="e.g. Fees Collection" autocomplete="off">
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Menu Key</label>
                        <input type="text" class="form-control" id="txtMenuKey" maxlength="50" placeholder="e.g. FEES_COLLECTION" autocomplete="off">
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Menu Icon <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtMenuIcon" maxlength="50" placeholder="e.g. ti ti-users" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtMenuIcon"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Target URL / Route <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtMenuURL" maxlength="300" placeholder="e.g. /Fees/Index" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtMenuURL"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Parent Menu</label>
                        <select class="form-select form-control searchable-select" id="ddlParentId">
                            <option value="">None (Root Menu)</option>
                            @foreach (var p in Model.ParentMenus)
                            {
                                <option value="@p.MenuID">@p.MenuName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Display Order</label>
                        <input type="number" class="form-control" id="txtDisplayOrder" value="0" min="0">
                        <div class="invalid-feedback" id="errTxtDisplayOrder"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check form-switch mt-4">
                            <input class="form-check-input" type="checkbox" id="isActive" checked>
                            <label class="form-check-label" for="isActive">Primary Activation Status</label>                        
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const IV = window.InlineFormValidation;
        const menuFieldMap = {
            txtMenuName: 'errTxtMenuName',
            txtMenuIcon: 'errTxtMenuIcon',
            txtMenuURL: 'errTxtMenuURL',
            txtDisplayOrder: 'errTxtDisplayOrder'
        };
        const menuModal = new bootstrap.Modal(document.getElementById('menuModal'));
        let selectedMenuId = 0;

        function clearMenuModalValidation() {
            IV.clearMap(menuFieldMap);
            IV.clearNotice('menuModalNotice');
        }

        IV.bindAutoClear(menuFieldMap);

        function initParentMenuDropdown() {
            const $ddlParent = $('#ddlParentId');
            if (!$ddlParent.length || typeof $ddlParent.select2 !== 'function') return;
            if ($ddlParent.hasClass('select2-hidden-accessible')) return;

            $ddlParent.select2({
                placeholder: 'Select parent menu',
                allowClear: true,
                width: '100%',
                dropdownParent: $('#menuModal')
            });
        }

        initParentMenuDropdown();

        function selectItem(id, row) {
            IV.clearNotice('menuPageNotice');
            selectedMenuId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            row.querySelector('input[type="radio"]').checked = true;
            const btnEdit = document.getElementById('btnEdit');
            const btnDelete = document.getElementById('btnDelete');
            if (btnEdit && permCanEdit) btnEdit.disabled = false;
            if (btnDelete && permCanDelete) btnDelete.disabled = false;
        }

        function openAddModal() {
            if (!permCanAdd) {
                IV.setNotice('menuPageNotice', 'You do not have permission to add.');
                return;
            }
            IV.clearNotice('menuPageNotice');
            clearMenuModalValidation();
            document.getElementById('modalTitle').innerHTML = 'Add New Menu';
            document.getElementById('menuForm').reset();
            document.getElementById('txtMenuId').value = "0";
            document.getElementById('isActive').checked = true;
            $('#ddlParentId').val('').trigger('change');
            menuModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) {
                IV.setNotice('menuPageNotice', 'You do not have permission to edit.');
                return;
            }
            if (selectedMenuId === 0) return;
            IV.clearNotice('menuPageNotice');
            clearMenuModalValidation();
            try {
                const response = await fetch(`/MasterMenu/GetMenu?menuId=${selectedMenuId}`);
                const res = await response.json();
                
                if (res.success) {
                    const m = res.menu;
                    document.getElementById('modalTitle').innerHTML = 'Edit Menu';
                    document.getElementById('txtMenuId').value = m.menuID;
                    document.getElementById('txtMenuName').value = m.menuName;
                    document.getElementById('txtDisplayLabel').value = m.displayLabel || '';
                    document.getElementById('txtMenuKey').value = m.menuKey || '';
                    document.getElementById('txtMenuURL').value = m.menuURL;
                    document.getElementById('txtMenuIcon').value = m.menuIcon;
                    $('#ddlParentId').val(m.parentID || '').trigger('change');
                    document.getElementById('txtDisplayOrder').value = m.displayOrder;
                    document.getElementById('isActive').checked = m.isActive;
                    menuModal.show();
                } else {
                    IV.setNotice('menuPageNotice', res.message || 'Could not load menu.');
                }
            } catch (err) {
                IV.setNotice('menuPageNotice', 'Could not load menu details.');
            }
        }

        async function deleteSelected() {
            if (!permCanDelete) {
                IV.setNotice('menuPageNotice', 'You do not have permission to delete.');
                return;
            }
            if (selectedMenuId === 0) return;
            IV.setNotice('menuPageNotice', 'Delete is not available for this module yet.');
        }

        function validateMenuForm() {
            clearMenuModalValidation();
            let ok = true;
            const name = document.getElementById('txtMenuName').value.trim();
            const icon = document.getElementById('txtMenuIcon').value.trim();
            const url = document.getElementById('txtMenuURL').value.trim();
            const orderRaw = document.getElementById('txtDisplayOrder').value;
            const order = parseInt(orderRaw, 10);
            if (!name) { IV.setFieldError('txtMenuName', 'errTxtMenuName', 'Menu name is required.'); ok = false; }
            if (!icon) { IV.setFieldError('txtMenuIcon', 'errTxtMenuIcon', 'Menu icon is required.'); ok = false; }
            if (!url) { IV.setFieldError('txtMenuURL', 'errTxtMenuURL', 'Target URL or route is required.'); ok = false; }
            if (orderRaw === '' || Number.isNaN(order) || order < 0) {
                IV.setFieldError('txtDisplayOrder', 'errTxtDisplayOrder', 'Enter a valid display order (0 or greater).');
                ok = false;
            }
            return ok;
        }

        async function saveMenu() {
            const menuId = parseInt(document.getElementById('txtMenuId').value);
            if (menuId === 0 && !permCanAdd) {
                IV.setNotice('menuModalNotice', 'You do not have permission to add.');
                return;
            }
            if (menuId > 0 && !permCanEdit) {
                IV.setNotice('menuModalNotice', 'You do not have permission to edit.');
                return;
            }
            if (!validateMenuForm()) return;

            const orderVal = parseInt(document.getElementById('txtDisplayOrder').value, 10);
            const data = {
                menuID: parseInt(document.getElementById('txtMenuId').value),
                menuName: document.getElementById('txtMenuName').value.trim(),
                displayLabel: document.getElementById('txtDisplayLabel').value.trim(),
                menuKey: document.getElementById('txtMenuKey').value.trim(),
                menuIcon: document.getElementById('txtMenuIcon').value.trim(),
                menuURL: document.getElementById('txtMenuURL').value.trim(),
                parentID: document.getElementById('ddlParentId').value ? parseInt(document.getElementById('ddlParentId').value) : null,
                displayOrder: orderVal,
                isActive: document.getElementById('isActive').checked
            };

            const btn = document.getElementById('btnSaveMenu');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';

            try {
                const response = await fetch('/MasterMenu/Save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await response.json();

                if (res.success) {
                    menuModal.hide();
                    location.reload();
                } else {
                    IV.setNotice('menuModalNotice', res.message || 'Save failed.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="ti ti-cloud me-1"></i> Save Menu';
                }
            } catch (err) {
                IV.setNotice('menuModalNotice', 'Could not save menu.');
                btn.disabled = false;
                btn.innerHTML = '<i class="ti ti-cloud me-1"></i> Save Menu';
            }
        }

        async function toggleStatus(menuId, isActive) {
            if (!permCanEdit) {
                IV.setNotice('menuPageNotice', 'You do not have permission to change status.');
                location.reload();
                return;
            }
            IV.clearNotice('menuPageNotice');
            try {
                const response = await fetch(`/MasterMenu/ToggleStatus?menuId=${menuId}&isActive=${isActive}`, { method: 'POST' });
                const res = await response.json();
                if (res.success) {
                } else {
                    IV.setNotice('menuPageNotice', res.message || 'Could not update status.');
                    location.reload();
                }
            } catch (err) {
                IV.setNotice('menuPageNotice', 'Could not update status.');
                location.reload();
            }
        }
    </script>
}
