@*
    ======================================================================
    VIEW: Organisation / Index.cshtml
    PURPOSE: User interface rendering for the Organisation module.
    ======================================================================
*@
@model SchoolERP.Net.Models.OrganisationPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Organisation Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/Organisation", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Organisation", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Organisation", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h4 class="fw-bold mb-0">Organisation Management</h4>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        @if (canAdd)
        {
            <button type="button" class="btn btn-primary shadow-sm" onclick="openModal(0)">
                <i class="fas fa-plus me-2"></i>Add Organisation
            </button>
        }
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="bg-light">
                    <tr>
                        <th>Organisation Name</th>
                        <th>Company Code</th>
                        <th>Parent</th>
                        <th>Financial Year</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="orgTableBody">
                    @foreach (var org in Model.Organisations)
                    {
                        <tr>
                            <td>
                                <div class="font-weight-bold">@org.OrganisationName</div>
                                <small class="text-muted">@org.Email</small>
                            </td>
                            <td><span class="badge bg-soft-info text-info">@org.CompanyCode</span></td>
                            <td>@(org.ParentName ?? "None")</td>
                            <td>@org.FinancialYear</td>
                            <td>
                                @if (canEdit)
                                {
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" @(org.IsActive ? "checked" : "") onchange="toggleStatus(@org.OrganisationID, this.checked)">
                                    </div>
                                }
                                else
                                {
                                    <span class="badge @(org.IsActive ? "bg-success" : "bg-secondary")">@(org.IsActive ? "Active" : "Inactive")</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (canEdit)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-soft-primary me-1" onclick="openModal(@org.OrganisationID)"><i class="ti ti-edit"></i></button>
                                }
                                @if (canDelete)
                                {
                                    <button type="button" class="btn btn-sm btn-icon btn-soft-danger" onclick="deleteOrg(@org.OrganisationID)"><i class="ti ti-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="orgModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex align-items-center">
                <h5 class="modal-title mb-0" id="modalTitle">Add Organisation</h5>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
                    @if (canAdd || canEdit)
                    {
                        <button type="button" class="btn btn-sm btn-primary" onclick="saveOrg()">Save Organisation</button>
                    }
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <div class="modal-body">
                <form id="orgForm">
                    <input type="hidden" id="OrganisationID" name="OrganisationID" value="0">
                    
                    <!-- Tabs Navigation: Segregates 40+ config options logically -->
                    <ul class="nav nav-tabs nav-tabs-solid nav-justified mb-4" id="orgTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">General</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab">Contact</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="academic-tab" data-bs-toggle="tab" data-bs-target="#academic" type="button" role="tab">Academic</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">Settings</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="enquiry-tab" data-bs-toggle="tab" data-bs-target="#enquiry" type="button" role="tab">Enquiry</button>
                        </li>
                    </ul>

                    <!-- Tabs Content -->
                    <div class="tab-content" id="orgTabsContent">
                        
                        <!-- General Tab -->
                        <div class="tab-pane fade show active" id="general" role="tabpanel">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Organisation Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="OrganisationName" id="txtOrganisationName" required>
                                    <div class="invalid-feedback" id="errTxtOrganisationName"></div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Company Code <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="CompanyCode" id="txtCompanyCode" required>
                                    <div class="invalid-feedback" id="errTxtCompanyCode"></div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Parent Organisation</label>
                                    <select class="form-select" name="ParentOrganisationID" id="ddlParent">
                                        <option value="">None (Top Level)</option>
                                        @foreach (var org in Model.Organisations)
                                        {
                                            <option value="@org.OrganisationID">@org.OrganisationName</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">From Code</label>
                                    <input type="number" class="form-control" name="FromCode">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">To Code</label>
                                    <input type="number" class="form-control" name="ToCode">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Financial Year</label>
                                    <input type="text" class="form-control" name="FinancialYear" placeholder="e.g. 2024-2025">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Previous FY</label>
                                    <input type="number" class="form-control" name="PreviousFinancialYear">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">College Code</label>
                                    <input type="text" class="form-control" name="CollegeCode">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">School Start Date</label>
                                    <input type="date" class="form-control" name="SchoolStartDate">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Renewal Upto</label>
                                    <input type="date" class="form-control" name="RenewalUptoDate">
                                </div>
                                <div class="col-md-12">
                                    <div class="form-check form-switch mb-3">
                                        <input class="form-check-input" type="checkbox" name="IsActive" id="IsActive" checked>
                                        <label class="form-check-label" for="IsActive">Is Active</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Contact Tab -->
                        <div class="tab-pane fade" id="contact" role="tabpanel">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Address Line 1</label>
                                    <textarea class="form-control" name="Address1" rows="2"></textarea>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Address Line 2</label>
                                    <textarea class="form-control" name="Address2" rows="2"></textarea>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">City</label>
                                    <input type="text" class="form-control" name="City">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">State</label>
                                    <input type="text" class="form-control" name="State">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Fax</label>
                                    <input type="text" class="form-control" name="Fax">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Mobile</label>
                                    <input type="text" class="form-control" name="Mobile">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Phone</label>
                                    <input type="text" class="form-control" name="Phone">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" name="Email">
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label class="form-label">Website</label>
                                    <input type="url" class="form-control" name="Website">
                                </div>
                            </div>
                        </div>

                        <!-- Academic Tab -->
                        <div class="tab-pane fade" id="academic" role="tabpanel">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Affiliation No</label>
                                    <input type="text" class="form-control" name="AffiliationNo">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Board Name</label>
                                    <input type="text" class="form-control" name="BoardName">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Session ID</label>
                                    <input type="number" class="form-control" name="SessionID">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Upload URL</label>
                                    <input type="text" class="form-control" name="UploadURL">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" name="IsCourseSemesterTemplate">
                                        <label class="form-check-label">Semester Template</label>
                                    </div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" name="IsMultiLanguage">
                                        <label class="form-check-label">Multi Language</label>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Run By</label>
                                    <input type="text" class="form-control" name="RunBy">
                                </div>
                            </div>
                        </div>

                        <!-- Settings Tab (Fines, Fees, Modules) -->
                        <div class="tab-pane fade" id="settings" role="tabpanel">
                            <h6 class="mb-3 text-primary border-bottom pb-2">Fines & Fees</h6>
                            <div class="row mb-4">
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Late Fine/Day</label>
                                    <input type="number" step="0.01" class="form-control" name="LateFinePerDay">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Lib Fine/Day</label>
                                    <input type="number" step="0.01" class="form-control" name="LibraryFinePerDay">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Max Lib Fine</label>
                                    <input type="number" step="0.01" class="form-control" name="LibraryFineMaxPerBook">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Form Price</label>
                                    <input type="number" step="0.01" class="form-control" name="FormSalePrice">
                                </div>
                            </div>

                            <h6 class="mb-3 text-primary border-bottom pb-2">Modules & Permissions</h6>
                            <div class="row">
                                @foreach (var prop in new[] { "IsFeePayAllowed", "IsChequeAllowed", "IsScholarshipEnabled", "IsAttendanceOnline", "IsPartialFeeAllowed", "IsFeeTemplateEnabled", "IsMultiReceiptCopy", "IsSubstituteLeaveApproval", "IsHostelFeeTemplate", "IsAllowSessionChange", "IsOTPLogin", "IsCopyrightActive" })
                                {
                                    <div class="col-md-4 mb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" name="@prop" id="@prop">
                                            <label class="form-check-label" for="@prop">@System.Text.RegularExpressions.Regex.Replace(prop.Replace("Is", ""), "([a-z])([A-Z])", "$1 $2")</label>
                                        </div>
                                    </div>
                                }
                            </div>

                            <h6 class="mb-3 text-primary border-bottom pb-2 mt-4">Attendance & SMS</h6>
                            <div class="row">
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Punch Before (Min)</label>
                                    <input type="number" class="form-control" name="PunchBeforeMinute">
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="form-label">Punch After (Min)</label>
                                    <input type="number" class="form-control" name="PunchAfterMinute">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">SMS Sender ID</label>
                                    <input type="text" class="form-control" name="SenderID">
                                </div>
                                <div class="col-md-12 mb-3">
                                    <label class="form-label">SMS API Key</label>
                                    <input type="text" class="form-control" name="SMSApiKey">
                                </div>
                            </div>
                        </div>

                        <!-- Enquiry Tab -->
                        <div class="tab-pane fade" id="enquiry" role="tabpanel">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Enquiry Mobile</label>
                                    <input type="text" class="form-control" name="EnquiryMobileNo">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Enquiry Email</label>
                                    <input type="email" class="form-control" name="EnquiryEmail">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Enquiry Website</label>
                                    <input type="url" class="form-control" name="EnquiryWebsite">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Copyright Text</label>
                                    <input type="text" class="form-control" name="CopyrightText">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Portal User Type ID</label>
                                    <input type="number" class="form-control" name="PortalUserTypeID">
                                </div>
                            </div>
                        </div>

                    </div> <!-- End Tab Content -->
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const modal = new bootstrap.Modal(document.getElementById('orgModal'));
        const form = document.getElementById('orgForm');
        const IV = window.InlineFormValidation;
        const orgFieldMap = {
            txtOrganisationName: 'errTxtOrganisationName',
            txtCompanyCode: 'errTxtCompanyCode'
        };

        function clearOrgModalValidation() {
            if(IV) IV.clearMap(orgFieldMap);
        }

        if(IV) IV.bindAutoClear(orgFieldMap);

        function validateOrgForm() {
            clearOrgModalValidation();
            let ok = true;
            const orgName = document.getElementById('txtOrganisationName').value.trim();
            const compCode = document.getElementById('txtCompanyCode').value.trim();
            
            if (!orgName) {
                if(IV) IV.setFieldError('txtOrganisationName', 'errTxtOrganisationName', 'Organisation Name is required.');
                ok = false;
            }
            if (!compCode) {
                if(IV) IV.setFieldError('txtCompanyCode', 'errTxtCompanyCode', 'Company Code is required.');
                ok = false;
            }
            return ok;
        }

        function openModal(id) {
            if (id === 0 && !permCanAdd) {
                Swal.fire('Permission', 'You do not have permission to add organisations.', 'warning');
                return;
            }
            if (id > 0 && !permCanEdit) {
                Swal.fire('Permission', 'You do not have permission to edit organisations.', 'warning');
                return;
            }
            form.reset();
            clearOrgModalValidation();
            document.getElementById('OrganisationID').value = id;
            document.getElementById('modalTitle').textContent = id === 0 ? 'Add Organisation' : 'Edit Organisation';
            
            // Activate first tab
            const firstTab = document.querySelector('#orgTabs button[data-bs-target="#general"]');
            bootstrap.Tab.getInstance(firstTab)?.show() || new bootstrap.Tab(firstTab).show();

            if (id > 0) {
                fetch(`/Organisation/GetOrganisation?id=${id}`)
                    .then(res => res.json())
                    .then(res => {
                        if (res.success) {
                            const data = res.data;
                            Object.keys(data).forEach(key => {
                                const input = form.elements[key];
                                if (input) {
                                    if (input.type === 'checkbox') {
                                        input.checked = data[key];
                                    } else if (input.type === 'date') {
                                        if (data[key]) input.value = data[key].split('T')[0];
                                    } else {
                                        input.value = data[key] ?? '';
                                    }
                                }
                            });
                        }
                    });
            }
            modal.show();
        }

        async function saveOrg() {
            const oid = parseInt(document.getElementById('OrganisationID').value) || 0;
            if (oid === 0 && !permCanAdd) {
                Swal.fire('Permission', 'You do not have permission to add organisations.', 'warning');
                return;
            }
            if (oid > 0 && !permCanEdit) {
                Swal.fire('Permission', 'You do not have permission to edit organisations.', 'warning');
                return;
            }
            if (!validateOrgForm()) return;
            const formData = new FormData(form);
            const data = {};
            
            // Handle all form elements dynamically converting them to JSON
            // Maps standard string inputs and asserts Checkboxes to C# booleans
            Array.from(form.elements).forEach(el => {
                if (!el.name) return;
                if (el.type === 'checkbox') {
                    data[el.name] = el.checked;
                } else if (el.value !== "") {
                    data[el.name] = el.value;
                }
            });

            // Ensure numeric IDs are correct
            data.OrganisationID = parseInt(data.OrganisationID) || 0;
            if (data.ParentOrganisationID) data.ParentOrganisationID = parseInt(data.ParentOrganisationID);

            const res = await fetch('/Organisation/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            
            if (result.success) {
                modal.hide();
                Swal.fire('Success', result.message, 'success').then(() => location.reload());
            } else {
                Swal.fire('Error', result.message, 'error');
            }
        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                Swal.fire('Permission', 'You do not have permission to change status.', 'warning').then(() => location.reload());
                return;
            }
            const res = await fetch(`/Organisation/ToggleStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
            const result = await res.json();
            if (!result.success) {
                Swal.fire('Error', result.message, 'error').then(() => location.reload());
            }
        }

        async function deleteOrg(id) {
            if (!permCanDelete) {
                Swal.fire('Permission', 'You do not have permission to delete organisations.', 'warning');
                return;
            }
            Swal.fire({
                title: 'Are you sure?',
                text: "This will soft-delete the organisation!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const res = await fetch(`/Organisation/Delete?id=${id}`, { method: 'POST' });
                    const resData = await res.json();
                    if (resData.success) {
                        Swal.fire('Deleted!', resData.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', resData.message, 'error');
                    }
                }
            });
        }
    </script>
}
