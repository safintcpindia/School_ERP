@model SchoolERP.Net.Models.MstUserManagementPageViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Permission Management";
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Permission Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <button class="btn btn-primary shadow-sm" id="btnAddPermission" onclick="openAddModal()">
            <i class="fas fa-plus me-2"></i>Add
        </button>
        <button id="btnEdit" class="btn btn-info shadow-sm" disabled onclick="editSelected()">
            <i class="fas fa-edit me-2"></i>Edit
        </button>
        <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
            <i class="fas fa-trash me-2"></i>Delete
        </button>
    </div>
</div>


