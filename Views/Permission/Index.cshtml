@*
    ======================================================================
    VIEW: Permission / Index.cshtml
    PURPOSE: User interface rendering for the Permission module.
    ======================================================================
*@
@model SchoolERP.Net.Models.MstUserManagementPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Permission Management";
    

    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
    {
        PermHelper.LoadPermissions(currentUserId);
    }

    var canAdd = PermHelper.HasPermissionByUrl("/Permission", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Permission", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Permission", "Delete");
}

<div id="permPageNotice" class="alert alert-danger py-2 px-3 small d-none mb-2" role="alert"></div>

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Permission Management</h6>
    </div>

    <div class="d-flex flex-wrap align-items-center gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary shadow-sm" id="btnAddPermission" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info shadow-sm" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>


