    <div class="row">
        <div class="col-xl-12">
        <div class="card shadow-tbl">
               @*  <div class="card-header bg-white py-3 border-bottom-0">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <h5 class="mb-0 fw-bold text-dark">Master Permissions (Actions)</h5>
                        <div class="position-relative">
                            <i class="fas fa-search search-icon-input"></i>
                            <input type="text" class="form-control form-control-sm ps-4" id="searchInput" placeholder="Search permissions...">
                        </div>
                    </div>
                </div> *@
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-items-center mb-0" id="permissionsTable">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">Select</th>
                                    <th>Permission Name (Action)</th>
                                    <th>Display Label</th>
                                    <th>Status</th>
                                    <th>Created On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Permissions)
                                {
                                    <tr class="item-row" onclick="selectItem(@p.PermissionID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="radio" name="selectedPermission" class="form-check-input" value="@p.PermissionID">
                                        </td>
                                        <td>
                                            <span class="badge bg-info-soft text-info fw-bold">@p.PermissionName</span>
                                        </td>
                                        <td>@p.DisplayLabel</td>
                                        <td onclick="event.stopPropagation()">
                                            @if (canEdit)
                                            {
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" checked="@p.IsActive" onchange="toggleStatus(@p.PermissionID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">@(p.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                        <td><span class="text-xs">@p.CreatedOn.ToString("dd MMM yyyy")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


<!---Add Permission---->
<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title fw-bold mb-0" id="modalTitle">Add Permission</h5>
                <div class="ms-auto d-flex align-items-center gap-1">
                    @* <button type="button" class="btn btn-sm btn-light" id="btnCancel" data-bs-dismiss="modal">Cancel</button> *@
                    <button type="button" class="btn btn-sm btn-success shadow-sm" id="btnSave" onclick="saveItem()"><i class="ti ti-cloud me-1"></i> Save</button>                    
                    <button class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                </div>
            </div>
            <div class="modal-body">
                <div id="permModalNotice" class="alert alert-warning py-2 small d-none mb-3" role="alert"></div>
                <form id="itemForm" class="row">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Permission Name (Standard Action) <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtPermissionName" placeholder="e.g. View / Add / Export" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtPermissionName"></div>
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Display Label <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtDisplayLabel" placeholder="e.g. View Records" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtDisplayLabel"></div>
                    </div>
                    <div class="col-md-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="isActive" checked>
                            <label class="form-check-label fw-bold" for="isActive">Active</label>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedPermissionId = 0;
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const IV = window.InlineFormValidation;
        const permFieldMap = {
            txtPermissionName: 'errTxtPermissionName',
            txtDisplayLabel: 'errTxtDisplayLabel'
        };

        function clearPermModalValidation() {
            IV.clearMap(permFieldMap);
            IV.clearNotice('permModalNotice');
        }

        function selectItem(id, row) {
            IV.clearNotice('permPageNotice');
            selectedPermissionId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            row.querySelector('input[type="radio"]').checked = true;
            const btnEdit = document.getElementById('btnEdit');
            const btnDelete = document.getElementById('btnDelete');
            if (btnEdit && permCanEdit) btnEdit.disabled = false;
            if (btnDelete && permCanDelete) btnDelete.disabled = false;
        }

        IV.bindAutoClear(permFieldMap);

        function validatePermissionNameField() {
            const name = document.getElementById('txtPermissionName').value.trim();
            if (!name) {
                IV.setFieldError('txtPermissionName', 'errTxtPermissionName', 'Permission name is required.');
                return false;
            }
            if (!/^[a-zA-Z][a-zA-Z0-9_ ]*$/.test(name)) {
                IV.setFieldError('txtPermissionName', 'errTxtPermissionName', 'Start with a letter. Only letters, numbers, spaces, and underscore are allowed.');
                return false;
            }
            if (name.length > 50) {
                IV.setFieldError('txtPermissionName', 'errTxtPermissionName', 'Permission name must be 50 characters or less.');
                return false;
            }
            IV.clearFieldError('txtPermissionName', 'errTxtPermissionName');
            return true;
        }

        function validateDisplayLabelField() {
            const label = document.getElementById('txtDisplayLabel').value.trim();
            if (!label) {
                IV.setFieldError('txtDisplayLabel', 'errTxtDisplayLabel', 'Display label is required.');
                return false;
            }
            if (label.length > 100) {
                IV.setFieldError('txtDisplayLabel', 'errTxtDisplayLabel', 'Display label must be 100 characters or less.');
                return false;
            }
            IV.clearFieldError('txtDisplayLabel', 'errTxtDisplayLabel');
            return true;
        }

        function openAddModal() {
            if (!permCanAdd) {
                IV.setNotice('permPageNotice', 'You do not have permission to add.');
                return;
            }
            IV.clearNotice('permPageNotice');
            clearPermModalValidation();
            document.getElementById('modalTitle').textContent = 'Add Permission';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            itemModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) {
                IV.setNotice('permPageNotice', 'You do not have permission to edit.');
                return;
            }
            if (selectedPermissionId === 0) return;
            IV.clearNotice('permPageNotice');
            clearPermModalValidation();
            const resp = await fetch(`/Permission/GetPermission?permissionId=${selectedPermissionId}`);
            const res = await resp.json();
            if (res.success) {
                document.getElementById('modalTitle').textContent = 'Edit Permission';
                document.getElementById('txtItemId').value = res.permission.permissionID;
                document.getElementById('txtPermissionName').value = res.permission.permissionName;
                document.getElementById('txtDisplayLabel').value = res.permission.displayLabel || '';
                document.getElementById('isActive').checked = res.permission.isActive;
                itemModal.show();
            } else {
                IV.setNotice('permPageNotice', res.message || 'Could not load permission.');
            }
        }

        async function deleteSelected() {
            if (!permCanDelete) {
                IV.setNotice('permPageNotice', 'You do not have permission to delete.');
                return;
            }
            if (selectedPermissionId === 0) return;
            if (!confirm('Are you sure you want to delete this permission? This action cannot be undone.')) return;

            IV.clearNotice('permPageNotice');
            const resp = await fetch(`/Permission/Delete?permissionId=${selectedPermissionId}`, { method: 'POST' });
            const res = await resp.json();
            if (res.success) location.reload();
            else IV.setNotice('permPageNotice', res.message || 'Delete failed.');
        }

        function validatePermissionForm() {
            clearPermModalValidation();
            const isNameValid = validatePermissionNameField();
            const isLabelValid = validateDisplayLabelField();
            return isNameValid && isLabelValid;
        }

        document.getElementById('txtPermissionName')?.addEventListener('blur', validatePermissionNameField);
        document.getElementById('txtDisplayLabel')?.addEventListener('blur', validateDisplayLabelField);

        async function saveItem() {
            const isNew = parseInt(document.getElementById('txtItemId').value, 10) === 0;
            if (isNew && !permCanAdd) {
                IV.setNotice('permModalNotice', 'You do not have permission to add.');
                return;
            }
            if (!isNew && !permCanEdit) {
                IV.setNotice('permModalNotice', 'You do not have permission to edit.');
                return;
            }
            if (!validatePermissionForm()) return;

            const data = {
                permissionID: parseInt(document.getElementById('txtItemId').value),
                permissionName: document.getElementById('txtPermissionName').value.trim(),
                displayLabel: document.getElementById('txtDisplayLabel').value.trim(),
                isActive: document.getElementById('isActive').checked
            };
            const resp = await fetch('/Permission/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const res = await resp.json();
            if (res.success) location.reload();
            else IV.setNotice('permModalNotice', res.message || 'Save failed.');
        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                IV.setNotice('permPageNotice', 'You do not have permission to change status.');
                return;
            }
            IV.clearNotice('permPageNotice');
            const resp = await fetch(`/Permission/ToggleStatus?permissionId=${id}&isActive=${isActive}`, { method: 'POST' });
            const res = await resp.json();
            if (!res.success) {
                IV.setNotice('permPageNotice', res.message || 'Could not update status.');
                location.reload();
            }
        }
    </script>
}
