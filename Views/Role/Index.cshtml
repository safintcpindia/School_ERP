@*
    ======================================================================
    VIEW: Role Management Index
    PURPOSE: Provides a single-page interface to view all master roles,
             toggle their active statuses, and create/edit roles.
             Contains a highly dynamic javascript-based hierarchical tree
             view for mapping modules permissions sequentially alongside role saves.
    FEATURES:
    - Master table rendering mapped from MstUserManagementPageViewModel
    - Split-modal design (Left: Metadata, Right: Matrix checks)
    - AJAX-based form submission for both Roles and Permissions
    ======================================================================
*@
@model SchoolERP.Net.Models.MstUserManagementPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Role Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/Role", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Role", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Role", "Delete");
}

<link rel="stylesheet" href="~/css/treeview.css" />
<style>
    /* ── Combined Role + Permission form ── */
    .role-form-panel {
        -background: #f8f9fa;
        border-right: 1px solid #dee2e6;
        min-width: 300px;
        max-width: 340px;
        display: flex;
        flex-direction: column;
    }
    .perm-panel {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .modal-split-body {
        display: flex;
        flex: 1;
        min-height: 0;
        overflow: hidden;
    }
    #rolePermModal .modal-content {
        height: 92vh;
        display: flex;
        flex-direction: column;
    }
    #rolePermModal .modal-body {
        flex: 1;
        min-height: 0;
        padding: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .perm-tree-scroll {
        flex: 1;
        overflow-y: auto;
    }
    .perm-checkbox { width: 18px; height: 18px; cursor: pointer; }
    .perm-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: #6c757d; display: block; margin-bottom: 4px; }

    /* section header inside left panel */
    .panel-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #6c757d;
        margin-bottom: 0.5rem;
        padding-bottom: 0.3rem;
        border-bottom: 1px solid #dee2e6;
    }

    /* perm toolbar */
    .perm-toolbar {
        background: #f8f9fa;
        border-bottom: 1px solid #dee2e6;
        padding: 0.5rem 0.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }
    .perm-toolbar .text-hint {
        font-size: 0.72rem;
        color: #6c757d;
    }
</style>


<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Role Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary shadow-sm" id="btnAddRole" onclick="openRoleForm(0)">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEditRole" class="btn btn-info shadow-sm" disabled onclick="editSelectedRole()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
    </div>
</div>

    <div class="row">
        <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    @*  <h5 class="mb-0 fw-bold text-dark">
                    All Users
                    </h5> *@
                    <div class="position-relative border d-flex align-items-center rounded-3 px-3">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search Roles..." style="min-width: 220px;">
                    </div>
                    <!--<div class="d-flex align-items-center gap-2 flex-wrap">
                        -- Status Filter --
                        <select class="form-select form-control" id="ddlStatusFilter" style="width: auto; min-width: 130px;">
                            <option value="all">All Status</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                            <option value="locked">Locked</option>
                        </select>
                        -- Search --
                    </div>-->
                </div>
            </div>
        </div>
    </div>
        <div class="col-xl-12">
            <div class="card shadow-tbl">               
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table" id="rolesTable">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">Select</th>
                                    <th>Role Name</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Created On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var role in Model.Roles)
                                {
                                    <tr class="item-row" onclick="selectRole(@role.RoleID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="radio" name="selectedRole" class="form-check-input" value="@role.RoleID">
                                        </td>
                                        <td>@role.RoleName</td>
                                        <td>@role.RoleDesc</td>
                                        <td onclick="event.stopPropagation()">
                                            @if (canEdit)
                                            {
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" @(role.IsActive ? "checked" : "") onchange="toggleStatus(@role.RoleID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(role.IsActive ? "bg-success" : "bg-secondary")">@(role.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                        <td>@role.CreatedOn.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


<!-- ═══════════════════════════════════════════════════════════
     COMBINED ROLE + PERMISSIONS MODAL
═══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="rolePermModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title fw-bold mb-0">                    
                    <span id="modalHeadTitle">Add Role</span>
                </h5>
                <div class="ms-auto d-flex align-items-center gap-1">                    
                    <button type="button" class="btn btn-success" id="btnSaveAll" onclick="saveAll()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>                    
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                </div>
            </div>

            <!-- Split body: LEFT = role details | RIGHT = permissions -->
            <div class="modal-body">
                <div class="modal-split-body">

                    <!-- ── LEFT: Role Details Panel ── -->
                    <div class="role-form-panel p-3">                        
                        <input type="hidden" id="txtRoleId" value="0">
                        <div class="mb-3">
                            <label class="form-label small">Role Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtRoleName"
                                   placeholder="e.g. SuperAdmin" required>
                            <div class="invalid-feedback" id="errTxtRoleName"></div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small">Description</label>
                            <textarea class="form-control" id="txtRoleDesc" rows="4"
                                      placeholder="Explain the role's scope..."></textarea>
                        </div>

                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="chkIsActive" checked>
                            <label class="form-check-label fw-semibold small" for="chkIsActive">Active</label>
                        </div>

                        <!-- Save status indicator inside panel -->
                        <div id="roleSaveStatus" class="d-none">
                            <div class="alert alert-success py-2 px-3 small mb-0" id="roleSaveOk">
                                <i class="fas fa-check-circle me-1"></i><span id="roleSaveOkMsg">Role saved.</span>
                            </div>
                            <div class="alert alert-danger py-2 px-3 small mb-0 d-none" id="roleSaveErr">
                                <i class="fas fa-exclamation-circle me-1"></i><span id="roleSaveErrMsg"></span>
                            </div>
                        </div>

                        <div class="mt-auto pt-3 border-top">
                            <p class="text-muted" style="font-size:0.72rem;">
                                <i class="fas fa-info-circle me-1 text-primary"></i>
                                Configure permissions on the right, then click <strong>Save Changes</strong> to apply both together.
                            </p>
                        </div>
                    </div>

                    <!-- ── RIGHT: Permissions Panel ── -->
                    <div class="perm-panel">
                        <div class="perm-toolbar bg-white border-0 mb-0">
                            @* <span class="text-hint"><i class="fas fa-info-circle me-1"></i>Toggle entire modules using the folder icons</span> *@
                            @* <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-primary" id="btnCheckAll" onclick="toggleAllChecks(true)">Check All</button>
                                <button class="btn btn-sm btn-outline-secondary" id="btnUncheckAll" onclick="toggleAllChecks(false)">Uncheck All</button>
                            </div> *@
                        </div>

                        <div class="perm-tree-scroll p-3">
                            <div class="tree-grid-container">
                                <table class="tree-grid">
                                    <thead>
                                        <tr id="treeHeaderRow">
                                            <th class="id-column">ID</th>
                                            <th>Menu Name</th>
                                            @* Dynamic permission columns injected by JS *@
                                        </tr>
                                    </thead>
                                    <tbody id="treeGridBody">
                                        <tr>
                                            <td colspan="10" class="text-center py-5 text-muted">
                                                <i class="fas fa-spinner fa-spin fa-lg me-2"></i>Loading permissions...
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Permission save status -->
                        <div id="permSaveStatus" class="d-none px-3 py-2 border-top small">
                            <span class="text-success d-none" id="permSaveOk"><i class="fas fa-check-circle me-1"></i>Permissions saved.</span>
                            <span class="text-danger d-none" id="permSaveErr"><i class="fas fa-exclamation-circle me-1"></i><span id="permSaveErrMsg"></span></span>
                        </div>
                    </div>

                </div><!-- /modal-split-body -->
            </div><!-- /modal-body -->

            <!-- Footer -->


        </div>
    </div>
</div>

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        let selectedRoleId = 0;
        const rolePermModal = new bootstrap.Modal(document.getElementById('rolePermModal'));
        const IV = window.InlineFormValidation;
        const roleFieldMap = {
            txtRoleName: 'errTxtRoleName'
        };

        function clearRoleModalValidation() {
            if(IV) IV.clearMap(roleFieldMap);
        }

        if(IV) IV.bindAutoClear(roleFieldMap);

        function selectRole(roleId, row) {
            selectedRoleId = roleId;
            document.querySelectorAll('#rolesTable tbody .item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            row.querySelector('input[type="radio"]').checked = true;
            const btnEdit = document.getElementById('btnEditRole');
            if (btnEdit && permCanEdit) btnEdit.disabled = false;
        }

        function editSelectedRole() {
            if (!permCanEdit || selectedRoleId <= 0) return;
            openRoleForm(selectedRoleId);
        }

        function validateRoleForm() {
            clearRoleModalValidation();
            let ok = true;
            const roleName = document.getElementById('txtRoleName').value.trim();
            if (!roleName) {
                if(IV) IV.setFieldError('txtRoleName', 'errTxtRoleName', 'Role Name is required.');
                ok = false;
            }
            return ok;
        }

        /* ─────────────────────────────────────────────────────────
           Open form for Add (id=0) or Edit (id>0)
        ───────────────────────────────────────────────────────── */
        async function openRoleForm(id) {
            if (id === 0 && !permCanAdd) {
                alert('You do not have permission to add roles.');
                return;
            }
            if (id > 0 && !permCanEdit) {
                alert('You do not have permission to edit roles.');
                return;
            }
            // Reset form & status banners
            document.getElementById('txtRoleId').value = id;
            document.getElementById('txtRoleName').value = '';
            document.getElementById('txtRoleDesc').value = '';
            document.getElementById('chkIsActive').checked = true;
            hideStatus();
            clearRoleModalValidation();

            document.getElementById('modalHeadTitle').textContent = id === 0 ? 'Add Role' : 'Edit Role';

            // Render permission tree (use roleId=0 for brand new role → all unchecked)
            loadPermissions(id);

            // If editing, fetch role data and pre-fill
            if (id > 0) {
                const resp = await fetch(`/Role/GetRole?roleId=${id}`);
                const res = await resp.json();
                if (res.success) {
                    document.getElementById('txtRoleName').value = res.role.roleName;
                    document.getElementById('txtRoleDesc').value = res.role.roleDesc || '';
                    document.getElementById('chkIsActive').checked = res.role.isActive;
                }
            }

            rolePermModal.show();
        }

        /* ─────────────────────────────────────────────────────────
           Save Role → then save Permissions (single click)
        ───────────────────────────────────────────────────────── */
        async function saveAll() {
            if (!validateRoleForm()) return;
            const roleName = document.getElementById('txtRoleName').value.trim();

            const ridBefore = parseInt(document.getElementById('txtRoleId').value);
            if (ridBefore === 0 && !permCanAdd) {
                alert('You do not have permission to add roles.');
                return;
            }
            if (ridBefore > 0 && !permCanEdit) {
                alert('You do not have permission to edit roles.');
                return;
            }

            const btn = document.getElementById('btnSaveAll');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Saving...';

            try {
                // ── Step 1: Save Role ──────────────────────────────
                // Serializes left-panel details first to generate an authoritative RoleID
                const roleData = {
                    roleID: parseInt(document.getElementById('txtRoleId').value),
                    roleName: roleName,
                    roleDesc: document.getElementById('txtRoleDesc').value.trim(),
                    isActive: document.getElementById('chkIsActive').checked
                };

                const roleResp = await fetch('/Role/Save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(roleData)
                });
                const roleRes = await roleResp.json();

                if (!roleRes.success) {
                    showError('role', roleRes.message);
                    return;
                }

                // Capture the authoritative RoleID (new or existing)
                const savedRoleId = roleRes.roleId || parseInt(document.getElementById('txtRoleId').value);
                document.getElementById('txtRoleId').value = savedRoleId;
                showOk('role', roleRes.message || 'Role saved successfully.');

                if (!permCanEdit) {
                    setTimeout(() => {
                        rolePermModal.hide();
                        location.reload();
                    }, 900);
                    return;
                }

                // ── Step 2: Save Permissions ───────────────────────
                // Pulls all checked permutations on the right panel into a JSON struct for bulk insertion against the RoleID
                const selected = [];
                document.querySelectorAll('.perm-checkbox:checked').forEach(cb => {
                    selected.push({
                        menuID: parseInt(cb.dataset.menu),
                        permissionID: parseInt(cb.dataset.perm)
                    });
                });

                const permResp = await fetch('/Role/SavePermissions', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ roleID: savedRoleId, selectedPermissions: selected })
                });
                const permRes = await permResp.json();

                if (!permRes.success) {
                    showError('perm', permRes.message);
                    return;
                }

                showOk('perm', 'Permissions saved successfully.');

                // Close after short delay and refresh list
                setTimeout(() => {
                    rolePermModal.hide();
                    location.reload();
                }, 900);

            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save me-2"></i>Save Changes';
            }
        }

        /* ─────────────────────────────────────────────────────────
           Toggle Status (inline in table)
        ───────────────────────────────────────────────────────── */
        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                alert('You do not have permission to change role status.');
                location.reload();
                return;
            }
            const resp = await fetch(`/Role/ToggleStatus?roleId=${id}&isActive=${isActive}`, { method: 'POST' });
            const res = await resp.json();
            if (!res.success) {
                alert(res.message || 'Could not update status.');
                location.reload();
            }
        }

        /* ─────────────────────────────────────────────────────────
           Load & render permission tree
        ───────────────────────────────────────────────────────── */
        async function loadPermissions(roleId) {
            const body = document.getElementById('treeGridBody');
            body.innerHTML = `<tr><td colspan="10" class="text-center py-5 text-muted">
                <i class="fas fa-spinner fa-spin fa-lg me-2"></i>Loading permissions...</td></tr>`;

            try {
                const resp = await fetch(`/Role/GetPermissions?roleId=${roleId}`);
                if (!resp.ok) throw new Error(`Server returned ${resp.status}: ${resp.statusText}`);
                
                const res = await resp.json();
                if (res.success) {
                    renderTree(res.data);
                } else {
                    body.innerHTML = `<tr><td colspan="10" class="text-center py-5 text-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>Error: ${res.message || 'Failed to load permissions'}</td></tr>`;
                }
            } catch (err) {
                console.error('LoadPermissions Error:', err);
                body.innerHTML = `<tr><td colspan="10" class="text-center py-5 text-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>Network or Script Error: ${err.message}</td></tr>`;
            }
        }

        function renderTree(matrix) {
            const body = document.getElementById('treeGridBody');
            body.innerHTML = '';

            if (!matrix || !Array.isArray(matrix) || matrix.length === 0) {
                const currentRoleId = parseInt(document.getElementById('txtRoleId')?.value || '0', 10);
                const emptyMessage = currentRoleId > 0
                    ? 'No menu permissions found in the system. Check if menus and permissions are seeded.'
                    : 'Save role details first to load the permission matrix.';
                body.innerHTML = `<tr><td colspan="10" class="text-center py-5 text-muted">
                    <i class="fas fa-info-circle me-2"></i>${emptyMessage}</td></tr>`;
                return;
            }

            const menus = {};
            const uniquePerms = [];
            const permIdsSeen = new Set();

            matrix.forEach(item => {
                // Handle possible case sensitivity (camelCase vs PascalCase)
                const mID = item.menuID || item.menuId;
                const mName = item.menuName || item.MenuName;
                const pID = item.parentID || item.parentId;
                const permID = item.permissionID || item.permissionId;
                const permName = item.permissionName || item.PermissionName;
                const lbl = item.displayLabel || item.DisplayLabel || permName;
                const hasAcc = item.hasAccess || item.HasAccess || false;

                if (!menus[mID]) {
                    // Structure nodes into Parent/Child groups.
                    menus[mID] = {
                        id: mID,
                        name: mName,
                        parentID: pID,
                        permissions: {}
                    };
                }
                // Flags if this specific access block is assigned or blank.
                menus[mID].permissions[permID] = hasAcc;

                if (!permIdsSeen.has(permID)) {
                    permIdsSeen.add(permID);
                    uniquePerms.push({
                        id: permID,
                        label: lbl,
                        name: permName
                    });
                }
            });

            uniquePerms.sort((a, b) => {
                if (a.name === 'View') return -1;
                if (b.name === 'View') return 1;
                return a.id - b.id;
            });

            const headerRow = document.getElementById('treeHeaderRow');
            headerRow.innerHTML = `<th class="id-column">ID</th><th>Menu Name</th>`;
            uniquePerms.forEach(p => {
                headerRow.innerHTML += `<th class="matrix-col w-s-nowrap">
                    <input type="checkbox"
                           class="form-check-input me-1 column-master-check"
                           data-perm="${p.id}"
                           onchange="togglePermissionColumn(this)"
                           ${permCanEdit ? '' : 'disabled'}>
                    ${p.label}
                </th>`;
            });

            const menuArray = Object.values(menus);
            const rootMenus = menuArray.filter(m => !m.parentID);

            const buildRows = (list, depth = 0) => {
                list.forEach((m, index) => {
                    const children = menuArray.filter(c => c.parentID === m.id);
                    const isParent = children.length > 0;
                    const isLast = index === list.length - 1;

                    const tr = document.createElement('tr');
                    tr.className = `tree-row depth-${depth} ${isParent ? 'parent-node collapsed' : 'leaf-node'}`;
                    tr.dataset.id = m.id;
                    if (m.parentID) tr.dataset.parentId = m.parentID;

                    let html = `<td class="id-column">${m.id}</td>`;

                    let toggleHtml = isParent
                        ? `<span class="tree-toggle" onclick="toggleNode(${m.id}, event)"><i class="fas fa-plus"></i></span>`
                        : `<span style="width:20px;display:inline-block;"></span>`;

                    html += `<td class="tree-cell">`;
                    for (let i = 0; i < depth; i++) {
                        html += `<span class="tree-indent"><span class="tree-line-v"></span></span>`;
                    }
                    if (depth > 0) {
                        html += `<span class="tree-indent">
                                    <span class="tree-line-v ${isLast ? 'last' : ''}"></span>
                                    <span class="tree-line-h"></span>
                                 </span>`;
                    }

                    html += `<input type="checkbox" class="row-master-check me-2" onchange="onToggleRow(this, ${m.id})"${permCanEdit ? '' : ' disabled'}>`;
                    html += toggleHtml;
                    html += `<i class="fas ${isParent ? 'fa-folder-open folder' : 'fa-file file'} tree-icon"></i>`;
                    html += `<span class="tree-label">${m.name}</span></td>`;

                    uniquePerms.forEach(p => {
                        const hasPerm = m.permissions[p.id];
                        if (hasPerm !== undefined) {
                            html += `<td class="matrix-col">
                                <input type="checkbox" class="form-check-input perm-checkbox"
                                       data-menu="${m.id}" data-perm="${p.id}" ${hasPerm ? 'checked' : ''}
                                       onchange="handlePermissionToggle(this)"
                                       ${permCanEdit ? '' : ' disabled'}>
                             </td>`;
                        } else {
                            html += `<td class="matrix-col">-</td>`;
                        }
                    });

                    tr.innerHTML = html;
                    body.appendChild(tr);

                    if (isParent) buildRows(children, depth + 1);
                });
            };

            buildRows(rootMenus);
            syncAllGridStates();
        }

        function toggleNode(menuId, event) {
            event.stopPropagation();
            const row = document.querySelector(`.tree-row[data-id="${menuId}"]`);
            const isExpanded = row.classList.contains('expanded');
            row.classList.toggle('expanded');
            row.classList.toggle('collapsed');
            const icon = row.querySelector('.tree-toggle i');
            icon.classList.toggle('fa-minus');
            icon.classList.toggle('fa-plus');
            const descendants = document.querySelectorAll(`.tree-row[data-parent-id="${menuId}"]`);
            descendants.forEach(d => {
                if (isExpanded) {
                    hideDescendants(d.dataset.id);
                    d.style.display = 'none';
                } else {
                    d.style.display = 'table-row';
                }
            });
        }

        function hideDescendants(parentId) {
            document.querySelectorAll(`.tree-row[data-parent-id="${parentId}"]`).forEach(d => {
                d.style.display = 'none';
                hideDescendants(d.dataset.id);
            });
        }

        function getTreeRow(menuId) {
            return document.querySelector(`.tree-row[data-id="${menuId}"]`);
        }

        function getDirectChildRows(menuId) {
            return Array.from(document.querySelectorAll(`.tree-row[data-parent-id="${menuId}"]`));
        }

        function getRowPermissionCheckboxes(menuId) {
            return Array.from(document.querySelectorAll(`#treeGridBody .perm-checkbox[data-menu="${menuId}"]`));
        }

        function getRowMasterCheckbox(menuId) {
            return getTreeRow(menuId)?.querySelector('.row-master-check');
        }

        function rowHasCheckedPermissions(menuId) {
            return getRowPermissionCheckboxes(menuId).some(cb => cb.checked);
        }

        function rowHasAnyActiveDescendant(menuId) {
            return getDirectChildRows(menuId).some(childRow => {
                const childMenuId = childRow.dataset.id;
                return isMenuActive(childMenuId);
            });
        }

        function isMenuActive(menuId) {
            return rowHasCheckedPermissions(menuId) || rowHasAnyActiveDescendant(menuId);
        }

        function syncRowMasterCheckbox(menuId) {
            const rowMaster = getRowMasterCheckbox(menuId);
            if (!rowMaster) return;
            rowMaster.checked = isMenuActive(menuId);
        }

        function syncAncestors(menuId) {
            const row = getTreeRow(menuId);
            if (!row || !row.dataset.parentId) return;

            const parentId = row.dataset.parentId;
            syncRowMasterCheckbox(parentId);
            syncAncestors(parentId);
        }

        function syncPermissionColumnHeader(permissionId) {
            const columnCheckboxes = document.querySelectorAll(`#treeGridBody .perm-checkbox[data-perm="${permissionId}"]`);
            const headerCheckbox = document.querySelector(`#treeHeaderRow .column-master-check[data-perm="${permissionId}"]`);
            if (!headerCheckbox || columnCheckboxes.length === 0) return;
            headerCheckbox.checked = Array.from(columnCheckboxes).every(cb => cb.checked);
        }

        function syncAllGridStates() {
            const allRows = Array.from(document.querySelectorAll('#treeGridBody .tree-row'));
            allRows
                .sort((a, b) => {
                    const depthA = parseInt((a.className.match(/depth-(\d+)/)?.[1] || '0'), 10);
                    const depthB = parseInt((b.className.match(/depth-(\d+)/)?.[1] || '0'), 10);
                    return depthB - depthA;
                })
                .forEach(row => syncRowMasterCheckbox(row.dataset.id));

            document.querySelectorAll('#treeHeaderRow .column-master-check')
                .forEach(headerCheckbox => syncPermissionColumnHeader(headerCheckbox.dataset.perm));
        }

        function setMenuBranchState(menuId, isChecked) {
            const row = getTreeRow(menuId);
            if (!row) return;

            const rowMaster = row.querySelector('.row-master-check');
            if (rowMaster) rowMaster.checked = isChecked;

            getRowPermissionCheckboxes(menuId).forEach(cb => {
                cb.checked = isChecked;
            });

            getDirectChildRows(menuId).forEach(childRow => {
                setMenuBranchState(childRow.dataset.id, isChecked);
            });
        }

        function onToggleRow(cb, menuId) {
            setMenuBranchState(menuId, cb.checked);
            syncAncestors(menuId);

            document.querySelectorAll('#treeHeaderRow .column-master-check')
                .forEach(headerCheckbox => syncPermissionColumnHeader(headerCheckbox.dataset.perm));
        }

        function handlePermissionToggle(permissionCheckbox) {
            const menuId = permissionCheckbox.dataset.menu;
            syncRowMasterCheckbox(menuId);
            syncAncestors(menuId);
            syncPermissionColumnHeader(permissionCheckbox.dataset.perm);
        }

        function togglePermissionColumn(headerCheckbox) {
            const permissionId = headerCheckbox.dataset.perm;
            const isChecked = headerCheckbox.checked;

            document.querySelectorAll(`#treeGridBody .perm-checkbox[data-perm="${permissionId}"]`)
                .forEach(cb => {
                    cb.checked = isChecked;
                    syncRowMasterCheckbox(cb.dataset.menu);
                    syncAncestors(cb.dataset.menu);
                });
        }

        function toggleAllChecks(check) {
            document.querySelectorAll('.perm-checkbox').forEach(cb => cb.checked = check);
        }

        /* ─────────────────────────────────────────────────────────
           Status helpers
        ───────────────────────────────────────────────────────── */
        function hideStatus() {
            document.getElementById('roleSaveStatus').classList.add('d-none');
            document.getElementById('roleSaveOk').classList.remove('d-none');
            document.getElementById('roleSaveErr').classList.add('d-none');
            document.getElementById('permSaveStatus').classList.add('d-none');
            document.getElementById('permSaveOk').classList.add('d-none');
            document.getElementById('permSaveErr').classList.add('d-none');
        }

        function showOk(target, msg) {
            if (target === 'role') {
                document.getElementById('roleSaveStatus').classList.remove('d-none');
                document.getElementById('roleSaveOk').classList.remove('d-none');
                document.getElementById('roleSaveErr').classList.add('d-none');
                document.getElementById('roleSaveOkMsg').textContent = msg;
            } else {
                document.getElementById('permSaveStatus').classList.remove('d-none');
                document.getElementById('permSaveOk').classList.remove('d-none');
                document.getElementById('permSaveErr').classList.add('d-none');
            }
        }

        function showError(target, msg) {
            if (target === 'role') {
                document.getElementById('roleSaveStatus').classList.remove('d-none');
                document.getElementById('roleSaveOk').classList.add('d-none');
                document.getElementById('roleSaveErr').classList.remove('d-none');
                document.getElementById('roleSaveErrMsg').textContent = msg;
            } else {
                document.getElementById('permSaveStatus').classList.remove('d-none');
                document.getElementById('permSaveOk').classList.add('d-none');
                document.getElementById('permSaveErr').classList.remove('d-none');
                document.getElementById('permSaveErrMsg').textContent = msg;
            }
        }

        /* ─────────────────────────────────────────────────────────
           Table search
        ───────────────────────────────────────────────────────── */
        document.getElementById('txtSearchInput').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#rolesTable tbody .item-row').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}
