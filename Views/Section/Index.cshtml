@*
    ======================================================================
    VIEW: Section / Index.cshtml
    PURPOSE: User interface rendering for the Section Management module.
    ======================================================================
*@
@model SchoolERP.Net.Models.MstSectionPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Section Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/Section", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Section", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Section", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-1 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Section Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary" id="btnAddSection" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-edit me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="sectionsTable">
                        <thead>
                            <tr class="bg-light">
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Section Name</th>
                                <th>Status</th>
                                <th>Created On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Sections)
                            {
                                <tr class="item-row" onclick="selectItem(@s.SectionID, this)" style="cursor: pointer;">
                                    <td class="ps-4 text-center">
                                        <input type="radio" name="selectedSection" class="form-check-input" value="@s.SectionID">
                                    </td>
                                    <td>
                                        @s.SectionName
                                    </td>
                                    <td>
                                        @if (canEdit)
                                        {
                                            <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                <input class="form-check-input section-status-switch" type="checkbox" @(s.IsActive ? "checked" : "") onchange="toggleStatus(@s.SectionID, this.checked)">
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span>
                                        }
                                    </td>
                                    <td>@s.CreatedOn.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header p-3">
                <h5 class="modal-title" id="modalTitle">Add Section</h5>
                <div class="ms-auto d-flex align-items-center gap-1">                    
                    <button type="button" class="btn btn-success" id="btnSave" onclick="saveItem()">
                        <i class="ti ti-cloud me-1"></i>Save
                    </button>
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                </div>
            </div>
            <div class="modal-body p-3">
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Section Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtSectionName" placeholder="e.g. Section A" autocomplete="off">
                        <div class="invalid-feedback" id="errTxtSectionName"></div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" checked>
                        <label class="form-check-label fw-bold" for="isActive">Active</label>                        
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const IV = window.InlineFormValidation;
        const sectionFieldMap = { txtSectionName: 'errTxtSectionName' };
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedSectionId = 0;

        function clearSectionModalValidation() {
            IV.clearMap(sectionFieldMap);
            IV.clearNotice('sectionModalNotice');
        }

        IV.bindAutoClear(sectionFieldMap);

        function selectItem(id, row) {
            IV.clearNotice('sectionPageNotice');
            selectedSectionId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            row.querySelector('input[type="radio"]').checked = true;
            const btnEdit = document.getElementById('btnEdit');
            const btnDelete = document.getElementById('btnDelete');
            if (btnEdit && permCanEdit) btnEdit.disabled = false;
            if (btnDelete && permCanDelete) btnDelete.disabled = false;
        }

        function openAddModal() {
            if (!permCanAdd) {
                IV.setNotice('sectionPageNotice', 'You do not have permission to add.');
                return;
            }
            IV.clearNotice('sectionPageNotice');
            clearSectionModalValidation();
            document.getElementById('modalTitle').textContent = 'Add Section';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            itemModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) {
                IV.setNotice('sectionPageNotice', 'You do not have permission to edit.');
                return;
            }
            if (selectedSectionId === 0) return;
            IV.clearNotice('sectionPageNotice');
            clearSectionModalValidation();
            try {
                const resp = await fetch(`/Section/GetSection?id=${selectedSectionId}`);
                const res = await resp.json();
                if (res.success) {
                    document.getElementById('modalTitle').textContent = 'Edit Section';
                    document.getElementById('txtItemId').value = res.data.sectionID;
                    document.getElementById('txtSectionName').value = res.data.sectionName;
                    document.getElementById('isActive').checked = res.data.isActive;
                    itemModal.show();
                } else {
                    IV.setNotice('sectionPageNotice', res.message || 'Could not load section.');
                }
            } catch (err) {
                console.error(err);
                IV.setNotice('sectionPageNotice', 'Could not load section details.');
            }
        }

        async function deleteSelected() {
            if (!permCanDelete) {
                IV.setNotice('sectionPageNotice', 'You do not have permission to delete.');
                return;
            }
            if (selectedSectionId === 0) return;
            if (!confirm('Are you sure you want to delete this section? This action cannot be undone.')) return;

            IV.clearNotice('sectionPageNotice');
            try {
                const resp = await fetch(`/Section/Delete?id=${selectedSectionId}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('sectionPageNotice', res.message || 'Delete failed.');
            } catch (err) {
                console.error(err);
                IV.setNotice('sectionPageNotice', 'Could not delete section.');
            }
        }

        async function saveItem() {
            const sid = parseInt(document.getElementById('txtItemId').value);
            if (sid === 0 && !permCanAdd) {
                IV.setNotice('sectionModalNotice', 'You do not have permission to add.');
                return;
            }
            if (sid > 0 && !permCanEdit) {
                IV.setNotice('sectionModalNotice', 'You do not have permission to edit.');
                return;
            }
            clearSectionModalValidation();
            const name = document.getElementById('txtSectionName').value.trim();
            if (!name) {
                IV.setFieldError('txtSectionName', 'errTxtSectionName', 'Section name is required.');
                return;
            }

            const data = {
                sectionID: parseInt(document.getElementById('txtItemId').value),
                sectionName: name,
                isActive: document.getElementById('isActive').checked
            };

            try {
                const resp = await fetch('/Section/Save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await resp.json();
                if (res.success) location.reload();
                else IV.setNotice('sectionModalNotice', res.message || 'Save failed.');
            } catch (err) {
                console.error(err);
                IV.setNotice('sectionModalNotice', 'Could not save section.');
            }
        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                IV.setNotice('sectionPageNotice', 'You do not have permission to change status.');
                if (window.toast) window.toast.error('You do not have permission to change status.');
                location.reload();
                return;
            }
            IV.clearNotice('sectionPageNotice');
            try {
                const resp = await fetch(`/Section/ToggleStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) {
                    if (window.toast) window.toast.success(res.message || 'Status updated.');
                } else {
                    IV.setNotice('sectionPageNotice', res.message || 'Could not update status.');
                    if (window.toast) window.toast.error(res.message || 'Could not update status.');
                    location.reload();
                }
            } catch (err) {
                console.error(err);
                IV.setNotice('sectionPageNotice', 'Could not update status.');
                location.reload();
            }
        }
    </script>
}
