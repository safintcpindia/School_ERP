@*
    ======================================================================
    VIEW: Sessions / Index.cshtml
    PURPOSE: User interface rendering for the Sessions module.
    ======================================================================
*@
@model SchoolERP.Net.Models.MstSessionPageViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Session Management";
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h4 class="fw-bold mb-0">Session Management</h4>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <button class="btn btn-primary shadow-sm" id="btnAddSession" onclick="openAddModal()">
            <i class="fas fa-plus me-2"></i>Add
        </button>
        <button id="btnEdit" class="btn btn-success shadow-sm" disabled onclick="editSelected()">
            <i class="fas fa-edit me-2"></i>Edit
        </button>
        <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
            <i class="fas fa-trash me-2"></i>Delete
        </button>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-items-center mb-0" id="sessionsTable">
                        <thead>
                            <tr class="bg-light">
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Session Title</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Created On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Sessions)
                            {
                                <tr class="item-row" onclick="selectItem(@s.SessionId, this)" style="cursor: pointer;">
                                    <td class="ps-4 text-center">
                                        <input type="radio" name="selectedSession" class="form-check-input" value="@s.SessionId">
                                    </td>
                                    <td>
                                        <span class="fw-bold">@s.SessionTitle</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-flex justify-content-center" onclick="event.stopPropagation()">
                                            <input class="form-check-input session-status-switch" type="checkbox" @(s.IsActive ? "checked" : "") onchange="toggleStatus(@s.SessionId, this.checked)">
                                        </div>
                                    </td>
                                    <td class="text-center"><span class="text-muted small">@s.CreatedOn.ToString("dd MMM yyyy")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom bg-light d-flex align-items-center">
                <h5 class="modal-title fw-bold mb-0" id="modalTitle">Add Session</h5>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-sm btn-primary shadow-sm" id="btnSave" onclick="saveItem()">
                        <i class="fas fa-save me-1"></i>Save Session
                    </button>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-4">
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Session Title</label>
                        <input type="text" class="form-control" id="txtSessionTitle" required placeholder="e.g. 2024-25">
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" checked>
                        <label class="form-check-label fw-bold" for="isActive">Active</label>
                        <div class="form-text">Activating this will deactivate all other sessions.</div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedSessionId = 0;

        function selectItem(id, row) {
            selectedSessionId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            row.querySelector('input[type="radio"]').checked = true;
            document.getElementById('btnEdit').disabled = false;
            document.getElementById('btnDelete').disabled = false;
        }

        function openAddModal() {
            document.getElementById('modalTitle').textContent = 'Add Session';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            itemModal.show();
        }

        async function editSelected() {
            if (selectedSessionId === 0) return;
            try {
                const resp = await fetch(`/Sessions/GetSession?id=${selectedSessionId}`);
                const res = await resp.json();
                if (res.success) {
                    document.getElementById('modalTitle').textContent = 'Edit Session';
                    document.getElementById('txtItemId').value = res.data.sessionId;
                    document.getElementById('txtSessionTitle').value = res.data.sessionTitle;
                    document.getElementById('isActive').checked = res.data.isActive;
                    itemModal.show();
                } else {
                    alert(res.message);
                }
            } catch (err) {
                console.error(err);
                alert('Error fetching session details');
            }
        }

        async function deleteSelected() {
            if (selectedSessionId === 0) return;
            if (!confirm('Are you sure you want to delete this session? This action cannot be undone.')) return;

            try {
                const resp = await fetch(`/Sessions/Delete?id=${selectedSessionId}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) location.reload(); else alert(res.message);
            } catch (err) {
                console.error(err);
                alert('Error deleting session');
            }
        }

        async function saveItem() {
            const title = document.getElementById('txtSessionTitle').value.trim();
            if (!title) {
                alert('Please enter session title');
                return;
            }

            // Constructs MstSessionUpsertRequest directly handling active states dynamically.
            const data = {
                sessionId: parseInt(document.getElementById('txtItemId').value),
                sessionTitle: title,
                isActive: document.getElementById('isActive').checked
            };

            try {
                const resp = await fetch('/Sessions/Save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await resp.json();
                if (res.success) location.reload(); else alert(res.message);
            } catch (err) {
                console.error(err);
                alert('Error saving session');
            }
        }

        async function toggleStatus(id, isActive) {
            try {
                const resp = await fetch(`/Sessions/ToggleStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) {
                    // Since only one can be active, reload to update UI switches
                    if (isActive) location.reload();
                } else {
                    alert(res.message);
                    location.reload();
                }
            } catch (err) {
                console.error(err);
                alert('Error toggling status');
                location.reload();
            }
        }
    </script>
}
