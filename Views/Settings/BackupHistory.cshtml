@*
    ======================================================================
    VIEW: Settings / BackupHistory.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@{
    Layout = "_Layout";
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Backup History</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        <button type="button" class="btn btn-primary d-inline-flex align-items-center" id="btnCreateBackup">
            <i class="ti ti-plus me-1"></i>Create Backup
        </button>
    </div>
</div>

<div class="row">
    <div class="col-xl-8">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Backup Files</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <a href="#" class="text-primary">db_ver_7.0.0_2024-02-19_11-39-37.sql</a>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end flex-wrap gap-1 flex-shrink-0">
                                        <button class="btn btn-icon btn-sm btn-outline-primary" title="Download">
                                            <i class="ti ti-download fs-13"></i>
                                        </button>
                                        <button class="btn btn-icon btn-sm btn-outline-success" title="Restore">
                                            <i class="ti ti-restore fs-13"></i>
                                        </button>
                                        <button class="btn btn-icon btn-sm btn-outline-danger" title="Delete">
                                            <i class="ti ti-trash fs-13"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="#" class="text-primary">db_ver_7.0.0_2024-01-15_09-22-10.sql</a>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end flex-wrap gap-1 flex-shrink-0">
                                        <button class="btn btn-icon btn-sm btn-outline-primary" title="Download">
                                            <i class="ti ti-download fs-13"></i>
                                        </button>
                                        <button class="btn btn-icon btn-sm btn-outline-success" title="Restore">
                                            <i class="ti ti-restore fs-13"></i>
                                        </button>
                                        <button class="btn btn-icon btn-sm btn-outline-danger" title="Delete">
                                            <i class="ti ti-trash fs-13"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <a href="#" class="text-primary">db_ver_6.5.0_2023-12-01_14-55-42.sql</a>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end flex-wrap gap-1 flex-shrink-0">
                                        <button class="btn btn-icon btn-sm btn-outline-primary" title="Download">
                                            <i class="ti ti-download fs-13"></i>
                                        </button>
                                        <button class="btn btn-icon btn-sm btn-outline-success" title="Restore">
                                            <i class="ti ti-restore fs-13"></i>
                                        </button>
                                        <button class="btn btn-icon btn-sm btn-outline-danger" title="Delete">
                                            <i class="ti ti-trash fs-13"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-header">
                <h6 class="card-title small">Upload From Local Directory</h6>
            </div>
            <div class="card-body">
                <form action="/"
                      method="post"
                      class="dropzone dz-clickable"
                      id="myAwesomeDropzone"
                      data-plugin="dropzone"
                      data-previews-container="#file-previews"
                      data-upload-preview-template="#uploadPreviewTemplate">
                    <div class="dz-message needsclick">
                        <i class="ti ti-cloud-upload h1 text-muted"></i>
                        <h6 class="small">Drop files here or click to upload.</h6>                       
                    </div>
                </form>
                <!-- Preview -->
                <div class="dropzone-previews"
                     id="file-previews">
                </div>
               @*  <div class="border border-dashed rounded p-4 text-center">
                    <i class="ti ti-cloud-upload fs-1 text-muted d-block mb-2" style="font-size: 48px !important;"></i>
                    <h6 class="small">Drop files here or click to upload.</h6>
                    <input type="file" class="form-control mt-3" accept=".sql,.bak">
                </div> *@
                <button class="btn btn-primary w-100 mt-3">Upload</button>
            </div>
        </div>

        <div class="card shadow-tbl-outer">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="card-title mb-0">Cron Secret Key</h6>
                <button class="btn btn-success">Generate</button>
            </div>
            <div class="card-body">
                <input type="text" class="form-control" readonly placeholder="Generated key will appear here">
            </div>
        </div>
    </div>
</div>


<!-- file preview template -->
<div class="d-none" id="uploadPreviewTemplate">
    <div class="card mt-2 mb-0 shadow-none border">
        <div class="p-2">
            <div class="row align-items-center">
                <div class="col-auto">
                    <img data-dz-thumbnail
                         src="#"
                         class="avatar-sm rounded bg-light"
                         alt="" />
                </div>
                <div class="col ps-0">
                    <a href="javascript:void(0);"
                       class="text-muted fw-bold"
                       data-dz-name></a>
                    <p class="mb-0" data-dz-size></p>
                </div>
                <div class="col-auto">
                    <!-- Button -->
                    <a href=""
                       class="btn btn-link btn-lg text-muted"
                       data-dz-remove>
                        <i class="ti ti-x"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- end card -->
</div>