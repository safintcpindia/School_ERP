@*
    ======================================================================
    VIEW: Settings / Captcha.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@{
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Captcha Setting</h6>
    </div>
</div>
<!-- End Page Header -->
<!-- start row -->

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-header">
                <div class="d-flex align-items-center justify-content-between flex-wrap">
                    <div class="position-relative border d-flex align-items-center rounded-3 px-3">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search ..." style="min-width: 220px;">
                    </div>
                    <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                        <button class="btn btn-icon btn-outline-primary" title="Copy">
                            <i class="ti ti-copy fs-5"></i>
                        </button>
                        <button class="btn btn-icon btn-outline-secondary" title="Excel">
                            <i class="ti ti-file-excel fs-5"></i>
                        </button>
                        <button class="btn btn-icon btn-outline-info" title="CSV">
                            <i class="ti ti-file-barcode fs-5"></i>
                        </button>
                        <button class="btn btn-icon btn-outline-danger" title="Pdf">
                            <i class="ti ti-file-type-pdf fs-5"></i>
                        </button>
                        <button class="btn btn-icon btn-outline-success" title="Print">
                            <i class="ti ti-printer fs-5"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="card-body">

                <div class="tab-content">

                    <!-----System Pane---->
                    <div class="tab-pane active" id="system">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-----Student Pane---->
                    <div class="tab-pane" id="std">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-----Parent Pane---->
                    <div class="tab-pane" id="prt">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>



                </div>

            </div>
            <!-- end card-body -->
        </div>
        <!-- end card -->
    </div>
    <!-- end col -->

</div>
<!-- end row -->
