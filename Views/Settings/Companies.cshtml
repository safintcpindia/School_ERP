@model SchoolERP.Net.Models.MstCompanyPageViewModel
@{
    Layout = "_Layout";
}

<style>
    :root {
        --tree-line-color: #dee2e6;
        --tree-indent: 2.5rem;
    }

    .tree-node {
        position: relative;
        display: flex;
        align-items: center;
    }

    .tree-indent-wrapper {
        display: flex;
        align-items: center;
        height: 100%;
    }

    .tree-line {
        width: var(--tree-indent);
        height: 48px;
        position: relative;
        flex-shrink: 0;
    }

    .tree-line::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 0;
        bottom: 0;
        width: 2px;
        background-color: var(--tree-line-color);
    }

    .tree-line.last::before {
        bottom: 50%;
    }

    .tree-line.horizontal::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 100%;
        height: 2px;
        background-color: var(--tree-line-color);
    }

    .tree-toggle {
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: 2px solid var(--tree-line-color);
        border-radius: 6px;
        cursor: pointer;
        z-index: 2;
        transition: all 0.2s ease;
        margin-right: 12px;
        color: #6c757d;
        font-size: 10px;
    }

    .tree-toggle:hover {
        background: var(--bs-primary);
        border-color: var(--bs-primary);
        color: #fff;
        transform: scale(1.1);
    }

    .tree-toggle i {
        transition: transform 0.3s ease;
    }

    .tree-toggle.collapsed i {
        transform: rotate(-90deg);
    }

    .item-row {
        transition: background-color 0.2s ease;
    }

    .item-row:hover {
        background-color: rgba(var(--bs-primary-rgb), 0.03) !important;
    }

    .item-row.hidden {
        display: none;
    }

    .avatar-sm {
        transition: transform 0.2s ease;
    }

    .item-row:hover .avatar-sm {
        transform: scale(1.1) rotate(5deg);
    }

    /* Indentation levels */
    .level-0 { padding-left: 0; }
    .level-1 { padding-left: 2rem; }
    .level-2 { padding-left: 4rem; }
    .level-3 { padding-left: 6rem; }
    .level-4 { padding-left: 8rem; }
    
    .school-name-cell {
        min-width: 300px;
    }

    .badge-soft-primary {
        background-color: rgba(var(--bs-primary-rgb), 0.1);
        color: var(--bs-primary);
    }
</style>


<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Company Master</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <button class="btn btn-primary shadow-sm" id="btnAddCompany" onclick="openModal()">
            <i class="fas fa-plus me-2"></i>Add
        </button>
        <button id="btnEdit" class="btn btn-info shadow-sm" disabled onclick="editSelected()">
            <i class="fas fa-edit me-2"></i>Edit
        </button>
        <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
            <i class="fas fa-trash me-2"></i>Delete
        </button>
    </div>
</div>

    <div class="card border-0 shadow-tbl">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table" id="companyTable">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 50px;">Select</th>
                            <th>School Name</th>
                            <th>Code</th>
                            <th>Parent</th>
                            <th>Email/Phone</th>
                            <th>Session</th>
                            <th>Currency</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Companies)
                        {
                            <tr class="item-row level-@item.Level" 
                                data-id="@item.CompanyId" 
                                data-parent="@(item.ParentCompanyId ?? 0)" 
                                onclick="selectItem(@item.CompanyId, this)" 
                                style="cursor: pointer;">
                                <td class="ps-4 text-center">
                                    <input type="radio" name="selectedCompany" class="form-check-input" value="@item.CompanyId">
                                </td>
                                <td class="school-name-cell">
                                    <div class="d-flex align-items-center" style="margin-left: @(item.Level * 2.5)rem;">
                                        @if (item.HasChildren)
                                        {
                                            <div class="tree-toggle" onclick="toggleHierarchy(@item.CompanyId, event)">
                                                <i class="fas fa-chevron-down"></i>
                                            </div>
                                        }
                                        else if (item.Level > 0)
                                        {
                                            <div style="width: 36px;"></div>
                                        }
                                        
                                        <div class="avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                            <i class="ti ti-building fs-5"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark d-block">@item.SchoolName</span>
                                            <small class="text-muted">ID: @item.CompanyId</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge badge-soft-primary px-2 py-1">@item.SchoolCode</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ParentName))
                                    {
                                        <span class="text-muted small"><i class="ti ti-arrow-forward-up me-1"></i>@item.ParentName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="text-muted mb-1"><i class="ti ti-mail me-1"></i>@item.Email</div>
                                        <div class="text-muted"><i class="ti ti-phone me-1"></i>@item.Phone</div>
                                    </div>
                                </td>
                                <td><span class="text-dark small fw-medium">@item.SessionTitle</span></td>
                                <td><span class="badge bg-light text-dark border">@item.CurrencyCode</span></td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center" onclick="event.stopPropagation()">
                                        <input class="form-check-input" type="checkbox" checked="@item.IsActive" onchange="toggleStatus(@item.CompanyId, this.checked)">
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


<!-- Add/Edit Modal -->
<div class="modal fade" id="companyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold mb-0" id="modalTitle">Add New Company</h5>
                <div class="ms-auto d-flex align-items-center gap-2">
                    @* <button type="button" class="btn btn-sm btn-light" id="btnCancel" data-bs-dismiss="modal">Cancel</button> *@
                    <button type="button" class="btn btn-sm btn-primary shadow-sm" id="btnSave" onclick="saveCompany()"><i class="ti ti-cloud me-1"></i> Save</button>
                    <button class="btn-out-close" data-bs-dismiss="modal"><i class="ti ti-x"></i></button>
                </div>
            </div>
            <div class="modal-body p-4">
                <form id="companyForm">
                    <input type="hidden" id="txtCompanyId" value="0" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">School Name <span class="text-danger">*</span></label>
                            <input type="text" id="txtSchoolName" class="form-control" placeholder="" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">School Code <span class="text-danger">*</span></label>
                            <input type="text" id="txtSchoolCode" class="form-control" placeholder="" required>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Parent Company</label>
                            <select id="ddlParentCompany" class="form-select form-control">
                                <option value="">Select Parent</option>
                                @foreach (var p in Model.ParentCompanies)
                                {
                                    <option value="@p.CompanyId">@p.SchoolName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Address</label>
                            <textarea id="txtAddress" class="form-control" rows="2" placeholder=""></textarea>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Phone</label>
                            <input type="text" id="txtPhone" class="form-control" placeholder="">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Email</label>
                            <input type="email" id="txtEmail" class="form-control" placeholder="">
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Default Session <span class="text-danger">*</span></label>
                            <select id="ddlSession" class="form-select form-control" required>
                                <option value="">Select</option>
                                @foreach (var s in Model.Sessions)
                                {
                                    <option value="@s.SessionId">@s.SessionTitle</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Default Currency <span class="text-danger">*</span></label>
                            <select id="ddlCurrency" class="form-select form-control" required>
                                <option value="">Select</option>
                                @foreach (var c in Model.Currencies)
