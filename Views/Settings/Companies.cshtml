                                <option value="Pacific/Wake">(GMT+12:00) Pacific, Wake</option>
                                <option value="Pacific/Wallis">(GMT+12:00) Pacific, Wallis</option>
                                <option value="Pacific/Chatham">(GMT+12:45) Pacific, Chatham</option>
                                <option value="Pacific/Apia">(GMT+13:00) Pacific, Apia</option>
                                <option value="Pacific/Fakaofo">(GMT+13:00) Pacific, Fakaofo</option>
                                <option value="Pacific/Kanton">(GMT+13:00) Pacific, Kanton</option>
                                <option value="Pacific/Tongatapu">(GMT+13:00) Pacific, Tongatapu</option>
                                <option value="Pacific/Kiritimati">(GMT+14:00) Pacific, Kiritimati</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Start Day of Week</label>
                            <select id="ddlStartDay" class="form-select form-control">
                                <option value="Monday" selected="">Monday</option>
                                <option value="Tuesday">Tuesday</option>
                                <option value="Wednesday">Wednesday</option>
                                <option value="Thursday">Thursday</option>
                                <option value="Friday">Friday</option>
                                <option value="Saturday">Saturday</option>
                                <option value="Sunday">Sunday</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Currency Format</label>
                            <select id="ddlCurrencyFormat" class="form-select form-control">
                                <option value="">Select</option>
                                <option value="####.##">12345678.00</option>
                                <option value="#,###.##">12,345,678.00</option>
                                <option value="#,##,###.##">1,23,45,678.00</option>
                                <option value="#.###.##">12.345.678.00</option>
                                <option value="#.###,##">12.345.678,00</option>
                                <option value="# ###.##">12 345 678.00 (Not For RTL)</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-check-label">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkIsActive" checked>
                                <label class="form-check-label" for="chkIsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<script>
    let selectedCompanyId = 0;

    function selectItem(id, row) {
        selectedCompanyId = id;
        // Highlight row
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        // Check radio
        row.querySelector('input[type="radio"]').checked = true;
        // Enable buttons
        document.getElementById('btnEdit').disabled = false;
        document.getElementById('btnDelete').disabled = false;
    }

    function toggleHierarchy(parentId, event) {
        event.stopPropagation();
        const toggle = event.currentTarget;
        const isCollapsed = toggle.classList.toggle('collapsed');
        const icon = toggle.querySelector('i');
        
        if (isCollapsed) {
            icon.classList.replace('fa-chevron-down', 'fa-chevron-right');
            hideChildren(parentId);
        } else {
            icon.classList.replace('fa-chevron-right', 'fa-chevron-down');
            showChildren(parentId);
        }
    }

    function hideChildren(parentId) {
        document.querySelectorAll(`tr[data-parent="${parentId}"]`).forEach(row => {
            row.classList.add('hidden');
            const id = row.getAttribute('data-id');
            const toggle = row.querySelector('.tree-toggle');
            if (toggle) {
                toggle.classList.add('collapsed');
                toggle.querySelector('i').classList.replace('fa-chevron-down', 'fa-chevron-right');
            }
            hideChildren(id);
        });
    }

    function showChildren(parentId) {
        document.querySelectorAll(`tr[data-parent="${parentId}"]`).forEach(row => {
            row.classList.remove('hidden');
            // We only show direct children, they might be collapsed themselves
            // but the user can then expand them. 
            // If we want to keep their previous state, we'd need more logic.
            // For now, let's just show direct children.
        });
    }

    function openModal() {
        $('#companyForm')[0].reset();
        $('#txtCompanyId').val(0);
        $('#modalTitle').text('Add New Company');
        $('#companyModal').modal('show');
    }

    async function editSelected() {
        if (selectedCompanyId === 0) return;
        try {
            const response = await fetch(`/Settings/GetCompany/${selectedCompanyId}`);
            const result = await response.json();
            
            if (result.success) {
                const data = result.data;
                $('#txtCompanyId').val(data.companyId);
                $('#txtSchoolName').val(data.schoolName);
                $('#txtSchoolCode').val(data.schoolCode);
                $('#ddlParentCompany').val(data.parentCompanyId || "");
                $('#txtAddress').val(data.address);
                $('#txtPhone').val(data.phone);
                $('#txtEmail').val(data.email);
                $('#ddlSession').val(data.sessionId);
                $('#ddlCurrency').val(data.currencyId);
                $('#ddlStartMonth').val(data.sessionStartMonth);
                $('#ddlDateFormat').val(data.dateFormat);
                $('#ddlTimezone').val(data.timezone);
                $('#ddlStartDay').val(data.startDayOfWeek);
                $('#ddlCurrencyFormat').val(data.currencyFormat || "");
                $('#chkIsActive').prop('checked', data.isActive);

                $('#modalTitle').text('Edit Company');
                $('#companyModal').modal('show');
            } else {
                alert(result.message || 'Error fetching company details');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An unexpected error occurred');
        }
    }

    async function saveCompany() {
        const formData = {
            companyId: parseInt($('#txtCompanyId').val()),
            schoolName: $('#txtSchoolName').val(),
            schoolCode: $('#txtSchoolCode').val(),
            parentCompanyId: $('#ddlParentCompany').val() ? parseInt($('#ddlParentCompany').val()) : null,
            address: $('#txtAddress').val(),
            phone: $('#txtPhone').val(),
            email: $('#txtEmail').val(),
            sessionId: parseInt($('#ddlSession').val()),
            currencyId: parseInt($('#ddlCurrency').val()),
            sessionStartMonth: $('#ddlStartMonth').val(),
            dateFormat: $('#ddlDateFormat').val(),
            timezone: $('#ddlTimezone').val(),
            startDayOfWeek: $('#ddlStartDay').val(),
            currencyFormat: $('#ddlCurrencyFormat').val(),
            isActive: $('#chkIsActive').is(':checked')
        };
        
        if (!formData.schoolName || !formData.schoolCode || !formData.sessionId || !formData.currencyId) {
            alert('Please fill all required fields');
            return;
        }

        try {
            const response = await fetch('/Settings/SaveCompany', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });
            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert(result.message || 'Error saving company');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An unexpected error occurred');
        }
    }

    async function toggleStatus(id, isActive) {
        try {
            const response = await fetch(`/Settings/ToggleCompanyStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
            const result = await response.json();
            if (!result.success) {
                alert(result.message || 'Error updating status');
                location.reload();
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An unexpected error occurred');
            location.reload();
        }
    }
</script>
