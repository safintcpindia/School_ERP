@*
    ======================================================================
    VIEW: Settings / Languages.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@using SchoolERP.Net.Services
@inject ILocalizationService Localizer
@{
    Layout = "_Layout";
    var availableLanguages = Localizer.GetAvailableLanguages().OrderBy(l => l).ToList();
    var currentLanguage = Localizer.GetCurrentLanguage();
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h4 class="fw-bold mb-0">@Localizer.GetString("languages")</h4>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-2">
        <button type="button" class="btn btn-primary d-inline-flex align-items-center" id="btnAddLanguage">
            <i class="ti ti-plus me-1"></i>Add
        </button>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Language</th>
                                <th>Status</th>
                                <th>Active</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var lang in availableLanguages)
                            {
                                <tr>
                                    <td>@i++</td>
                                    <td>
                                        <img src="~/assets/img/flags/us.png" class="me-1" width="20" alt="">
                                        @System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(lang.Replace("_", " "))
                                    </td>
                                    <td>
                                        <span class="badge badge-boxed badge-outline-success">Active</span>
                                    </td>
                                    <td>
                                        <form asp-controller="Language" asp-action="SetLanguage" method="post" id="form_@lang">
                                            <input type="hidden" id="txtLanguage_@lang" name="language" value="@lang" />
                                            <input type="hidden" id="txtReturnUrl_@lang" name="returnUrl" value="@Context.Request.Path" />
                                            <div class="form-check">
                                                <input type="radio" id="optLanguage_@lang" class="form-check-input" name="activeLanguage" 
                                                       @(currentLanguage == lang ? "checked" : "") 
                                                       onchange="document.getElementById('form_@lang').submit();">
                                            </div>
                                        </form>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex align-items-center justify-content-end gap-2">
                                            <a href="/Settings/Translations/@lang" id="btnEditTranslations_@lang" class="btn btn-sm btn-outline-primary" title="Edit Translations">
                                                <i class="ti ti-edit"></i>
                                            </a>
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" id="chkLanguageActive_@lang" type="checkbox" role="switch" checked>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
