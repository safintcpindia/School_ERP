@*
    ======================================================================
    VIEW: Settings / PaymentMethods.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@model SchoolERP.Net.Models.PaymentMethodsPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@using SchoolERP.Net.Services
@inject ILocalizationService Localizer
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Payment Methods";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/Settings", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Settings", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Settings", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Payment Methods</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary shadow-sm" id="btnAddPayment" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-success shadow-sm" disabled onclick="editSelected()">
                <i class="ti ti-edit me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-items-center mb-0" id="paymentMethodsTable">
                            <thead>
                                <tr class="bg-light">
                                    <th class="ps-4" style="width: 50px;">Select</th>
                                    <th>Payment Key</th>
                                    <th>Payment Secret</th>
                                    <th>Status</th>
                                    <th>Created On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.PaymentMethods != null && Model.PaymentMethods.Any())
                                {
                                    @foreach (var item in Model.PaymentMethods)
                                    {
                                        <tr class="item-row" onclick="selectItem(@item.PaymentId, this)" style="cursor: pointer;">
                                            <td class="ps-4 text-center">
                                                <input type="radio" name="selectedPayment" class="form-check-input" value="@item.PaymentId">
                                            </td>
                                            <td>
                                                <span class="badge bg-info-soft text-info fw-bold">@item.PaymentKey</span>
                                            </td>
                                            <td><span class="text-muted">••••••••••••</span></td>
                                            <td class="text-center">
                                                @if (canEdit)
                                                {
                                                    <div class="form-check form-switch d-flex justify-content-center" onclick="event.stopPropagation()">
                                                        <input class="form-check-input" type="checkbox" @(item.IsActive ? "checked" : "") onchange="toggleStatus(@item.PaymentId, this.checked)">
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Active" : "Inactive")</span>
                                                }
                                            </td>
                                            <td class="text-center"><span class="text-xs">@item.CreatedOn.ToString("dd MMM yyyy")</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">No payment methods found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <h6 class="modal-title" id="modalTitle">Add Payment Method</h6>
                <div class="ms-auto d-flex align-items-center gap-1">                    
                    <button type="button" class="btn btn-success shadow-sm" id="btnSave" onclick="saveItem()"><i class="ti ti-cloud me-1"></i> Save Changes</button>
                    <button type="button" class="btn btn-danger ms-1" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                </div>
            </div>
            <div class="modal-body p-4">
                @* Local alert div removed in favor of global toast system *@
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="mb-3">
                        <input type="text" class="form-control" id="txtPaymentKey" required placeholder="e.g. pk_live_xxxxxxxx">
                        <div class="invalid-feedback" id="errPaymentKey"></div>
                    </div>
                    <div class="mb-3">
                        <input type="password" class="form-control" id="txtPaymentSecret" required placeholder="e.g. sk_live_xxxxxxxx">
                        <div class="invalid-feedback" id="errPaymentSecret"></div>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" checked>
                        <label class="form-check-label" for="isActive">Active</label>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const IV = window.InlineFormValidation;
        const paymentFieldMap = { 
            txtPaymentKey: 'errPaymentKey', 
            txtPaymentSecret: 'errPaymentSecret' 
        };
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedPaymentId = 0;

        function clearPaymentModalValidation() {
            IV.clearMap(paymentFieldMap);
            IV.clearNotice('paymentModalNotice');
        }

        IV.bindAutoClear(paymentFieldMap);

        function selectItem(id, row) {
            selectedPaymentId = id;
            // Highlight row
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            // Check radio
            row.querySelector('input[type="radio"]').checked = true;
            const btnEdit = document.getElementById('btnEdit');
            const btnDelete = document.getElementById('btnDelete');
            if (btnEdit && permCanEdit) btnEdit.disabled = false;
            if (btnDelete && permCanDelete) btnDelete.disabled = false;
        }

        function openAddModal() {
            if (!permCanAdd) {
                showToast('You do not have permission to add.', 'warning');
                return;
            }
            clearPaymentModalValidation();
            document.getElementById('modalTitle').textContent = 'Add Payment Method';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            itemModal.show();
        }

        async function editSelected() {
            if (!permCanEdit) {
                showToast('You do not have permission to edit.', 'warning');
                return;
            }
            if (selectedPaymentId === 0) return;
            clearPaymentModalValidation();
            const resp = await fetch(`/api/PaymentMethodApi/GetById/${selectedPaymentId}`);
            const res = await resp.json();
            if (res.success) {
                document.getElementById('modalTitle').textContent = 'Edit Payment Method';
                document.getElementById('txtItemId').value = res.data.paymentId;
                document.getElementById('txtPaymentKey').value = res.data.paymentKey;
                document.getElementById('txtPaymentSecret').value = res.data.paymentSecret;
                document.getElementById('isActive').checked = res.data.isActive;
                itemModal.show();
            }
        }

        async function deleteSelected() {
            if (!permCanDelete) {
                showToast('You do not have permission to delete.', 'warning');
                return;
            }
            if (selectedPaymentId === 0) return;
            if (!confirm('Are you sure you want to delete this payment method? This action cannot be undone.')) return;

            const resp = await fetch(`/Settings/DeletePaymentMethod?id=${selectedPaymentId}`, { method: 'POST' });
            const res = await resp.json();
            if (res.success) location.reload(); else showToast(res.message, 'error');
        }

        async function saveItem() {
            const pid = parseInt(document.getElementById('txtItemId').value);
            if (pid > 0 && !permCanEdit) {
                IV.setNotice('paymentModalNotice', 'You do not have permission to edit.');
                return;
            }
            clearPaymentModalValidation();

            const paymentKey = document.getElementById('txtPaymentKey').value.trim();
            const paymentSecret = document.getElementById('txtPaymentSecret').value.trim();

            let hasError = false;
            if (!paymentKey) { IV.setFieldError('txtPaymentKey', 'errPaymentKey', 'Payment key is required.'); hasError = true; }
            if (!paymentSecret) { IV.setFieldError('txtPaymentSecret', 'errPaymentSecret', 'Payment secret is required.'); hasError = true; }

            if (hasError) return;

            // Maps UI parameters to MstPaymentMethodUpsertRequest
            const data = {
                paymentId: pid,
                paymentKey: paymentKey,
                paymentSecret: paymentSecret,
                isActive: document.getElementById('isActive').checked
            };

            const resp = await fetch('/Settings/SavePaymentMethod', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const res = await resp.json();
            if (res.success) {
                location.reload();
            } else {
                IV.setNotice('paymentModalNotice', res.message || 'Save failed.');
            }

        }

        async function toggleStatus(id, isActive) {
            if (!permCanEdit) {
                showToast('You do not have permission to change status.', 'warning');
                location.reload();
                return;
            }
            await fetch(`/Settings/TogglePaymentStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
        }
    </script>
}
