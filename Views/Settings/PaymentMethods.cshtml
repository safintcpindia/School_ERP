@*
    ======================================================================
    VIEW: Settings / PaymentMethods.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@model SchoolERP.Net.Models.PaymentMethodsPageViewModel
@using SchoolERP.Net.Services
@inject ILocalizationService Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = "Payment Methods";
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Payment Methods</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        <button class="btn btn-primary shadow-sm" id="btnAddPayment" onclick="openAddModal()">
            <i class="fas fa-plus me-2"></i>Add
        </button>
        <button id="btnEdit" class="btn btn-success shadow-sm" disabled onclick="editSelected()">
            <i class="fas fa-edit me-2"></i>Edit
        </button>
        <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
            <i class="fas fa-trash me-2"></i>Delete
        </button>
    </div>
</div>

    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-items-center mb-0" id="paymentMethodsTable">
                            <thead>
                                <tr class="bg-light">
                                    <th class="ps-4" style="width: 50px;">Select</th>
                                    <th>Payment Key</th>
                                    <th>Payment Secret</th>
                                    <th>Status</th>
                                    <th>Created On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.PaymentMethods != null && Model.PaymentMethods.Any())
                                {
                                    @foreach (var item in Model.PaymentMethods)
                                    {
                                        <tr onclick="selectItem(@item.PaymentId, this)" style="cursor: pointer;">
                                            <td class="ps-4 text-center">
                                                <input type="radio" name="selectedPayment" class="form-check-input" value="@item.PaymentId">
                                            </td>
                                            <td>
                                                <span class="badge bg-info-soft text-info fw-bold">@item.PaymentKey</span>
                                            </td>
                                            <td><span class="text-muted">••••••••••••</span></td>
                                            <td class="text-center">
                                                <div class="form-check form-switch d-flex justify-content-center" onclick="event.stopPropagation()">
                                                    <input class="form-check-input" type="checkbox" @(item.IsActive ? "checked" : "") onchange="toggleStatus(@item.PaymentId, this.checked)">
                                                </div>
                                            </td>
                                            <td class="text-center"><span class="text-xs">@item.CreatedOn.ToString("dd MMM yyyy")</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">No payment methods found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom bg-light d-flex align-items-center">
                <h5 class="modal-title fw-bold mb-0" id="modalTitle">Add Payment Method</h5>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-light" id="btnCancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-sm btn-primary shadow-sm" id="btnSave" onclick="saveItem()">Save Changes</button>
                    <button type="button" class="btn-close ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-4">
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="mb-3">
                        <label class="form-label">Payment Key</label>
                        <input type="text" class="form-control" id="txtPaymentKey" required placeholder="e.g. pk_live_xxxxxxxx">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Secret</label>
                        <input type="password" class="form-control" id="txtPaymentSecret" required placeholder="e.g. sk_live_xxxxxxxx">
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="isActive" checked>
                        <label class="form-check-label fw-bold" for="isActive">Active</label>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const itemModal = new bootstrap.Modal(document.getElementById('itemModal'));
        let selectedPaymentId = 0;

        function selectItem(id, row) {
            selectedPaymentId = id;
            // Highlight row
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            // Check radio
            row.querySelector('input[type="radio"]').checked = true;
            // Enable buttons
            document.getElementById('btnEdit').disabled = false;
            document.getElementById('btnDelete').disabled = false;
        }

        function openAddModal() {
            document.getElementById('modalTitle').textContent = 'Add Payment Method';
            document.getElementById('itemForm').reset();
            document.getElementById('txtItemId').value = "0";
            document.getElementById('isActive').checked = true;
            itemModal.show();
        }

        async function editSelected() {
            if (selectedPaymentId === 0) return;
            const resp = await fetch(`/api/PaymentMethodApi/GetById/${selectedPaymentId}`);
            const res = await resp.json();
            if (res.success) {
                document.getElementById('modalTitle').textContent = 'Edit Payment Method';
                document.getElementById('txtItemId').value = res.data.paymentId;
                document.getElementById('txtPaymentKey').value = res.data.paymentKey;
                document.getElementById('txtPaymentSecret').value = res.data.paymentSecret;
                document.getElementById('isActive').checked = res.data.isActive;
                itemModal.show();
            }
        }

        async function deleteSelected() {
            if (selectedPaymentId === 0) return;
            if (!confirm('Are you sure you want to delete this payment method? This action cannot be undone.')) return;

            const resp = await fetch(`/Settings/DeletePaymentMethod?id=${selectedPaymentId}`, { method: 'POST' });
            const res = await resp.json();
            if (res.success) location.reload(); else alert(res.message);
        }

        async function saveItem() {
            // Maps UI parameters to MstPaymentMethodUpsertRequest
            const data = {
                paymentId: parseInt(document.getElementById('txtItemId').value),
                paymentKey: document.getElementById('txtPaymentKey').value.trim(),
                paymentSecret: document.getElementById('txtPaymentSecret').value.trim(),
                isActive: document.getElementById('isActive').checked
            };

            if (!data.paymentKey || !data.paymentSecret) {
                alert('Please fill in all required fields.');
                return;
            }

            const resp = await fetch('/Settings/SavePaymentMethod', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const res = await resp.json();
            if (res.success) location.reload(); else alert(res.message);
        }

        async function toggleStatus(id, isActive) {
            await fetch(`/Settings/TogglePaymentStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
        }
    </script>
}
