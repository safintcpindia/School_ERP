                                    <textarea rows="10" id="editor2" class="form-control" style="height: 300px" placeholder="Enter footer content for Pay Slip..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Online Admission Receipt -->
