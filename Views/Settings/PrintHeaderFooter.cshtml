@*
    ======================================================================
    VIEW: Settings / PrintHeaderFooter.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@{
    Layout = "_Layout";
}

<style>
      .ck-editor__editable_inline {
        min-height: 300px;
      }
      .nav-pills .nav-link{
        background-color: #F5F6F8;
    }
    .nav-pills .nav-link.active{
        background-color:var(--primary);
    }
    </style>

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h4 class="fw-bold mb-0">Print Header Footer</h4>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-2">
        <button type="button" class="btn btn-primary d-inline-flex align-items-center" id="btnSavePrint">
            <i class="ti ti-device-floppy me-1"></i>Save
        </button>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <ul class="nav nav-pills gap-2 mb-4" id="printTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="pill" href="#fees_receipt">Fees Receipt</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="pill" href="#pay_slip">Pay Slip</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="pill" href="#online_admission_receipt">Online Admission Receipt</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="pill" href="#online_exam">Online Exam</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- Fees Receipt -->
                    <div class="tab-pane active" id="fees_receipt">
                        <div class="row align-items-center">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label class="form-label">Header Image (2230 by 300) <span class="text-danger">*</span></label>
                                    <form action="/"
                                          method="post"
                                          class="dropzone dz-clickable"
                                          id="myAwesomeDropzone"
                                          data-plugin="dropzone"
                                          data-previews-container="#file-previews"
                                          data-upload-preview-template="#uploadPreviewTemplate">
                                        <div class="dz-message needsclick">
                                            <i class="ti ti-cloud-upload h1 text-muted"></i>
                                            <h5>Drop files here or click to upload.</h5>
                                            <span class="text-muted fs-13">
                                                (Header Image Resolution is 2230 by
                                                300.)
                                            </span>
                                        </div>
                                    </form>
                                    <!-- Preview -->
                                    <div class="dropzone-previews"
                                         id="file-previews">
                                     </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Footer Content</label>
                                    <textarea rows="10" class="form-control" id="editor" style="height: 300px" placeholder="Enter footer content for Fees Receipt..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pay Slip -->
                    <div class="tab-pane" id="pay_slip">
                        <div class="row align-items-center">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label class="form-label">Header Image (2230 by 300) <span class="text-danger">*</span></label>
                                    <form action="/"
                                          method="post"
                                          class="dropzone dz-clickable"
                                          id="myAwesomeDropzone"
                                          data-plugin="dropzone"
                                          data-previews-container="#file-previews"
                                          data-upload-preview-template="#uploadPreviewTemplate">
                                        <div class="dz-message needsclick">
                                            <i class="ti ti-cloud-upload h1 text-muted"></i>
                                            <h5>Drop files here or click to upload.</h5>
                                            <span class="text-muted fs-13">
                                                (Header Image Resolution is 2230 by
                                                300.)
                                            </span>
                                        </div>
                                    </form>
                                    <!-- Preview -->
