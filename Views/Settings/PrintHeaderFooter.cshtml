                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Online Exam -->
                    <div class="tab-pane" id="online_exam">
                        <div class="row align-items-center">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label class="form-label">Header Image (2230 by 300) <span class="text-danger">*</span></label>
                                    <form action="/"
                                          method="post"
                                          class="dropzone dz-clickable"
                                          id="myAwesomeDropzone"
                                          data-plugin="dropzone"
                                          data-previews-container="#file-previews"
                                          data-upload-preview-template="#uploadPreviewTemplate">
                                        <div class="dz-message needsclick">
                                            <i class="ti ti-cloud-upload h1 text-muted"></i>
                                            <h5>Drop files here or click to upload.</h5>
                                            <span class="text-muted fs-13">
                                                (Header Image Resolution is 2230 by
                                                300.)
                                            </span>
                                        </div>
                                    </form>
                                    <!-- Preview -->
                                    <div class="dropzone-previews"
                                         id="file-previews">
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Footer Content</label>
                                    <textarea rows="10" id="editor4" class="form-control" style="height: 300px" placeholder="Enter footer content for Online Exam..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>                  

                </div>
            </div>
        </div>

        

    </div>
</div>

                                  <!-- file preview template -->
                    <div class="d-none" id="uploadPreviewTemplate">
                        <div class="card mt-2 mb-0 shadow-none border">
                            <div class="p-2">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <img data-dz-thumbnail
                                             src="#"
                                             class="avatar-sm rounded bg-light"
                                             alt="" />
                                    </div>
                                    <div class="col ps-0">
                                        <a href="javascript:void(0);"
                                           class="text-muted fw-bold"
                                           data-dz-name></a>
                                        <p class="mb-0" data-dz-size></p>
                                    </div>
                                    <div class="col-auto">
                                        <!-- Button -->
                                        <a href=""
                                           class="btn btn-link btn-lg text-muted"
                                           data-dz-remove>
                                            <i class="ti ti-x"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- end card -->
                    </div>