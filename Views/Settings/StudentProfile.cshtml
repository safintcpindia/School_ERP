@*
    ======================================================================
    VIEW: Settings / StudentProfile.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@{
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Student Profile Update</h6>
    </div>
    <button class="btn btn-success"><i class="ti ti-cloud me-1"></i> Save</button>
</div>
<!-- End Page Header -->

<div class="row">
    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 ">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search ..." style="min-width: 220px;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- start row -->
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center">
                <p class="mb-0 text-dark">Allow Editable Form Fields</p>
                <div>
                    <div class="form-check form-check-inline">
                        <input type="radio" class="form-check-input" name="allow" id="dis">
                        <label for="dis" class="form-check-label">Disabled</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input type="radio" class="form-check-input" name="allow" id="en">
                        <label for="en" class="form-check-label">Enable</label>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="tab-content">
                    <!-----Student Pane---->
                    <div class="tab-pane active" id="std">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Roll Number
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Middle Name
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-----Parent Pane---->
                    <div class="tab-pane" id="stf">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Designation
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Department
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>



                </div>

            </div>
            <!-- end card-body -->
        </div>
        <!-- end card -->
    </div>
    <!-- end col -->

</div>
<!-- end row -->
