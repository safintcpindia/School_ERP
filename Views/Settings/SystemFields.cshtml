@model List<SchoolERP.Net.Models.FieldModel>
@{
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h6 class="fw-bold mb-0">System Fields</h6>
        <p class="text-muted small mb-0">Enable or disable predefined system fields for various modules.</p>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-tbl-outer">
            <div class="card-header bg-light py-2">
                <div class="d-flex align-items-center justify-content-between">
                    <ul class="nav nav-pills nav-pills-sm gap-2" id="moduleTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#student-fields" type="button">Student</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#staff-fields" type="button">Staff</button>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="tab-content" id="pills-tabContent">
                    <!-- Student Fields -->
                    <div class="tab-pane fade show active" id="student-fields" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Field Name</th>
                                        <th class="text-end pe-4" style="width: 150px;">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var studentFields = Model.Where(f => f.BelongsTo == "students" || f.BelongsTo == "Student").OrderBy(f => f.DisplayOrder).ToList(); }
                                    @if (studentFields.Any())
                                    {
                                        foreach (var field in studentFields)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-semibold text-dark">@field.FieldName</td>
                                                <td class="text-end pe-4">
                                                    <div class="form-check form-switch d-inline-block">
                                                        <input class="form-check-input" type="checkbox" @(field.IsActive ? "checked" : "") 
                                                               onclick="toggleStatus(@field.FieldId, this.checked)">
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center py-4 text-muted">No system fields found for this module.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Staff Fields -->
                    <div class="tab-pane fade" id="staff-fields" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Field Name</th>
                                        <th class="text-end pe-4" style="width: 150px;">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var staffFields = Model.Where(f => f.BelongsTo == "staff" || f.BelongsTo == "Staff").OrderBy(f => f.DisplayOrder).ToList(); }
                                    @if (staffFields.Any())
                                    {
                                        foreach (var field in staffFields)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-semibold text-dark">@field.FieldName</td>
                                                <td class="text-end pe-4">
                                                    <div class="form-check form-switch d-inline-block">
                                                        <input class="form-check-input" type="checkbox" @(field.IsActive ? "checked" : "") 
                                                               onclick="toggleStatus(@field.FieldId, this.checked)">
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center py-4 text-muted">No system fields found for this module.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function toggleStatus(id, isActive) {
            try {
                const response = await fetch('/api/SettingsApi/fields/toggle-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, isActive })
                });
                const result = await response.json();
                if (!result.success) {
                    alert(result.message);
                    location.reload();
                }
            } catch (error) {
                console.error('Error toggling status:', error);
            }
        }
    </script>
}
