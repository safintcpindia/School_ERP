@*
    ======================================================================
    VIEW: Settings / Users.cshtml
    PURPOSE: User interface rendering for the Settings module.
    ======================================================================
*@
@model SchoolERP.Net.Models.UsersPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/Settings", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Settings", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Settings", "Delete");
}

<style>
    .choices__list--dropdown .choices__item--selectable, .choices__list[aria-expanded] .choices__item--selectable{
        padding-right:0;
    }
</style>

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h4 class="fw-bold mb-0">Users</h4>
    </div>
    <div>
        @if (canAdd)
        {
            <button type="button" class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add User
            </button>
        }
        @if (canEdit)
        {
            <button type="button" class="btn btn-info" id="topEditBtn" onclick="editSelectedUser()" disabled>
                <i class="ti ti-pencil me-1"></i> Edit User
            </button>
        }
        @if (canDelete)
        {
            <button type="button" class="btn btn-danger" id="topDeleteBtn" onclick="deleteSelectedUsers()" disabled>
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
    </div>
</div>

<div class="row">

    <div class="col-xl-12">
        <div class="card mb-2">
            <div class="card-body">
                <div class="row align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Financial Year</label>
                        <select class="form-control" data-choices name="choices-single-default" id="choices-single-default">
                            <option value="">Year</option>
                            <option value="Choice 1">2024-25</option>
                            <option value="Choice 2">2025-26</option>                            
                        </select>
                        @* <select class="form-select">
                            <option value="value">Financial Year</option>
                            <option value="value">2024-25</option>
                            <option value="value">2025-26</option>
                        </select> *@
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Organization</label>
                        <select class="form-control" data-choices name="choices-single-default" id="choices-single-default">
                            <option value="">Organization</option>
                            <option value="Choice 1">Org 1</option>
                            <option value="Choice 2">Org 2</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">City</label>
                        <select class="form-control" data-choices name="choices-single-default" id="choices-single-default">
                            <option value="">City</option>
                            <option value="Choice 1">Indore</option>
                            <option value="Choice 2">Bhopal</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">State</label>
                        <select class="form-control" data-choices name="choices-single-default" id="choices-single-default">
                            <option value="">State</option>
                            <option value="Choice 1">Gujarat</option>
                            <option value="Choice 2">Uttar Pradesh</option>
                        </select>
                    </div>
                    <div class="col-md-1 px-0">
                        <label class="form-label"></label>
                        <button class="btn btn-primary w-100"><i class="ti ti-search me-1"></i> Search</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <h4 class="card-title mb-0">User List</h4>
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <div class="input-icon-start position-relative">
                            <span class="input-icon-addon">
                                <i class="ti ti-search"></i>
                            </span>
                            <input type="text" class="form-control" id="searchInput" placeholder="Search Users...">
                        </div>
                    </div>
                </div>             
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="usersTable">
                        <thead>
                            <tr>
                                <th style="width: 40px;">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="selectAllUsers">
                                    </div>
                                </th>
                                <th>#</th>
                                <th>Username</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Created On</th>
                                <th>Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td>
                                        <div class="form-check">
                                            <input class="form-check-input user-checkbox" type="checkbox" value="@user.UserID" data-user='@Html.Raw(Json.Serialize(user))'>
                                        </div>
                                    </td>
                                    <td>@user.UserID</td>
                                    <td>@user.Username</td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td><span class="badge bg-light text-dark">@user.RoleNames</span></td>
                                    <td>@user.CreatedOn.ToString("dd-MM-yyyy")</td>
                                    <td>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" 
                                                   @(user.IsActive ? "checked" : "") 
                                                   onchange="toggleStatus(@user.UserID, this.checked)">
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <a class="btn btn-icon btn-sm" href="#" data-bs-toggle="dropdown">
                                                <i class="ti ti-dots-vertical"></i>
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" href="javascript:void(0);" 
                                                       onclick="openEditModal(@Json.Serialize(user))">
                                                       <i class="ti ti-edit me-1"></i> Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item text-danger" href="javascript:void(0);"
                                                       onclick="deleteUser(@user.UserID)">
                                                        <i class="ti ti-trash me-1"></i> Delete
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title mb-0" id="modalTitle">Add User</h5>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-sm btn-primary" onclick="saveUser()">Save changes</button>                    
                </div>
            </div>
            <div class="modal-body">
                @* Local alert div removed in favor of global toast system *@
                <form id="userForm">
                    <input type="hidden" id="userId" value="0">
                    <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">User Type</label>
                        <select class="form-select form-control searchable-select" id="userTypeId" required>
                            <option value="">Select</option>
                            @foreach (var type in Model.UserTypes)
                            {
                                <option value="@type.UserTypeID">@type.TypeName</option>
                            }
                        </select>
                        <div class="invalid-feedback" id="errUserType"></div>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select form-control searchable-select" id="roleId" required>
                            <option value="">Select Role</option>
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.RoleID">@role.RoleName</option>
                            }
                        </select>
                        <div class="invalid-feedback" id="errRole"></div>
                    </div>


                        @* <div class="col-md-6 mb-3">
                        <label class="form-label">Employee Name</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Mehul Shah</option>
                            <option>Pravin Tambe</option>
                        </select>
                    </div> *@
                        <div class="col-md-3 mb-3">
                            <label class="form-label">User ID</label>
                            <input type="text" class="form-control" id="username" required>
                            <div class="invalid-feedback" id="errUsername"></div>
                        </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" id="fullName" required>
                        <div class="invalid-feedback" id="errFullName"></div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" id="email">
                    </div>
                    
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Mobile Number</label>
                            <input type="text" class="form-control" id="phoneNo">
                        </div>

                        @* <div class="col-md-4 mb-3">
                        <label class="form-label">Dashboard</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Employee</option>
                            <option>Admin</option>                            
                        </select>
                    </div>
                        <div class="col-md-4 mb-3">
                        <label class="form-label">Permission</label>
                        <select class="form-select">
                            <option>Select</option>
                            <option>Reject</option>
                            <option>Pending</option>
                        </select>
                    </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Approved</label>
                            <select class="form-select">
                                <option>Select</option>
                                <option>Pending</option>
                                <option>Reject</option>
                            </select>
                        </div> *@

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Back Days Allow</label>
                            <input type="number" class="form-control" id="backDaysAllow">
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Start Date</label>
                            <input type="date" class="form-control">
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Start Time</label>
                            <input type="time" class="form-control">
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-control">
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">End Time</label>
                            <input type="time" class="form-control">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" id="passwordLabel">Password <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="password">
                            <div class="invalid-feedback" id="errPassword"></div>
                            <small class="text-muted" id="passwordHelp">Leave blank to keep existing password when editing.</small>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Confirm Password</label>
                            <input type="password" class="form-control">
                        </div>                    

                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="name" id="lg" value="" />
                        <label class="form-check-label" for="lg">Login with OTP</label>
                    </div>
                    
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));
        const IV = window.InlineFormValidation;
        const userFieldMap = { 
            userTypeId: 'errUserType', 
            roleId: 'errRole', 
            username: 'errUsername', 
            fullName: 'errFullName', 
            password: 'errPassword' 
        };
        const userModal = new bootstrap.Modal(document.getElementById('userModal'));

        function clearUserModalValidation() {
            IV.clearMap(userFieldMap);
            IV.clearNotice('userModalNotice');
        }

        IV.bindAutoClear(userFieldMap);
        const searchInput = document.getElementById('searchInput');
        const usersTable = document.getElementById('usersTable');
        const topEditBtn = document.getElementById('topEditBtn');
        const topDeleteBtn = document.getElementById('topDeleteBtn');
        const selectAllCheckbox = document.getElementById('selectAllUsers');
        const userCheckboxes = document.querySelectorAll('.user-checkbox');

        $(document).ready(function () {
            if (typeof $.fn.select2 !== 'function') return;

            $('#userModal .searchable-select').each(function () {
                const $ddl = $(this);
                if ($ddl.hasClass('select2-hidden-accessible')) return;
                $ddl.select2({
                    dropdownParent: $('#userModal'),
                    width: '100%',
                    allowClear: true,
                    placeholder: 'Select'
                });
            });
        });

        // Handle Select All
        if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', function() {
                const isChecked = this.checked;
                userCheckboxes.forEach(cb => {
                    if (cb.closest('tr').style.display !== 'none') {
                        cb.checked = isChecked;
                    }
                });
                updateTopButtonsState();
            });
        }

        // Handle Individual Checkbox
        userCheckboxes.forEach(cb => {
            cb.addEventListener('change', updateTopButtonsState);
        });

        function updateTopButtonsState() {
            const checkedBoxes = document.querySelectorAll('.user-checkbox:checked');
            const count = checkedBoxes.length;

            if (topEditBtn) {
                if (count === 1 && permCanEdit) {
                    topEditBtn.removeAttribute('disabled');
                } else {
                    topEditBtn.setAttribute('disabled', 'disabled');
                }
            }

            if (topDeleteBtn) {
                if (count > 0 && permCanDelete) {
                    topDeleteBtn.removeAttribute('disabled');
                } else {
                    topDeleteBtn.setAttribute('disabled', 'disabled');
                }
            }

            if (selectAllCheckbox) {
                const visibleCheckboxes = Array.from(userCheckboxes).filter(cb => cb.closest('tr').style.display !== 'none');
                const checkedVisible = visibleCheckboxes.filter(cb => cb.checked);
                selectAllCheckbox.checked = visibleCheckboxes.length > 0 && visibleCheckboxes.length === checkedVisible.length;
                selectAllCheckbox.indeterminate = checkedVisible.length > 0 && checkedVisible.length < visibleCheckboxes.length;
            }
        }

        function editSelectedUser() {
            if (!permCanEdit) {
                showToast('You do not have permission to edit users.', 'warning');
                return;
            }
            const checkedBox = document.querySelector('.user-checkbox:checked');
            if (checkedBox) {
                const userData = JSON.parse(checkedBox.getAttribute('data-user'));
                openEditModal(userData);
            }
        }

        function deleteSelectedUsers() {
            if (!permCanDelete) {
                showToast('You do not have permission to delete users.', 'warning');
                return;
            }
            const checkedBoxes = document.querySelectorAll('.user-checkbox:checked');
            if (checkedBoxes.length === 0) return;

            if (checkedBoxes.length === 1) {
                deleteUser(checkedBoxes[0].value);
            } else {
                if (confirm(`Are you sure you want to delete ${checkedBoxes.length} selected users?`)) {
                    // For bulk delete, since we don't have a bulk API yet, we can either call deleteUser sequentially
                    // or just alert the user that bulk is not yet implemented fully.
                    // For now, let's process the first one or sequentially.
                    let promises = Array.from(checkedBoxes).map(cb => {
                        return fetch(`/Settings/DeleteUser?id=${cb.value}`, { method: 'POST' }).then(res => res.json());
                    });
                    
                    Promise.all(promises).then(results => {
                        const failed = results.filter(r => !r.success);
                        if (failed.length > 0) {
                            showToast(failed.length + ' users failed to delete.', 'error');
                        }
                        location.reload();
                    }).catch(err => {
                        console.error('Bulk delete error', err);
                        location.reload();
                    });
                }
            }
        }

        // Search Filter
        searchInput.addEventListener('input', function() {
            const filter = this.value.toLowerCase();
            const rows = usersTable.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
            for (let row of rows) {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            }
            updateTopButtonsState();
        });

        function openAddModal() {
            if (!permCanAdd) {
                showToast('You do not have permission to add users.', 'warning');
                return;
            }
            document.getElementById('modalTitle').innerText = 'Add User';
            clearUserModalValidation();
            document.getElementById('userForm').reset();
            document.getElementById('userId').value = '0';
            document.getElementById('passwordLabel').innerHTML = 'Password <span class="text-danger">*</span>';
            document.getElementById('passwordHelp').style.display = 'none';
            document.getElementById('password').required = true;
            $('#userTypeId').val('').trigger('change');
            $('#roleId').val('').trigger('change');
            userModal.show();
        }

        function openEditModal(user) {
            if (!permCanEdit) {
                showToast('You do not have permission to edit users.', 'warning');
                return;
            }
            clearUserModalValidation();
            document.getElementById('modalTitle').innerText = 'Edit User';
            document.getElementById('userId').value = user.userID;
            document.getElementById('username').value = user.username;
            document.getElementById('fullName').value = user.fullName;
            document.getElementById('email').value = user.email;
            document.getElementById('phoneNo').value = user.phoneNo || '';
            document.getElementById('userTypeId').value = user.userTypeID || '';
            document.getElementById('roleId').value = user.defaultRoleID || '';
            $('#userTypeId').val(user.userTypeID || '').trigger('change');
            $('#roleId').val(user.defaultRoleID || '').trigger('change');
            document.getElementById('backDaysAllow').value = user.backDaysAllow || '0';
            document.getElementById('password').value = '';
            document.getElementById('passwordLabel').innerText = 'New Password';
            document.getElementById('passwordHelp').style.display = 'block';
            document.getElementById('password').required = false;
            userModal.show();
        }

        function saveUser() {
            const uid = parseInt(document.getElementById('userId').value) || 0;
            if (uid === 0 && !permCanAdd) {
                showToast('You do not have permission to add users.', 'warning');
                return;
            }
            if (uid > 0 && !permCanEdit) {
                IV.setNotice('userModalNotice', 'You do not have permission to edit users.');
                return;
            }
            clearUserModalValidation();

            const userTypeId = parseInt(document.getElementById('userTypeId').value) || 0;
            const roleId = parseInt(document.getElementById('roleId').value) || 0;
            const username = document.getElementById('username').value.trim();
            const fullName = document.getElementById('fullName').value.trim();
            const password = document.getElementById('password').value;

            let hasError = false;
            if (userTypeId <= 0) { IV.setFieldError('userTypeId', 'errUserType', 'User type is required.'); hasError = true; }
            if (roleId <= 0) { IV.setFieldError('roleId', 'errRole', 'Role is required.'); hasError = true; }
            if (!username) { IV.setFieldError('username', 'errUsername', 'User ID is required.'); hasError = true; }
            if (!fullName) { IV.setFieldError('fullName', 'errFullName', 'Name is required.'); hasError = true; }
            
            if (uid === 0 && !password) {
                IV.setFieldError('password', 'errPassword', 'Password is required for new users.');
                hasError = true;
            }

            if (hasError) return;

            const data = {
                userID: uid,
                username: username,
                fullName: fullName,
                email: document.getElementById('email').value,
                phoneNo: document.getElementById('phoneNo').value,
                password: password,
                userTypeID: userTypeId,
                defaultRoleID: roleId,
                roleIDs: [roleId],
                backDaysAllow: parseInt(document.getElementById('backDaysAllow').value) || 0
            };

            fetch('/Settings/SaveUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    IV.setNotice('userModalNotice', data.message || 'Save failed.');
                }
            })
            .catch(err => console.error('Error:', err));
        }

        function toggleStatus(userId, isActive) {
            fetch(`/Settings/ToggleStatus?userId=${userId}&isActive=${isActive}`, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                if (!data.success) {
                    showToast(data.message, 'error');
                    location.reload();
                }
            })
            .catch(err => {
                console.error('Error:', err);
                location.reload();
            });
        }

        function deleteUser(userId) {
            if (!permCanDelete) {
                showToast('You do not have permission to delete users.', 'warning');
                return;
            }
            if (confirm('Are you sure you want to delete this user?')) {
                fetch(`/Settings/DeleteUser?id=${userId}`, {
                    method: 'POST'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        showToast(data.message, 'error');
                    }
                })
                .catch(err => console.error('Error:', err));
            }
        }
    </script>
}
