                                                <li><a href="/Settings/Maintenance">Maintenance</a></li>
                                                <li><a href="/Settings/Miscellaneous">Miscellaneous</a></li>
                                            </ul>
                                        </li>
                                        <li><a href="/Permission/Index">@Localizer.GetString("permission_master")</a></li>
                                        <li><a href="/Role/Index">@Localizer.GetString("roles_permissions")</a></li>
