                    @{
                        // Load user context for permissions
                        int currentUserId = 0; // 0 = not authenticated/unknown
                        if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            // Prefer standard NameIdentifier, fallback to custom claim used elsewhere
                            var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
                            if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
                        }
                        // If not authenticated, load no permissions (menu becomes empty except static items)
                        if (currentUserId > 0)
                        {
                            PermHelper.LoadPermissions(currentUserId);
                        }

                        // Fetches all active UI elements and groups them by ParentID to form a dynamic 2-level nested tree matrix.
                        var activeMenus = MenuService.GetAllMenus().Where(m => m.IsActive).OrderBy(m => m.DisplayOrder).ToList();
                        var permittedMenuIds = activeMenus.Where(m => PermHelper.HasPermission(m.MenuID, "View")).Select(m => m.MenuID).ToHashSet();
                        var parentMenuIds = activeMenus.Where(m => m.ParentID.HasValue && permittedMenuIds.Contains(m.MenuID)).Select(m => m.ParentID.Value).Distinct().ToHashSet();
                        var allMenus = activeMenus.Where(m => permittedMenuIds.Contains(m.MenuID) || parentMenuIds.Contains(m.MenuID)).ToList();
                        var rootMenus = allMenus.Where(m => m.ParentID == null).ToList();
                    }

                    <!--<ul>
                        <li><a href="#"><i class="ti ti-box"></i> <span>Home</span></a></li>
                        <li><a href="#">About us</a></li>
                    </ul>-->
                    <ul>
                        <!-- <li class="menu-title"><span>@Localizer.GetString("main_menu")</span></li>   -->                     
                        @foreach (var menu in rootMenus)
                        {
                            var children = allMenus.Where(m => m.ParentID == menu.MenuID).ToList();
                            if (children.Any())
                            {

                                <li>
                                    <ul>
                                        <li class="submenu">
                                            <a href="javascript:void(0);">
                                                <i class="@(menu.MenuIcon ?? "ti ti-box")"></i><span> @menu.MenuName</span>
                                                <span class="menu-arrow"></span>
                                            </a>
                                            <ul>

                                                @foreach (var child in children)

                                                {
                                                    <li>
                                                        <a href="@child.MenuURL">

                                                            @child.MenuName
                                                        </a>
                                                    </li>

                                                }
                                            </ul>
                                        </li>
                                    </ul>
                                </li>

                            }
                            else
                            {
                                <li class="submenu">
                                    <a href="@menu.MenuURL">
                                        <i class="@(menu.MenuIcon ?? "ti ti-box")"></i> <span>
                                            @menu.MenuName
                                            </span>
                                    </a>
                                </li>
                            }
                        }


                        <li class="menu-title"><span>@Localizer.GetString("settings")</span></li>
                        <li>
                            <ul>
                                <li class="submenu">
                                    <a href="javascript:void(0);">
