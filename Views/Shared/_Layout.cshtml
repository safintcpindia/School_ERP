    <script src="~/js/inline-form-validation.js" asp-append-version="true"></script>

    <script>
        (function () {
            const ddl = document.getElementById('ddlSessionYear');
            const titleEl = document.getElementById('activeSessionTitle');
            const btnSave = document.getElementById('btnSaveSession');

            if (!ddl || !titleEl || !btnSave) return;

            function getCookie(name) {
                try {
                    const parts = (`; ${document.cookie}`).split(`; ${name}=`);
                    if (parts.length === 2) return parts.pop().split(';').shift() || '';
                } catch { }
                return '';
            }

            async function fetchSessions() {
                const resp = await fetch('/api/SessionApi/GetAll?includeDeleted=false', { method: 'GET' });
                const payload = await resp.json();
                if (!payload || payload.success !== true || !Array.isArray(payload.data)) {
                    throw new Error(payload?.message || 'Failed to load sessions');
                }
                return payload.data;
            }

            function setLoadingState(message) {
                ddl.innerHTML = '';
                const opt = document.createElement('option');
                opt.value = '';
                opt.textContent = message || 'Loading…';
                ddl.appendChild(opt);
                ddl.disabled = true;
                btnSave.disabled = true;
            }

            function populateSessions(sessions) {
                ddl.innerHTML = '';
                for (const s of sessions) {
                    const opt = document.createElement('option');
                    opt.value = String(s.sessionId);
                    opt.textContent = s.sessionTitle || `Session #${s.sessionId}`;
                    ddl.appendChild(opt);
                }
                ddl.disabled = sessions.length === 0;
                btnSave.disabled = sessions.length === 0;
            }

            function selectDefaultSession(sessions) {
                const cookieSessionId = parseInt(getCookie('CurrentSessionId') || '0', 10);
                const fromCookie = cookieSessionId
                    ? (sessions.find(s => s && s.sessionId === cookieSessionId) || null)
                    : null;

                const active = fromCookie || sessions.find(s => s && s.isActive === true) || sessions[0] || null;
                if (!active) {
                    titleEl.textContent = '—';
                    ddl.value = '';
                    return null;
                }
                titleEl.textContent = active.sessionTitle || '—';
                ddl.value = String(active.sessionId);
                return active;
            }

            async function init() {
                try {
                    setLoadingState('Loading…');
                    const sessions = await fetchSessions();
                    populateSessions(sessions);
                    selectDefaultSession(sessions);
                } catch (e) {
                    console.error(e);
                    setLoadingState('No sessions');
                    titleEl.textContent = '—';
                }
            }

            btnSave.addEventListener('click', async function () {
                const selectedId = parseInt(ddl.value || '0', 10);
                if (!selectedId) return;

                btnSave.disabled = true;
                ddl.disabled = true;
                try {
                    const resp = await fetch('/Sessions/SetCurrent', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId: selectedId })
                    });
                    const res = await resp.json();
                    if (!res || res.success !== true) {
                        throw new Error(res?.message || 'Could not set current session.');
                    }
                    window.location.reload();
                } catch (e) {
                    console.error(e);
                    btnSave.disabled = false;
                    ddl.disabled = false;
                }
            });

            init();
        })();
    </script>

    @RenderSection("Scripts", required: false)

</body>

