@model SchoolERP.Net.Models.VehicleAssignPageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Vehicle Assignment";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);

    var canAdd = PermHelper.HasPermissionByUrl("/Transport/VehicleAssign", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Transport/VehicleAssign", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Transport/VehicleAssign", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Vehicle Assignment List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-12 mb-3">
        <div class="card shadow-tbl-outer">
            <div class="card-body py-2">
                <input type="text" class="form-control w-25" id="txtSearch" placeholder="Search by route/vehicle...">
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblAssignments">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 50px;" class="ps-3">Select</th>
                                <th>Route</th>
                                <th>Vehicle</th>
                                <th style="width: 100px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var routeGroup in Model.Items.GroupBy(i => i.RouteID))
                            {
                                var first = routeGroup.First();
                                var assignmentIds = string.Join(",", routeGroup.Select(i => i.VehicleAssignID));
                                var vehicleIds = string.Join(",", routeGroup.Select(i => i.VehicleID));
                                <tr class="item-row" onclick="selectRoute(@first.RouteID, '@assignmentIds', '@vehicleIds', this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="radio" name="selectedItem" class="form-check-input" value="@first.RouteID">
                                    </td>
                                    <td class="fw-bold text-uppercase" style="vertical-align: top;">
                                        @first.RouteName
                                    </td>
                                    <td>
                                        @foreach (var item in routeGroup)
                                        {
                                            <div class="mb-1">@item.VehicleNumber.ToLower()</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@first.VehicleAssignID, this.checked)"
                                                   @(first.IsActive ? "checked" : "")
                                                   @(canEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4">
                                        @if (ViewBag.ErrorMessage != null)
                                        {
                                            <div class="text-danger">Error: @ViewBag.ErrorMessage</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No assignments found.</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="entryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Assign Vehicles to Route</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="entryForm">
                    <div class="row row-gap-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Select Route <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlRoute" required>
                                <option value="">-- Select Route --</option>
                                @foreach (var route in Model.Routes)
                                {
                                    <option value="@route.RouteID">@route.RouteName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Select Vehicles <span class="text-danger">*</span></label>
                            <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                                @foreach (var vehicle in Model.Vehicles)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input vehicle-chk" type="checkbox" value="@vehicle.VehicleID" id="chkVeh_@vehicle.VehicleID">
                                        <label class="form-check-label" for="chkVeh_@vehicle.VehicleID">
                                            @vehicle.VehicleNumber (@vehicle.VehicleModel)
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedRouteId = 0;
    let selectedAssignmentIds = "";
    let selectedVehicleIds = "";
    const canEdit = @canEdit.ToString().ToLower();
    const canDelete = @canDelete.ToString().ToLower();

    function selectRoute(routeId, assignmentIds, vehicleIds, row) {
        selectedRouteId = routeId;
        selectedAssignmentIds = assignmentIds;
        selectedVehicleIds = vehicleIds;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) document.getElementById('btnEdit').disabled = false;
        if (canDelete) document.getElementById('btnDelete').disabled = false;
    }

    document.getElementById('txtSearch').addEventListener('keyup', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblAssignments tbody tr.item-row').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Assignment';
        document.getElementById('entryForm').reset();
        document.getElementById('ddlRoute').disabled = false;
        document.querySelectorAll('.vehicle-chk').forEach(c => c.checked = false);
        new bootstrap.Modal(document.getElementById('entryModal')).show();
    }

    function editSelected() {
        if (!selectedRouteId) return;
        document.getElementById('modalTitle').textContent = 'Edit Assignment';
        document.getElementById('ddlRoute').value = selectedRouteId;
        document.getElementById('ddlRoute').disabled = true;
        
        const vIds = selectedVehicleIds.split(',');
        document.querySelectorAll('.vehicle-chk').forEach(chk => {
            chk.checked = vIds.includes(chk.value);
        });

        new bootstrap.Modal(document.getElementById('entryModal')).show();
    }

    async function saveRecord() {
        const routeId = document.getElementById('ddlRoute').value;
        if (!routeId) { alert('Please select a route'); return; }

        const vehicleIds = [];
        document.querySelectorAll('.vehicle-chk:checked').forEach(c => vehicleIds.push(parseInt(c.value)));
        
        const data = {
            routeID: parseInt(routeId),
            vehicleIDs: vehicleIds,
            isActive: true
        };

        fetch('/api/VehicleAssignApi/UpsertAssignments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('entryModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    async function deleteSelected() {
        if (!selectedAssignmentIds) return;
        if (!confirm('Are you sure you want to remove ALL vehicle assignments for this route?')) return;
        
        const aIds = selectedAssignmentIds.split(',');
        const promises = aIds.map(id => 
            fetch(`/api/VehicleAssignApi/DeleteAssignment/${id}`, { method: 'POST' })
            .then(r => r.json())
        );
        
        const results = await Promise.all(promises);
        const allSuccess = results.every(r => r.success);

        if (allSuccess) {
            showToast('Assignments removed successfully', 'success');
            setTimeout(() => location.reload(), 800);
        } else {
            showToast('Some assignments could not be removed', 'warning');
            setTimeout(() => location.reload(), 800);
        }
    }

    function toggleStatus(id, isActive) {
        fetch(`/api/VehicleAssignApi/ToggleAssignmentStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}
