@model SchoolERP.Net.Models.VehiclePageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Vehicle Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);

    var canAdd = PermHelper.HasPermissionByUrl("/Transport/Vehicles", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Transport/Vehicles", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Transport/Vehicles", "Delete");
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Vehicle List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-12 mb-3">
        <div class="card shadow-tbl-outer">
            <div class="card-body py-2">
                <input type="text" class="form-control w-25" id="txtSearch" placeholder="Search by number/model/driver...">
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblVehicles">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="ps-3">Select</th>
                                <th>Vehicle No</th>
                                <th>Model</th>
                                <th>Reg No</th>
                                <th>Capacity</th>
                                <th>Driver Name</th>
                                <th>Contact</th>
                                <th style="width: 100px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="item-row" onclick="selectItem(@item.VehicleID, this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="radio" name="selectedItem" class="form-check-input" value="@item.VehicleID">
                                    </td>
                                    <td>@item.VehicleNumber</td>
                                    <td>@item.VehicleModel</td>
                                    <td>@item.VehicleRegNo</td>
                                    <td>@item.VehicleMaxCapicity</td>
                                    <td>@item.VehicleDriverName</td>
                                    <td>@item.VehicleDriverContact</td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@item.VehicleID, this.checked)"
                                                   @(item.IsActive ? "checked" : "")
                                                   @(canEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center py-4">
                                        @if (ViewBag.ErrorMessage != null)
                                        {
                                            <div class="text-danger">Error: @ViewBag.ErrorMessage</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No records found.</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="entryModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Vehicle</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="entryForm" enctype="multipart/form-data">
                    <input type="hidden" id="hdnVehicleID" value="0">
                    
                    <div class="row">
                        <!-- Vehicle Details -->
                        <div class="col-md-8">
                            <h6 class="fw-bold mb-3 border-bottom pb-2">Vehicle Information</h6>
                            <div class="row row-gap-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Vehicle Number <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="txtVehicleNumber" required maxlength="50">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Model</label>
                                    <input type="text" class="form-control" id="txtVehicleModel" maxlength="100">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Year Made</label>
                                    <input type="text" class="form-control" id="txtYearMade" maxlength="10">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Registration No</label>
                                    <input type="text" class="form-control" id="txtRegNo" maxlength="50">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Chasis No</label>
                                    <input type="text" class="form-control" id="txtChasisNo" maxlength="50">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Max Capacity</label>
                                    <input type="number" class="form-control" id="txtCapacity">
                                </div>
                                <div class="col-md-8">
                                    <div class="form-check form-switch mt-4">
                                        <input class="form-check-input" type="checkbox" id="chkActive" checked>
                                        <label class="form-check-label" for="chkActive">Active Status</label>
                                    </div>
                                </div>
                            </div>

                            <h6 class="fw-bold mb-3 border-bottom pb-2 mt-4">Driver Information</h6>
                            <div class="row row-gap-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Driver Name</label>
                                    <input type="text" class="form-control" id="txtDriverName" maxlength="200">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Driver Contact</label>
                                    <input type="text" class="form-control" id="txtDriverContact" maxlength="20">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Driver License No</label>
                                    <input type="text" class="form-control" id="txtDriverLicense" maxlength="100">
                                </div>
                            </div>
                        </div>

                        <!-- Side Bar for Photo & Notes -->
                        <div class="col-md-4 border-start">
                            <h6 class="fw-bold mb-3 border-bottom pb-2">Driver Photo</h6>
                            <div class="text-center mb-3">
                                <img id="imgPreview" src="/assets/images/default-user.png" class="img-thumbnail rounded" style="width: 150px; height: 150px; object-fit: cover;">
                            </div>
                            <div class="mb-3">
                                <input type="file" class="form-control form-control-sm" id="filePhoto" accept="image/*" onchange="previewImage(this)">
                            </div>

                            <h6 class="fw-bold mb-3 border-bottom pb-2 mt-4">Notes</h6>
                            <textarea class="form-control" id="txtNote" rows="5" placeholder="Additional notes..."></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedId = 0;
    const canEdit = @canEdit.ToString().ToLower();
    const canDelete = @canDelete.ToString().ToLower();

    function selectItem(id, row) {
        selectedId = id;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) {
            const btnEdit = document.getElementById('btnEdit');
            if (btnEdit) btnEdit.disabled = false;
        }
        if (canDelete) {
            const btnDelete = document.getElementById('btnDelete');
            if (btnDelete) btnDelete.disabled = false;
        }
    }

    document.getElementById('txtSearch').addEventListener('keyup', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblVehicles tbody tr').forEach(row => {
            if (row.classList.contains('item-row')) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            }
        });
    });

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('imgPreview').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
        }
    }

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Vehicle';
        document.getElementById('hdnVehicleID').value = 0;
        document.getElementById('entryForm').reset();
        document.getElementById('chkActive').checked = true;
        document.getElementById('imgPreview').src = '/assets/images/default-user.png';
        new bootstrap.Modal(document.getElementById('entryModal')).show();
    }

    function editSelected() {
        if (!selectedId) return;
        fetch(`/api/VehiclesApi/GetVehicleByID/${selectedId}`)
            .then(r => r.json())
            .then(res => {
                if (!res.success) { showToast(res.message, 'danger'); return; }
                const d = res.data;
                document.getElementById('modalTitle').textContent = 'Edit Vehicle';
                document.getElementById('hdnVehicleID').value = d.vehicleID;
                document.getElementById('txtVehicleNumber').value = d.vehicleNumber;
                document.getElementById('txtVehicleModel').value = d.vehicleModel || '';
                document.getElementById('txtYearMade').value = d.vehicleYearMade || '';
                document.getElementById('txtRegNo').value = d.vehicleRegNo || '';
                document.getElementById('txtChasisNo').value = d.vehicleChasisNo || '';
                document.getElementById('txtCapacity').value = d.vehicleMaxCapicity || '';
                document.getElementById('txtDriverName').value = d.vehicleDriverName || '';
                document.getElementById('txtDriverContact').value = d.vehicleDriverContact || '';
                document.getElementById('txtDriverLicense').value = d.vehicleDriverLicense || '';
                document.getElementById('txtNote').value = d.vehicleNote || '';
                document.getElementById('chkActive').checked = d.isActive;
                
                if (d.vehicleDriverPhotoAttach) {
                    document.getElementById('imgPreview').src = `data:${d.vehicleDriverPhotoType};base64,${d.vehicleDriverPhotoAttach}`;
                } else {
                    document.getElementById('imgPreview').src = '/assets/images/default-user.png';
                }

                new bootstrap.Modal(document.getElementById('entryModal')).show();
            });
    }

    async function saveRecord() {
        const form = document.getElementById('entryForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const formData = new FormData();
        formData.append('VehicleID', document.getElementById('hdnVehicleID').value);
        formData.append('VehicleNumber', document.getElementById('txtVehicleNumber').value.trim());
        formData.append('VehicleModel', document.getElementById('txtVehicleModel').value.trim());
        formData.append('VehicleYearMade', document.getElementById('txtYearMade').value.trim());
        formData.append('VehicleRegNo', document.getElementById('txtRegNo').value.trim());
        formData.append('VehicleChasisNo', document.getElementById('txtChasisNo').value.trim());
        formData.append('VehicleMaxCapicity', document.getElementById('txtCapacity').value || '');
        formData.append('VehicleDriverName', document.getElementById('txtDriverName').value.trim());
        formData.append('VehicleDriverContact', document.getElementById('txtDriverContact').value.trim());
        formData.append('VehicleDriverLicense', document.getElementById('txtDriverLicense').value.trim());
        formData.append('VehicleNote', document.getElementById('txtNote').value.trim());
        formData.append('IsActive', document.getElementById('chkActive').checked);

        const photo = document.getElementById('filePhoto').files[0];
        if (photo) formData.append('DriverPhoto', photo);

        fetch('/api/VehiclesApi/UpsertVehicle', {
            method: 'POST',
            body: formData
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('entryModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    function deleteSelected() {
        if (!selectedId) return;
        if (!confirm('Are you sure you want to delete this vehicle record?')) return;
        fetch(`/api/VehiclesApi/DeleteVehicle/${selectedId}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => {
                showToast(res.message, res.success ? 'success' : 'danger');
                if (res.success) setTimeout(() => location.reload(), 800);
            });
    }

    function toggleStatus(id, isActive) {
        fetch(`/api/VehiclesApi/ToggleVehicleStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}
