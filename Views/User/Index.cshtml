@*
    ======================================================================
    VIEW: User / Index.cshtml
    PURPOSE: User interface rendering for the User module.
    ======================================================================
*@
@model SchoolERP.Net.Models.UsersPageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
}

<link rel="stylesheet" href="~/css/treeview.css" />
<style>
    .choices__list--dropdown .choices__item--selectable, .choices__list[aria-expanded] .choices__item--selectable {
        padding-right: 0;
    }

    /* --- Wizard Step 3 Redesign --- */
    .role-sidebar {
        -background: #f8f9fa;
        min-height: 400px;
    }

    .role-item-card {
        cursor: pointer;
        transition: all 0.2s ease;
        -border: 1px solid transparent !important;
    }

        .role-item-card:hover {
            background-color: #f1f3f9 !important;
            -transform: translateX(4px);
        }

        .role-item-card.active {
            background-color: #eef2ff !important;
            border-color: #5e72e4 !important;
            box-shadow: 0 2px 8px rgba(94, 114, 228, 0.15) !important;
        }

            .role-item-card.active i {
                color: #5e72e4 !important;
                opacity: 1 !important;
            }

    .x-small {
        font-size: 0.7rem;
    }

    .tree-grid {
        border: 1px solid #ddd;
    }

        .tree-grid th {
            padding: 10px 8px;
        }

    .w-s-nowrap {
        white-space: nowrap;
    }

        .w-s-nowrap .form-check-input {
            margin-top: 2px !important;
        }

    .tree-grid-wrapper {
        border-radius: 0;
    }

    /* Indicators */
    .wizard-step {
        cursor: pointer;
    }

        .wizard-step.completed .step-num {
            background: #2dce89 !important;
        }

        .wizard-step.active .step-num {
            background: #5e72e4 !important;
        }


        .top-6{
            top:6px;
        }
</style>


<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">User Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
       
        @if(PermHelper.HasPermissionByUrl("/User", "Add")) {
            <button class="btn btn-primary" id="btnAddUser" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }
        @if(PermHelper.HasPermissionByUrl("/User", "Edit")) {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if(PermHelper.HasPermissionByUrl("/User", "Delete")) {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

