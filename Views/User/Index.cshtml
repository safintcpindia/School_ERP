<!-- Users Table Card -->
<div class="row">

    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    @*  <h5 class="mb-0 fw-bold text-dark">
                    All Users
                    </h5> *@
                    <div class="position-relative border d-flex align-items-center rounded-3 px-3 ">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search users..." style="min-width: 220px;">
                    </div>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle" class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>
                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown" style="">
                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <!--<button type="button" class="btn btn-light btn-md me-2 fw-medium" id="btnResetFilters">Reset</button>
                                    <a href="javascript:void(0);" class="btn btn-secondary btn-md me-2 fw-medium" id="close-filter">Close</a>-->
                                    <button type="button" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">Filter</button>
                                </div>
                            </div>
                            <form action="#">
                                <div class="filter-body pb-0">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">User Type</label>
                                            <select class="form-select form-control select2" id="ddlFilterUserType" data-placeholder="Select user type">
                                                <option value="all">All</option>
                                                @foreach (var ut in Model.UserTypes)
                                                {
                                                    <option value="@ut.UserTypeID">@ut.TypeName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Company</label>
                                            <select class="form-select form-control select2" id="ddlFilterCompany" data-placeholder="Select company">
                                                <option value="all">All</option>
                                                @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                                {
                                                    <option value="@c.CompanyId">@c.SchoolName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Role</label>
                                            <select class="form-select form-control select2" id="ddlFilterRole" data-placeholder="Select role">
                                                <option value="all">All</option>
                                                @foreach (var role in Model.Roles)
                                                {
                                                    <option value="@role.RoleID">@role.RoleName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Status</label>
                                            <select class="form-select form-control select2" id="ddlFilterStatus" data-placeholder="Select status">
                                                <option value="all">All</option>
                                                <option value="active">Active</option>
                                                <option value="inactive">Inactive</option>
                                                <option value="locked">Locked</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    <div class="col-xl-12 mb-2" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="usersTable">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="">Select</th>
                                <th class="">User</th>
                                <th class="">Contact</th>
                                <th class="">User Type</th>
                                <th class="">Role(s)</th>
                                <th class="">Company/School</th>
                                <th class="">Status</th>
                                <th class="">Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var companyNameById = (Model.Companies ?? new List<MstCompanyViewModel>())
                                .GroupBy(c => c.CompanyId)
                                .ToDictionary(g => g.Key, g => g.First().SchoolName);
                            }
                            @foreach (var user in Model.Users)
                            {
                                string initials = "";
                                if (!string.IsNullOrEmpty(user.FullName))
                                {
                                    var parts = user.FullName.Split(' ');
                                    initials = parts.Length >= 2
                                    ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
                                    : $"{parts[0][0]}".ToUpper();
                                }
                                else
                                {
                                    initials = user.Username.Length >= 2
                                    ? user.Username.Substring(0, 2).ToUpper()
                                    : user.Username.ToUpper();
                                }

                                var avatarColors = new[] { "#4e73df", "#1cc88a", "#36b9cc", "#f6c23e", "#e74a3b", "#858796", "#5a5c69" };
                                string avatarColor = avatarColors[Math.Abs(user.UserID.GetHashCode()) % avatarColors.Length];

                                <tr class="user-row"
                                    data-status="@(user.IsLocked ? "locked" : (user.IsActive ? "active" : "inactive"))"
                                    data-user-type-id="@user.UserTypeID"
                                    data-role-ids="@(user.RoleIDs != null ? string.Join(",", user.RoleIDs) : "")"
                                    data-company-ids="@(user.CompanyIDs != null ? string.Join(",", user.CompanyIDs) : "")"
                                    onclick="selectUser(@user.UserID, this, @user.IsLocked.ToString().ToLower())" style="cursor: pointer;">
                                    <td class="ps-4 text-center">
                                        <input type="radio" name="selectedUser" class="form-check-input" value="@user.UserID">
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @*  <div class="avatar-circle me-3" style="background: @avatarColor;">
                                        <span class="avatar-initials">@initials</span>
                                        </div> *@
                                            <div class="d-flex flex-column justify-content-center">
                                                @user.FullName
                                                <p class="text-xs text-primary small mb-0">@@@user.Username</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="mb-0"><i class="ti ti-mail"></i> @user.Email</p>
                                        <p class="mb-0 text-muted"><i class="ti ti-phone"></i> @user.PhoneNo</p>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border fw-normal">@user.UserTypeName</span>
                                    </td>
                                    <td>
                                        @{
                                            string displayRoles = user.RoleNames;
                                            var roleList = displayRoles.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                            var limitedRoles = roleList.Take(2).ToList();
                                            int remainingRoles = roleList.Length - limitedRoles.Count;
                                        }
                                        <div class="list-expandable" onclick="toggleListExpansion(this, event)">
                                            <div class="short-view d-flex flex-wrap gap-1">
                                                @foreach (var role in limitedRoles)
                                                {
                                                    <span class="badge bg-light text-dark border fw-normal">@role.Trim()</span>
                                                }
                                                @if (remainingRoles > 0)
                                                {
                                                    <span class="badge bg-secondary-subtle text-dark border cursor-pointer fw-normal">+@remainingRoles more</span>
                                                }
                                            </div>
                                            <div class="full-view d-none flex-wrap gap-1">
                                                @foreach (var role in roleList)
                                                {
                                                    <span class="badge bg-light text-dark border fw-normal">@role.Trim()</span>
                                                }
                                                <span class="badge bg-dark-subtle text-dark border cursor-pointer fw-normal">less</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @{
                                            var companyNames = (user.CompanyIDs ?? new List<int>())
                                            .Where(cid => companyNameById.ContainsKey(cid))
                                            .Select(cid => companyNameById[cid])
                                            .Distinct()
                                            .ToList();
                                            var limitedCompanies = companyNames.Take(2).ToList();
                                            var remainingCompanyCount = companyNames.Count - limitedCompanies.Count;
                                        }
                                        <div class="list-expandable" onclick="toggleListExpansion(this, event)">
                                            @if (!companyNames.Any())
                                            {
                                                <span class="text-muted">Not Assigned</span>
                                            }
                                            else
                                            {
                                                <div class="short-view d-flex align-items-center gap-1 flex-wrap">
                                                    @foreach (var company in limitedCompanies)
                                                    {
                                                        <span class="badge bg-light text-dark border fw-normal">@company</span>
                                                    }
                                                    @if (remainingCompanyCount > 0)
                                                    {
                                                        <span class="badge bg-secondary-subtle text-dark border cursor-pointer fw-normal">
                                                            +@remainingCompanyCount more
                                                        </span>
                                                    }
                                                </div>
                                                <div class="full-view d-none align-items-center gap-1 flex-wrap">
                                                    @foreach (var company in companyNames)
                                                    {
                                                        <span class="badge bg-light text-dark border fw-normal">@company</span>
                                                    }
                                                    <span class="badge bg-dark-subtle text-dark border cursor-pointer fw-normal">less</span>
                                                </div>
                                            }
                                        </div>
                                    </td>

                                    <td class="align-middle text-center text-sm">
                                        @if (user.IsLocked)
                                        {
                                            <span class="badge badge-sm bg-gradient-danger">
                                                <i class="fas fa-lock me-1"></i>Locked
                                            </span>
                                        }
                                        else if (user.IsActive)
                                        {
                                            <div class="form-check form-switch d-flex justify-content-start mb-0" onclick="event.stopPropagation()">
                                                <input class="form-check-input" type="checkbox" role="switch"
                                                       checked onchange="toggleStatus(@user.UserID, this.checked)"
                                                       id="statusSwitch_@user.UserID">
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="form-check form-switch d-flex justify-content-center mb-0" onclick="event.stopPropagation()">
                                                <input class="form-check-input" type="checkbox" role="switch"
                                                       onchange="toggleStatus(@user.UserID, this.checked)"
                                                       id="statusSwitch_@user.UserID">
                                            </div>
                                        }
                                    </td>
                                    <td class="">
                                        <span class="">@user.CreatedOn.ToString("dd MMM yyyy")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Users.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="fas fa-users text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
                        <p class="text-muted mt-3">No users found. Click "Add New User" to create one.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<!-- Add/Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header justify-content-between align-items-center">
                <div class="d-flex flex-column">
                    <h5 class="modal-title" id="wizardModalTitle">
                        User Wizard
                    </h5>
                    <div class="wizard-steps-indicator d-flex align-items-center mt-3 gap-4">
                        <div class="wizard-step active" data-step="1" onclick="goToWizardStep(1)" style="cursor: pointer;">
                            <span class="step-num">1</span>
                            <span class="step-label d-none d-sm-inline">Identity</span>
                        </div>
                        <div class="wizard-step-line"></div>
                        <div class="wizard-step" data-step="2" onclick="goToWizardStep(2)" style="cursor: pointer;">
                            <span class="step-num">2</span>
                            <span class="step-label d-none d-sm-inline">Companies</span>
                        </div>
                        <div class="wizard-step-line"></div>
                        <div class="wizard-step" data-step="3" onclick="goToWizardStep(3)" style="cursor: pointer;">
                            <span class="step-num">3</span>
                            <span class="step-label d-none d-sm-inline">Permissions</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    @* <button type="button" class="btn btn-sm btn-light px-3" data-bs-dismiss="modal">Cancel</button> *@
                    <div class="ms-auto d-flex gap-2">
                        
                        <button type="button" class="btn btn-sm btn-primary shadow-sm" id="btnWizardNext" onclick="moveWizard(1)">
                            Next <i class="ti ti-arrow-narrow-right ms-1"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-success shadow-sm d-none" id="btnWizardFinish" onclick="finishWizard()">
                            <i class="ti ti-cloud me-1"></i> Save
                        </button>
                        <button type="button" class="btn btn-sm btn-light d-none" id="btnWizardPrev" onclick="moveWizard(-1)">
                            <i class="ti ti-arrow-narrow-left me-1"></i> Back
                        </button>
                        <button class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                    </div>
                </div>
                @* <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Close"></button> *@
            </div>
            <div class="modal-body p-0" style="overflow-y: auto;">
                <div class="wizard-content" style="height: 100%;">
                    <form id="userWizardForm">
                        <input type="hidden" id="txtUserId" value="0">

                        <!-- STEP 1: IDENTITY -->
                        <div class="wizard-pane active p-4" id="step1">
                            <h6 class="text-uppercase text-muted text-xxs font-weight-bolder mb-3">
                                <i class="fas fa-user-circle me-1"></i> Core Identity & Roles
                            </h6>
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label">User Name <span class="text-danger">*</span></label>
                                    <div class="mb-3">
                                        @* <span class="input-group-text bg-light"><i class="fas fa-at text-muted"></i></span> *@
                                        <input type="text" class="form-control" id="txtUsername" placeholder="" required>
                                        <div class="invalid-feedback" id="errTxtUsername"></div>
                                    </div>
                                </div>
                                <div class="col-md-4" id="passwordGroup">
                                    <label class="form-label" id="passwordLabel">Password <span class="text-danger">*</span></label>
                                    <div class="mb-3 position-relative">
                                        @* <span class="input-group-text bg-light"><i class="fas fa-lock text-muted"></i></span> *@
                                        <input type="password" class="form-control" id="txtPassword" placeholder="">
                                        <div class="invalid-feedback" id="errTxtPassword"></div>
                                        <button class="btn position-absolute end-0 top-6" type="button" id="btnTogglePassword">
                                        <i class="fas fa-eye fs-14 text-muted small"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted d-none" id="passwordNote">Leave blank to keep existing.</small>
                                </div>
                                <div class="col-md-4" id="confirmPasswordGroup">
                                    <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
                                    <div class="mb-3 position-relative">
                                        @* <span class="input-group-text bg-light"><i class="fas fa-lock text-muted"></i></span> *@
                                        <input type="password" class="form-control" id="txtConfirmPassword" placeholder="">
                                        <div class="invalid-feedback" id="errTxtConfirmPassword"></div>
                                        <button class="btn position-absolute end-0 top-6" type="button" id="btnTogglePassword2">
                                            <i class="fas fa-eye fs-14 text-muted small"></i>
                                        </button>
                                    </div>
                                    <small class="text-muted d-none" id="passwordNote2">Leave blank to keep existing.</small>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Full Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="txtFullName" placeholder="" required>
                                    <div class="invalid-feedback" id="errTxtFullName"></div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" id="txtEmail" placeholder="">
                                    <div class="invalid-feedback" id="errTxtEmail"></div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">User Type <span class="text-danger">*</span></label>
                                    <select class="form-select form-control searchable-select" id="ddlUserTypeID" required>
                                        <option value="">Select</option>
                                        @foreach (var ut in Model.UserTypes)
                                        {
                                            <option value="@ut.UserTypeID">@ut.TypeName</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback" id="errDdlUserTypeID"></div>
                                </div>
                               


                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Phone Number <span class="text-danger" id="reqPhoneNo">*</span></label>
                                    <input type="text" class="form-control" id="txtPhoneNo" placeholder="" inputmode="numeric" maxlength="10">
                                    <div class="invalid-feedback" id="errTxtPhoneNo"></div>
                                </div>

                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Back Days Allow</label>
