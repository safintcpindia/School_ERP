@*
    ======================================================================
    VIEW: User / Index.cshtml
    PURPOSE: User interface rendering for the User module.
    ======================================================================
*@
@model SchoolERP.Net.Models.UsersPageViewModel
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/treeview.css" />
<style>
    .choices__list--dropdown .choices__item--selectable, .choices__list[aria-expanded] .choices__item--selectable {
        padding-right: 0;
    }

    /* --- Wizard Step 3 Redesign --- */
    .role-sidebar {
        -background: #f8f9fa;
        min-height: 400px;
    }
    .role-item-card {
        cursor: pointer;
        transition: all 0.2s ease;
        -border: 1px solid transparent !important;
    }
    .role-item-card:hover {
        background-color: #f1f3f9 !important;
        -transform: translateX(4px);
    }
    .role-item-card.active {
        background-color: #eef2ff !important;
        border-color: #5e72e4 !important;
        box-shadow: 0 2px 8px rgba(94, 114, 228, 0.15) !important;
    }
    .role-item-card.active i {
        color: #5e72e4 !important;
        opacity: 1 !important;
    }
    .x-small { font-size: 0.7rem; }
    .tree-grid{
        border:1px solid #ddd;
    }
    
        .tree-grid th{
            padding:10px 8px;
        }

    .w-s-nowrap {
        white-space: nowrap;
    }

    .w-s-nowrap .form-check-input{
        margin-top:2px !important;
    }
    .tree-grid-wrapper {
        border-radius: 0;
    }

    /* Indicators */
    .wizard-step { cursor: pointer; }
    .wizard-step.completed .step-num { background: #2dce89 !important; }
    .wizard-step.active .step-num { background: #5e72e4 !important; }

    
</style>


    <!-- Page Header -->
    <div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
        <div>
            <h6 class="fw-bold mb-0">User Management</h6>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <div class="dropdown">
                <a href="#" class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                </a>
                <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown" style="">
                    <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                        <h6 class="mb-0 fw-bold">Select Criteria</h6>
                        <div class="d-flex align-items-center justify-content-end">
                            <a href="javascript:void(0);" class="btn btn-light btn-md me-2 fw-medium" id="close-filter">Close</a>
                            <button type="submit" class="btn btn-primary btn-md fw-medium">Filter</button>
                        </div>
                    </div>
                    <form action="#">
                        <div class="filter-body pb-0">
                            <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label mb-1">Financial Year <span class="text-danger">*</span></label>
                                <select class="form-control" data-choices name="choices-single-default" id="choices-single-default">
                                    <option value="">Year</option>
                                    <option value="Choice 1">2024-25</option>
                                    <option value="Choice 2">2025-26</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label mb-1">Organization <span class="text-danger">*</span></label>
                                <select class="form-select form-control select2">
                                    <option value="m-1" selected="">Select</option>
                                    <option value="m-2">Section A</option>
                                    <option value="m-3">Section B</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label mb-1">City <span class="text-danger">*</span></label>
                                <select class="form-select form-control select2">
                                    <option value="m-1" selected="">Select</option>
                                    <option value="m-2">City 1</option>
                                    <option value="m-3">City 2</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label mb-1">State <span class="text-danger">*</span></label>
                                <select class="form-select form-control select2">
                                    <option value="m-1" selected="">Select</option>
                                    <option value="m-2">State 1</option>
                                    <option value="m-3">State 2</option>
                                </select>
                            </div>
                        </div>
                        </div>

                    </form>
                </div>
            </div>
            <button class="btn btn-primary shadow-sm" id="btnAddUser" onclick="openAddModal()">
                <i class="ti ti-plus me-2"></i>Add
            </button>
            <button id="btnEdit" class="btn btn-info shadow-sm" disabled onclick="editSelected()">
                <i class="ti ti-edit me-2"></i>Edit
            </button>
            <button id="btnUnlock" class="btn btn-warning shadow-sm" disabled onclick="unlockSelected()">
                <i class="ti ti-unlock me-2"></i>Unlock
            </button> 
            <button id="btnDelete" class="btn btn-danger shadow-sm" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-2"></i>Delete
            </button> 
        </div>
    </div>

