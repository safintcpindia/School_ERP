                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase text-muted fw-semibold">Locked</p>
                            <h3 class="fw-bold mb-0 text-danger">@lockedUsers</h3>
                        </div>
                        <div class="stat-icon bg-gradient-danger">
                            <i class="fas fa-lock"></i>
